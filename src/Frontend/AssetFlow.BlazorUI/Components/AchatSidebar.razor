@* src/Frontend/AssetFlow.BlazorUI/Components/AchatSidebar.razor *@
@* Sidebar réutilisable pour toutes les pages Achat *@

@using AssetFlow.BlazorUI.Components

@* ── Overlay ── *@
@if (_drawerOpen)
{
    <div class="achat-drawer-overlay" @onclick="() => _drawerOpen = false"></div>
}

<aside class="achat-sidebar @(_drawerOpen ? "drawer-open" : "")">

    <div class="achat-sidebar-header">
        <img src="images/logo.png" alt="AssetFlow" class="achat-sidebar-logo" />
    </div>

    <nav class="achat-sidebar-nav">
        <a href="/statistiques"       class="achat-nav-link @(ActivePage=="statistiques"  ? "active" : "")" @onclick="() => _drawerOpen = false">
            <span class="achat-nav-icon">
                <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>
            </span>
            <span class="achat-nav-text">Statistiques</span>
        </a>
        <a href="/achat/equipements"  class="achat-nav-link @(ActivePage=="equipements"   ? "active" : "")" @onclick="() => _drawerOpen = false">
            <span class="achat-nav-icon">
                <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </span>
            <span class="achat-nav-text">Mes Équipements</span>
        </a>
        <a href="/achat/materiel"     class="achat-nav-link @(ActivePage=="materiel"      ? "active" : "")" @onclick="() => _drawerOpen = false">
            <span class="achat-nav-icon">
                <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            </span>
            <span class="achat-nav-text">Matériel</span>
        </a>
        <a href="/achat/fournisseurs" class="achat-nav-link @(ActivePage=="fournisseurs"  ? "active" : "")" @onclick="() => _drawerOpen = false">
            <span class="achat-nav-icon">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </span>
            <span class="achat-nav-text">Fournisseurs</span>
        </a>
        <a href="/demandes-achat"     class="achat-nav-link @(ActivePage=="demandes"      ? "active" : "")" @onclick="() => _drawerOpen = false">
            <span class="achat-nav-icon">
                <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            </span>
            <span class="achat-nav-text">Demandes d'achat</span>
            @if (_nombreNonVus > 0)
            {
                <span class="sidebar-badge-rouge">@_nombreNonVus</span>
            }
        </a>
        <a href="/achat/web-scraping" class="achat-nav-link @(ActivePage=="scraping"      ? "active" : "")" @onclick="() => _drawerOpen = false">
            <span class="achat-nav-icon">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            </span>
            <span class="achat-nav-text">Scraping Marché</span>
        </a>
        <a href="/achat/messagerie"   class="achat-nav-link @(ActivePage=="messagerie"    ? "active" : "")" @onclick="() => _drawerOpen = false">
            <span class="achat-nav-icon">
                <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </span>
            <span class="achat-nav-text">Messagerie IT</span>
            @if (_unreadMessages > 0)
            {
                <span class="sidebar-badge-rouge">@(_unreadMessages > 99 ? "99+" : _unreadMessages.ToString())</span>
            }
        </a>
        <a href="/agent-chat" class="achat-nav-link @(ActivePage=="agent" ? "active" : "")" @onclick="() => _drawerOpen = false">
            <span class="achat-nav-icon">
                 <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
                    stroke-linecap="round" stroke-linejoin="round"
                    style="width:20px;height:20px;overflow:visible">

                    <!-- Antenne centrale -->
                    <line x1="12" y1="1.5" x2="12" y2="4.5"/>
                    <circle cx="12" cy="1" r="0.9" fill="currentColor" stroke="none"/>

                    <!-- Antennes latérales -->
                    <line x1="8.5" y1="4" x2="7" y2="2.5"/>
                    <circle cx="6.6" cy="2.1" r="0.7" fill="currentColor" stroke="none"/>
                    <line x1="15.5" y1="4" x2="17" y2="2.5"/>
                    <circle cx="17.4" cy="2.1" r="0.7" fill="currentColor" stroke="none"/>

                    <!-- Corps / tête du bot -->
                    <rect x="5" y="4.5" width="14" height="11" rx="3"
                        fill="rgba(19,109,236,0.15)" stroke="currentColor"/>

                    <!-- Yeux lumineux -->
                    <circle cx="9.2" cy="9.5" r="1.5" fill="currentColor" stroke="none" opacity="0.9"/>
                    <circle cx="14.8" cy="9.5" r="1.5" fill="currentColor" stroke="none" opacity="0.9"/>
                    <!-- Reflets pupils -->
                    <circle cx="9.7" cy="9" r="0.45" fill="white" stroke="none"/>
                    <circle cx="15.3" cy="9" r="0.45" fill="white" stroke="none"/>

                    <!-- Sourire -->
                    <path d="M9 12.5 Q12 14.5 15 12.5" stroke-width="1.5"/>

                    <!-- Jambes / connecteurs -->
                    <line x1="9" y1="15.5" x2="9" y2="18"/>
                    <line x1="15" y1="15.5" x2="15" y2="18"/>
                    <line x1="7" y1="18" x2="11" y2="18"/>
                    <line x1="13" y1="18" x2="17" y2="18"/>
                </svg>
            </span>
            <span class="achat-nav-text">Agent IA</span>
            @if (_stockAlertCount > 0)
            {
                <span class="sidebar-badge-orange" title="@_stockAlertCount alerte(s) de stock">@_stockAlertCount</span>
            }
        </a>
    </nav>

    <div class="achat-sidebar-profile">
        <div class="achat-profile-avatar">@_initiales</div>
        <div class="achat-profile-info">
            <p class="achat-profile-name">@_nomUtilisateur</p>
            <p class="achat-profile-role">@_roleUtilisateur</p>
        </div>
    </div>

    <LogoutButton />

</aside>
