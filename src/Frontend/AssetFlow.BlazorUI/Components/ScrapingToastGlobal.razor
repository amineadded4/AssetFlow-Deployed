@implements IAsyncDisposable
@inject ScrapingBackgroundService ScrapingSvc
@inject IJSRuntime JS
@using AssetFlow.BlazorUI.DTOs

@if (ScrapingSvc.EnCours)
{
    <div class="sgt-container sgt-loading">
        <div class="sgt-spinner"></div>
        <div class="sgt-body">
            <span class="sgt-title">Recherche en cours…</span>
            <span class="sgt-sub">@ScrapingSvc.QueryEnCours</span>
        </div>
    </div>
}
else if (ScrapingSvc.ResultatsPrets && isMobile)
{
    <div class="sgt-container sgt-success">
        <div class="sgt-icon">✓</div>
        <div class="sgt-body">
            <span class="sgt-title">Résultats de Scraping prêt</span>
            <span class="sgt-sub">@ScrapingSvc.QueryEnCours</span>
        </div>
        <a href="/achat/web-scraping" class="sgt-action">Voir</a>
        <button class="sgt-close" @onclick="Fermer">×</button>
    </div>
}

@code {
    private bool isMobile;
    private bool visible = true;
    protected override void OnInitialized()
    {
        ScrapingSvc.OnChanged += OnChanged;
        ScrapingSvc.OnTermine += OnTermine;
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            isMobile = await JS.InvokeAsync<bool>("eval", "window.innerWidth <= 480");
    }
    private void Fermer() => visible = false;

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private async void OnTermine(ScrapingResultatDto res)
    {
        // Notification navigateur uniquement
        await JS.InvokeVoidAsync("scrapingNotifyBrowser",
            res.Succes,
            res.Query,
            res.NombreResultats);

        await InvokeAsync(StateHasChanged);
    }

    public ValueTask DisposeAsync()
    {
        ScrapingSvc.OnChanged -= OnChanged;
        ScrapingSvc.OnTermine -= OnTermine;
        return ValueTask.CompletedTask;
    }
}