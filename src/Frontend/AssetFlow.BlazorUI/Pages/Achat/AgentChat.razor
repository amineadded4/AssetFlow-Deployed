@page "/agent-chat"
@using AssetFlow.BlazorUI.DTOs
@using AssetFlow.BlazorUI.Components
@using Microsoft.AspNetCore.Components.Web

<RoleAuthGuard AllowedRoles="@(new[]{"EquipeAchat","Admin"})">
<div class="ai-shell">

    @* ── AchatSidebar ── *@
        @if (_estAdmin)
        {
            <AdminSidebar ForceOpen="_sidebarOpen" />
        }
        else
        {
            <AchatSidebar ActivePage="agent" ForceOpen="_sidebarOpen" />
        }

    @* ══════════════════════════════════════════════════════════
       HISTORY PANEL
    ══════════════════════════════════════════════════════════ *@
    <div class="ai-history-panel @(_historyOpen ? "open" : "")" aria-hidden="@(!_historyOpen)">
        <div class="ai-history-header">
            <span class="ai-history-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                Conversations
            </span>
            <div style="display:flex;gap:.4rem;align-items:center;">
                <button class="ai-history-new-btn" @onclick="StartNewConversation" title="Nouvelle conversation">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                </button>
                <button class="ai-history-close-btn" @onclick="ToggleHistory" title="Fermer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
        </div>

        <div class="ai-history-list">
            @if (_loadingHistory)
            {
                <div class="ai-history-loading">
                    <div class="ai-history-skeleton"></div>
                    <div class="ai-history-skeleton"></div>
                    <div class="ai-history-skeleton"></div>
                </div>
            }
            else if (_conversations.Count == 0)
            {
                <div class="ai-history-empty">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    </svg>
                    <p>Aucune conversation</p>
                </div>
            }
            else
            {
                @foreach (var group in GetGroupedConversations())
                {
                    <div class="ai-history-group">
                        <span class="ai-history-group-label">@group.Key</span>
                        @foreach (var conv in group.Value)
                        {
                            <div class="ai-history-item @(_activeConversationId == conv.Id ? "active" : "")"
                                 @onclick="() => LoadConversation(conv.Id)">
                                <div class="ai-history-item-body">
                                    @if (_editingConvId == conv.Id)
                                    {
                                        <input class="ai-history-title-input"
                                               @bind="_editingTitle"
                                               @onblur="() => SaveTitle(conv.Id)"
                                               @onkeydown="e => OnTitleKeyDown(e, conv.Id)"
                                               @onclick:stopPropagation="true" />
                                    }
                                    else
                                    {
                                        <span class="ai-history-item-title">@conv.Title</span>
                                    }
                                    <span class="ai-history-item-preview">@conv.LastMessage</span>
                                </div>
                                <div class="ai-history-item-actions" @onclick:stopPropagation="true">
                                    <button class="ai-history-action-btn"
                                            @onclick="() => StartEditTitle(conv.Id, conv.Title)"
                                            title="Renommer">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                        </svg>
                                    </button>
                                    <button class="ai-history-action-btn danger"
                                            @onclick="() => DeleteConversation(conv.Id)"
                                            title="Supprimer">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6l-1 14H6L5 6"/>
                                            <path d="M10 11v6M14 11v6"/>
                                            <path d="M9 6V4h6v2"/>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        </div>

        @if (_conversations.Count > 0)
        {
            <div class="ai-history-footer">
                <button class="ai-history-delete-all-btn" @onclick="DeleteAllConversations">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14H6L5 6"/>
                    </svg>
                    Tout effacer
                </button>
                <span class="ai-history-info">Conservé 30 jours</span>
            </div>
        }
    </div>

    @* ══════════════════════════════════════════════════════════
       NOUVEAU — DEMANDES D'ACHAT PANEL (top-right dropdown)
       + backdrop : un clic en dehors ferme le panneau
    ══════════════════════════════════════════════════════════ *@
    @if (_demandesOpen)
    {
        <div class="ai-demandes-backdrop" @onclick="CloseDemandes"></div>
    }
    <div class="ai-demandes-panel @(_demandesOpen ? "open" : "")"
         aria-hidden="@(!_demandesOpen)"
         @onclick:stopPropagation="true">
        <div class="ai-demandes-header">
            <span class="ai-demandes-title">
                 <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
                Demandes à traiter
                @if (_pendingDemandes.Count > 0)
                {
                    <span class="ai-demandes-count">@_pendingDemandes.Count</span>
                }
            </span>
            <button class="ai-demandes-refresh-btn" @onclick="LoadPendingDemandes" title="Rafraîchir">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
                    <path d="M21 3v5h-5"/>
                    <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
                    <path d="M8 16H3v5"/>
                </svg>
            </button>
        </div>

        <div class="ai-demandes-list">
            @if (_loadingDemandes)
            {
                <div class="ai-history-loading">
                    <div class="ai-history-skeleton"></div>
                    <div class="ai-history-skeleton"></div>
                    <div class="ai-history-skeleton"></div>
                </div>
            }
            else if (_pendingDemandes.Count == 0)
            {
                <div class="ai-history-empty">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                    <p>Aucune demande à traiter</p>
                </div>
            }
            else
            {
                @foreach (var d in _pendingDemandes)
                {
                    <div class="ai-demande-item" @onclick="() => ProcessDemande(d)">
                        <div class="ai-demande-head">
                            <span class="ai-demande-ref">@d.Reference</span>
                            <span class="ai-demande-statut @GetStatutClass(d.Statut)">
                                @GetStatutLabel(d.Statut)
                            </span>
                        </div>
                        <div class="ai-demande-name">@d.NomProduit</div>
                        <div class="ai-demande-meta">
                            <span class="ai-demande-qty">Qté : @d.Quantite</span>
                            <span class="ai-demande-by">par @d.DemandeurNom</span>
                            <span class="ai-demande-date">@d.DateCreation.ToLocalTime().ToString("dd/MM/yy")</span>
                        </div>
                        <div class="ai-demande-action-hint">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="9 18 15 12 9 6"/>
                            </svg>
                            Lancer l'agent IA
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    @* ── Main ── *@
    <div class="ai-main">

        @* ── Topbar ── *@
        <header class="ai-topbar">
            <div class="ai-topbar-left">
                <div class="ai-topbar-brand">
                    <div class="ai-brand-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
                            stroke-linecap="round" stroke-linejoin="round"
                            style="width:20px;height:20px;overflow:visible">

                            <!-- Antenne centrale -->
                            <line x1="12" y1="1.5" x2="12" y2="4.5"/>
                            <circle cx="12" cy="1" r="0.9" fill="currentColor" stroke="none"/>

                            <!-- Antennes latérales -->
                            <line x1="8.5" y1="4" x2="7" y2="2.5"/>
                            <circle cx="6.6" cy="2.1" r="0.7" fill="currentColor" stroke="none"/>
                            <line x1="15.5" y1="4" x2="17" y2="2.5"/>
                            <circle cx="17.4" cy="2.1" r="0.7" fill="currentColor" stroke="none"/>

                            <!-- Corps / tête du bot -->
                            <rect x="5" y="4.5" width="14" height="11" rx="3"
                                fill="rgba(19,109,236,0.15)" stroke="currentColor"/>

                            <!-- Yeux lumineux -->
                            <circle cx="9.2" cy="9.5" r="1.5" fill="currentColor" stroke="none" opacity="0.9"/>
                            <circle cx="14.8" cy="9.5" r="1.5" fill="currentColor" stroke="none" opacity="0.9"/>
                            <!-- Reflets pupils -->
                            <circle cx="9.7" cy="9" r="0.45" fill="white" stroke="none"/>
                            <circle cx="15.3" cy="9" r="0.45" fill="white" stroke="none"/>

                            <!-- Sourire -->
                            <path d="M9 12.5 Q12 14.5 15 12.5" stroke-width="1.5"/>

                            <!-- Jambes / connecteurs -->
                            <line x1="9" y1="15.5" x2="9" y2="18"/>
                            <line x1="15" y1="15.5" x2="15" y2="18"/>
                            <line x1="7" y1="18" x2="11" y2="18"/>
                            <line x1="13" y1="18" x2="17" y2="18"/>
                        </svg>
                    </div>
                    <div>
                        <span class="ai-brand-title">AssetFlow AI</span>
                        <span class="ai-brand-sub">Agent intelligent de gestion</span>
                    </div>
                    <button class="ai-menu-btn" @onclick="() => _sidebarOpen = !_sidebarOpen">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
                        </svg>
                    </button>
                    <button class="ai-history-toggle-btn @(_historyOpen ? "active" : "")"
                            @onclick="ToggleHistory"
                            title="Historique des conversations">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                        </svg>
                        <span>Historique</span>
                        @if (_conversations.Count > 0)
                        {
                            <span class="ai-history-count">@_conversations.Count</span>
                        }
                    </button>
                </div>
            </div>
            <div class="ai-topbar-right">
                @* ── NOUVEAU : bouton dropdown Demandes d'achat ── *@
                <button class="ai-demandes-toggle-btn @(_demandesOpen ? "active" : "")"
                    @onclick="ToggleDemandes"
                    title="Demandes d'achat à traiter">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
                <span>Demandes</span>
                @if (_pendingDemandes.Count > 0)
                {
                    <span class="ai-demandes-count-badge">@_pendingDemandes.Count</span>
                }
            </button>

                <div class="ai-status @(_isLoading ? "status-thinking" : "status-ready")">
                    <div class="ai-status-dot"></div>
                    <span>@(_isLoading ? "Réflexion..." : "Prêt")</span>
                </div>
                <button class="ai-clear-btn" @onclick="StartNewConversation" title="Nouvelle conversation">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
                        <path d="M21 3v5h-5"/>
                        <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
                        <path d="M8 16H3v5"/>
                    </svg>
                    Nouveau
                </button>
            </div>
        </header>

        @* ── Alertes stock — STICKY ── *@
        @if (_alertes.Count > 0 && _showAlertes)
        {
            <div class="ai-alertes-bar ai-alertes-sticky">
                <div class="ai-alertes-header">
                    <div class="ai-alertes-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
                            <path d="M12 9v4"/>
                            <line x1="12" y1="17" x2="12.01" y2="17"/>
                        </svg>
                        @_alertes.Count alerte(s) de stock détectée(s)
                    </div>
                    <button class="ai-alertes-close" @onclick="() => _showAlertes = false" title="Ignorer les alertes">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"/>
                            <line x1="6" y1="6" x2="18" y2="18"/>
                        </svg>
                    </button>
                </div>
                <div class="ai-alertes-list">
                    @foreach (var a in _alertes)
                    {
                        <div class="ai-alerte-card">
                            <div class="ai-alerte-info">
                                <span class="ai-alerte-ref">@a.Reference</span>
                                <span class="ai-alerte-name">@a.Designation</span>
                                <span class="ai-alerte-stock @(a.QuantiteStock == 0 ? "stock-zero" : "stock-low")">
                                    @a.QuantiteStock / @a.QuantiteMin
                                </span>
                            </div>
                            @if (a.Proposition != null)
                            {
                                <button class="ai-alerte-propose-btn" @onclick="() => OpenAlertProposal(a)">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M12 5v14M5 12h14"/>
                                    </svg>
                                    Commander
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Zone de messages ── *@
        <div class="ai-messages-wrap @(_alertes.Count > 0 && _showAlertes ? "has-alertes" : "")" id="ai-messages-container">

            @if (!_chatStarted && !_isLoading)
            {
                <div class="ai-welcome">
                    <div class="ai-welcome-icon">
                        <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                            <circle cx="24" cy="24" r="20" stroke-opacity=".3"/>
                            <circle cx="24" cy="24" r="12" stroke-opacity=".6"/>
                            <circle cx="24" cy="24" r="4" fill="currentColor"/>
                            <line x1="24" y1="4" x2="24" y2="14" stroke-width="2"/>
                            <line x1="24" y1="34" x2="24" y2="44" stroke-width="2"/>
                            <line x1="4" y1="24" x2="14" y2="24" stroke-width="2"/>
                            <line x1="34" y1="24" x2="44" y2="24" stroke-width="2"/>
                        </svg>
                    </div>
                    <h2>Bonjour, je suis votre assistant AssetFlow IA</h2>
                    <p>Je peux vous aider à consulter vos données, rechercher des informations, et créer des matériels, commandes et articles.</p>
                    @if (_pendingDemandes.Count > 0)
                    {
                        <div class="ai-welcome-tip">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                            <span>
                                <strong>@_pendingDemandes.Count demande(s) d'achat</strong> en attente de traitement.
                                Cliquez sur <strong>Demandes</strong> en haut à droite pour les voir.
                            </span>
                        </div>
                    }
                    <div class="ai-suggestions">
                        @foreach (var s in _suggestions)
                        {
                            <button class="ai-suggestion-chip" @onclick="() => SendSuggestion(s)">@s</button>
                        }
                    </div>
                </div>
            }

            @foreach (var msg in _messages)
            {
                <div class="ai-msg @(msg.IsUser ? "ai-msg-user" : "ai-msg-bot")">
                    @if (!msg.IsUser)
                    {
                        <div class="ai-msg-avatar">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
                                stroke-linecap="round" stroke-linejoin="round"
                                style="width:20px;height:20px;overflow:visible">

                                <!-- Antenne centrale -->
                                <line x1="12" y1="1.5" x2="12" y2="4.5"/>
                                <circle cx="12" cy="1" r="0.9" fill="currentColor" stroke="none"/>

                                <!-- Antennes latérales -->
                                <line x1="8.5" y1="4" x2="7" y2="2.5"/>
                                <circle cx="6.6" cy="2.1" r="0.7" fill="currentColor" stroke="none"/>
                                <line x1="15.5" y1="4" x2="17" y2="2.5"/>
                                <circle cx="17.4" cy="2.1" r="0.7" fill="currentColor" stroke="none"/>

                                <!-- Corps / tête du bot -->
                                <rect x="5" y="4.5" width="14" height="11" rx="3"
                                    fill="rgba(19,109,236,0.15)" stroke="currentColor"/>

                                <!-- Yeux lumineux -->
                                <circle cx="9.2" cy="9.5" r="1.5" fill="currentColor" stroke="none" opacity="0.9"/>
                                <circle cx="14.8" cy="9.5" r="1.5" fill="currentColor" stroke="none" opacity="0.9"/>
                                <!-- Reflets pupils -->
                                <circle cx="9.7" cy="9" r="0.45" fill="white" stroke="none"/>
                                <circle cx="15.3" cy="9" r="0.45" fill="white" stroke="none"/>

                                <!-- Sourire -->
                                <path d="M9 12.5 Q12 14.5 15 12.5" stroke-width="1.5"/>

                                <!-- Jambes / connecteurs -->
                                <line x1="9" y1="15.5" x2="9" y2="18"/>
                                <line x1="15" y1="15.5" x2="15" y2="18"/>
                                <line x1="7" y1="18" x2="11" y2="18"/>
                                <line x1="13" y1="18" x2="17" y2="18"/>
                            </svg>
                        </div>
                    }
                    <div class="ai-msg-content-wrap">
                        @if (!msg.IsUser && !string.IsNullOrEmpty(msg.AgentBadge))
                        {
                            <div class="ai-agent-badge @GetAgentBadgeClass(msg.AgentBadge)">
                                @GetAgentBadgeIcon(msg.AgentBadge) @GetAgentBadgeLabel(msg.AgentBadge)
                            </div>
                        }
                        <div class="ai-msg-bubble">
                            @((MarkupString)FormatMessage(msg.Content))
                        </div>

                        @* ══════════════════════════════════════════════════
                             NOUVEAU — Onglets matériels + 4 offres en LECTURE SEULE
                             Si la demande contient plusieurs matériels (Lignes),
                             on affiche un onglet par matériel ; cliquer sur un
                             onglet change les 4 cartes d'offres affichées dessous.
                          ══════════════════════════════════════════════════ *@
                          @{
                              // Construit les groupes à afficher :
                              //   - si OffersByMateriel existe (multi-matériel), on l'utilise
                              //   - sinon on retombe sur OfferCards (mono, ancien comportement)
                              List<MaterielOffersGroupDto>? groupes = msg.OffersByMateriel;
                              if ((groupes == null || groupes.Count == 0)
                                  && msg.OfferCards != null && msg.OfferCards.Count > 0)
                              {
                                  groupes = new List<MaterielOffersGroupDto>
                                  {
                                      new MaterielOffersGroupDto
                                      {
                                          NomProduit = "Matériel",
                                          Quantite   = 0,
                                          Offres     = msg.OfferCards
                                      }
                                  };
                              }
                          }

                          @if (groupes != null && groupes.Count > 0)
                          {
                              @* Onglets matériels (affichés uniquement si > 1 matériel) *@
                              @if (groupes.Count > 1)
                              {
                                  <div class="ai-materiel-tabs" role="tablist">
                                      @for (int i = 0; i < groupes.Count; i++)
                                      {
                                          var idx     = i;
                                          var grp     = groupes[idx];
                                          var active  = msg.ActiveMaterielTab == idx;
                                          <button class="ai-materiel-tab @(active ? "active" : "")"
                                                  role="tab"
                                                  aria-selected="@active"
                                                  @onclick="() => SelectMaterielTab(msg, idx)">
                                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                  <rect x="2" y="7" width="20" height="14" rx="2"/>
                                                  <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                                              </svg>
                                              <span class="ai-materiel-tab-name">@grp.NomProduit</span>
                                              <span class="ai-materiel-tab-qty">×@grp.Quantite</span>
                                              <span class="ai-materiel-tab-count">@grp.Offres.Count offre(s)</span>
                                          </button>
                                      }
                                  </div>
                              }

                              
                                  var safeIdx     = Math.Max(0, Math.Min(msg.ActiveMaterielTab, groupes.Count - 1));
                                  var activeGroup = groupes[safeIdx];
                              

                              @if (groupes.Count > 1)
                              {
                                  <div class="ai-materiel-active-head">
                                      <strong>@activeGroup.NomProduit</strong>
                                      <span class="ai-materiel-active-qty">— Quantité demandée : <b>@activeGroup.Quantite</b></span>
                                  </div>
                              }

                              <div class="ai-offers-grid">
                                  @foreach (var offre in activeGroup.Offres.Take(4))
                                  {
                                      <div class="ai-offer-card readonly">
                                          <div class="ai-offer-head">
                                              <div class="ai-offer-fournisseur">
                                                  <div class="ai-offer-icon">
