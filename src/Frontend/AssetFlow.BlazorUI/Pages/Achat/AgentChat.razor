@* src/Frontend/AssetFlow.BlazorUI/Pages/AgentChat.razor *@
@page "/agent-chat"
@using AssetFlow.BlazorUI.DTOs
@using AssetFlow.BlazorUI.Components
@using Microsoft.AspNetCore.Components.Web

<RoleAuthGuard AllowedRoles="@(new[]{"EquipeAchat"})">
<div class="ai-shell">

    @* ── Sidebar overlay mobile ── *@
    @if (_sidebarOpen)
    { <div class="ai-overlay" @onclick="() => _sidebarOpen = false"></div> }

    @* ── Sidebar selon rôle ── *@
    @if (_estAdmin)
        { <AdminSidebar ForceOpen="_sidebarOpen" /> }
    else if (_role?.Contains("IT", StringComparison.OrdinalIgnoreCase) == true)
        { <ITSidebar ActivePage="agent" ForceOpen="_sidebarOpen" /> }
    else
        { <AchatSidebar ActivePage="agent" ForceOpen="_sidebarOpen" /> }

    @* ── Main ── *@
    <div class="ai-main">

        @* ── Topbar ── *@
        <header class="ai-topbar">
            <div class="ai-topbar-left">
                <button class="ai-menu-btn" @onclick="() => _sidebarOpen = !_sidebarOpen">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
                    </svg>
                </button>
                <div class="ai-topbar-brand">
                    <div class="ai-brand-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M12 2a10 10 0 0 1 10 10c0 5.52-4.48 10-10 10S2 17.52 2 12 6.48 2 12 2z"/>
                            <path d="M8 12h8M12 8v8"/>
                            <circle cx="12" cy="12" r="3" fill="currentColor" opacity=".3"/>
                        </svg>
                    </div>
                    <div>
                        <span class="ai-brand-title">AssetFlow AI</span>
                        <span class="ai-brand-sub">Agent intelligent de gestion</span>
                    </div>
                </div>
            </div>
            <div class="ai-topbar-right">
                <div class="ai-status @(_isLoading ? "status-thinking" : "status-ready")">
                    <div class="ai-status-dot"></div>
                    <span>@(_isLoading ? "Réflexion..." : "Prêt")</span>
                </div>
                <button class="ai-clear-btn" @onclick="ClearChat" title="Nouvelle conversation">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
                    Nouveau
                </button>
            </div>
        </header>

        @* ── Alertes stock — STICKY, visibles en permanence ── *@
        @if (_alertes.Count > 0 && _showAlertes)
        {
            <div class="ai-alertes-bar ai-alertes-sticky">
                <div class="ai-alertes-header">
                    <div class="ai-alertes-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        @_alertes.Count alerte(s) de stock détectée(s)
                    </div>
                    <button class="ai-alertes-close" @onclick="() => _showAlertes = false" title="Ignorer les alertes">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <div class="ai-alertes-list">
                    @foreach (var a in _alertes)
                    {
                        <div class="ai-alerte-card">
                            <div class="ai-alerte-info">
                                <span class="ai-alerte-ref">@a.Reference</span>
                                <span class="ai-alerte-name">@a.Designation</span>
                                <span class="ai-alerte-stock @(a.QuantiteStock == 0 ? "stock-zero" : "stock-low")">
                                    @a.QuantiteStock / @a.QuantiteMin
                                </span>
                            </div>
                            @if (a.Proposition != null)
                            {
                                <button class="ai-alerte-propose-btn"
                                        @onclick="() => OpenAlertProposal(a)">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                                    Commander
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Zone de messages ── *@
        <div class="ai-messages-wrap @(_alertes.Count > 0 && _showAlertes ? "has-alertes" : "")" id="ai-messages-container">

            @* ── Welcome — visible uniquement si aucun message envoyé par l'user ── *@
            @if (!_chatStarted && !_isLoading)
            {
                <div class="ai-welcome">
                    <div class="ai-welcome-icon">
                        <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                            <circle cx="24" cy="24" r="20" stroke-opacity=".3"/>
                            <circle cx="24" cy="24" r="12" stroke-opacity=".6"/>
                            <circle cx="24" cy="24" r="4" fill="currentColor"/>
                            <line x1="24" y1="4" x2="24" y2="14" stroke-width="2"/>
                            <line x1="24" y1="34" x2="24" y2="44" stroke-width="2"/>
                            <line x1="4" y1="24" x2="14" y2="24" stroke-width="2"/>
                            <line x1="34" y1="24" x2="44" y2="24" stroke-width="2"/>
                        </svg>
                    </div>
                    <h2>Bonjour, je suis votre assistant AssetFlow IA</h2>
                    <p>Je peux vous aider à consulter vos données, rechercher des informations, et créer des matériels, commandes et articles.</p>
                    <div class="ai-suggestions">
                        @foreach (var s in _suggestions)
                        {
                            <button class="ai-suggestion-chip" @onclick="() => SendSuggestion(s)">@s</button>
                        }
                    </div>
                </div>
            }

            @foreach (var msg in _messages)
            {
                <div class="ai-msg @(msg.IsUser ? "ai-msg-user" : "ai-msg-bot")">
                    @if (!msg.IsUser)
                    {
                        <div class="ai-msg-avatar">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="M8 12h8M12 8v8"/>
                                <circle cx="12" cy="12" r="3" fill="currentColor" opacity=".3"/>
                            </svg>
                        </div>
                    }
                    <div class="ai-msg-content-wrap">
                        @if (!msg.IsUser && !string.IsNullOrEmpty(msg.AgentBadge))
                        {
                            <div class="ai-agent-badge @GetAgentBadgeClass(msg.AgentBadge)">
                                @GetAgentBadgeIcon(msg.AgentBadge) @GetAgentBadgeLabel(msg.AgentBadge)
                            </div>
                        }
                        <div class="ai-msg-bubble">
                            @((MarkupString)FormatMessage(msg.Content))
                        </div>

                        @* ── Formulaire d'approbation ── *@
                        @if (msg.Action != null && !msg.ActionProcessed)
                        {
                            <div class="ai-approval-form">
                                <div class="ai-approval-header">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    Vérifier et approuver la proposition
                                </div>

                                @* ── Erreurs de validation ── *@
                                @if (msg.ValidationErrors.Count > 0)
                                {
                                    <div class="ai-form-errors">
                                        @foreach (var err in msg.ValidationErrors)
                                        {
                                            <div class="ai-form-error-item">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                                @err
                                            </div>
                                        }
                                    </div>
                                }

                                @* ════════════════════════════════════════════
                                   FORMULAIRE MATÉRIEL (nouveau ou existant)
                                   ════════════════════════════════════════════ *@
                                @if (msg.Action.Type == "add_materiel" && msg.Action.MaterielProposal != null)
                                {
                                    var isExisting = msg.Action.Label?.StartsWith("exists:") == true;

                                    @* Info matériel (lecture seule si existant) *@
                                    <div class="ai-form-section-title">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                                        Informations matériel @(isExisting ? "(matériel existant)" : "")
                                    </div>

                                    <div class="ai-form-grid">
                                        <div class="ai-form-field">
                                            <label>Référence *</label>
                                            @if (isExisting)
                                            {
                                                <div class="ai-readonly-val">@msg.Action.MaterielProposal.Reference</div>
                                            }
                                            else
                                            {
                                                <input class="ai-inp @(msg.FieldErrors.ContainsKey("Reference") ? "ai-inp-err" : "")"
                                                       @bind="msg.Action.MaterielProposal.Reference" />
                                                @if (msg.FieldErrors.TryGetValue("Reference", out var er))
                                                { <span class="ai-field-err">@er</span> }
                                            }
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Désignation *</label>
                                            @if (isExisting)
                                            {
                                                <div class="ai-readonly-val">@msg.Action.MaterielProposal.Designation</div>
                                            }
                                            else
                                            {
                                                <input class="ai-inp @(msg.FieldErrors.ContainsKey("Designation") ? "ai-inp-err" : "")"
                                                       @bind="msg.Action.MaterielProposal.Designation" />
                                                @if (msg.FieldErrors.TryGetValue("Designation", out var ed))
                                                { <span class="ai-field-err">@ed</span> }
                                            }
                                        </div>
                                        <div class="ai-form-field ai-form-field-full">
                                            <label>Description</label>
                                            @if (isExisting)
                                            {
                                                <div class="ai-readonly-val">@(msg.Action.MaterielProposal.Description ?? "—")</div>
                                            }
                                            else
                                            {
                                                <input class="ai-inp" @bind="msg.Action.MaterielProposal.Description" />
                                            }
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Catégorie *</label>
                                            @if (isExisting)
                                            {
                                                <div class="ai-readonly-val">@msg.Action.MaterielProposal.Categorie</div>
                                            }
                                            else
                                            {
                                                <select class="ai-inp @(msg.FieldErrors.ContainsKey("Categorie") ? "ai-inp-err" : "")"
                                                        @bind="msg.Action.MaterielProposal.Categorie">
                                                    <option value="Infrastructure">Infrastructure</option>
                                                    <option value="Normal">Normal</option>
                                                </select>
                                                @if (msg.FieldErrors.TryGetValue("Categorie", out var ec))
                                                { <span class="ai-field-err">@ec</span> }
                                            }
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Stock actuel</label>
                                            <div class="ai-readonly-val">@msg.Action.MaterielProposal.QuantiteStock @msg.Action.MaterielProposal.Unite</div>
                                        </div>
                                        @if (!isExisting)
                                        {
                                            <div class="ai-form-field">
                                                <label>Stock minimum</label>
                                                <input type="number" min="0" class="ai-inp" @bind="msg.Action.MaterielProposal.QuantiteMin" />
                                            </div>
                                            <div class="ai-form-field">
                                                <label>Unité</label>
                                                <input class="ai-inp" @bind="msg.Action.MaterielProposal.Unite" />
                                            </div>
                                            <div class="ai-form-field">
                                                <label>Emplacement</label>
                                                <input class="ai-inp" @bind="msg.Action.MaterielProposal.Emplacement" />
                                            </div>
                                        }
                                    </div>

                                    @* Commande associée *@
                                    @if (msg.Action.MaterielProposal.Commande == null)
                                    {
                                        msg.Action.MaterielProposal.Commande = new AgentCommandeProposal();
                                    }
                                    <div class="ai-form-section-title">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg>
                                        Commande associée *
                                    </div>
                                    <div class="ai-form-grid">
                                        <div class="ai-form-field">
                                            <label>N° Commande *</label>
                                            <input class="ai-inp @(msg.FieldErrors.ContainsKey("NumeroCommande") ? "ai-inp-err" : "")"
                                                   @bind="msg.Action.MaterielProposal.Commande.NumeroCommande"
                                                   placeholder="Ex: CMD-2026-005" />
                                            @if (msg.FieldErrors.TryGetValue("NumeroCommande", out var enc))
                                            { <span class="ai-field-err">@enc</span> }
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Fournisseur</label>
                                            <input class="ai-inp" @bind="msg.Action.MaterielProposal.Commande.NomFournisseur"
                                                   placeholder="Nom du fournisseur" />
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Quantité *</label>
                                            <input type="number" min="1" class="ai-inp @(msg.FieldErrors.ContainsKey("Quantite") ? "ai-inp-err" : "")"
                                                   @bind="msg.Action.MaterielProposal.Commande.QuantiteAchetee"
                                                   @bind:after="() => AjusterArticlesMsg(msg)" />
                                            @if (msg.FieldErrors.TryGetValue("Quantite", out var eq))
                                            { <span class="ai-field-err">@eq</span> }
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Date d'achat</label>
                                            <input type="date" class="ai-inp" @bind="msg.Action.MaterielProposal.Commande.DateAchat" />
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Date livraison</label>
                                            <input type="date" class="ai-inp" @bind="msg.Action.MaterielProposal.Commande.DateLivraison" />
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Fin de garantie</label>
                                            <input type="date" class="ai-inp" @bind="msg.Action.MaterielProposal.Commande.DateFinGarantie" />
                                        </div>
                                    </div>

                                    @* Articles / numéros de série *@
                                    @if (msg.Action.MaterielProposal.Commande.QuantiteAchetee > 0)
                                    {
                                        <div class="ai-articles-section">
                                            <div class="ai-articles-title">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                                                @msg.Action.MaterielProposal.Commande.QuantiteAchetee art. — N° Série <span class="ai-articles-opt">(optionnel)</span>
                                            </div>
                                            <div class="ai-articles-list">
                                                @for (int i = 0; i < msg.Action.MaterielProposal.Commande.NumerosSerie.Count; i++)
                                                {
                                                    var idx = i;
                                                    <div class="ai-article-row">
                                                        <span class="ai-article-num">@(idx + 1)</span>
                                                        <input class="ai-inp"
                                                               placeholder="N° SÉRIE (OPTIONNEL)"
                                                               value="@msg.Action.MaterielProposal.Commande.NumerosSerie[idx]"
                                                               @onchange="e => msg.Action.MaterielProposal.Commande.NumerosSerie[idx] = e.Value?.ToString()" />
                                                        <span class="ai-article-statut">Disponible</span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }

                                @* ════════════════════════════════════════════
                                   FORMULAIRE COMMANDE SEULE
                                   ════════════════════════════════════════════ *@
                                @if (msg.Action.Type == "add_commande" && msg.Action.CommandeProposal != null)
                                {
                                    <div class="ai-form-grid">
                                        <div class="ai-form-field">
                                            <label>N° Commande *</label>
                                            <input class="ai-inp @(msg.FieldErrors.ContainsKey("NumeroCommande") ? "ai-inp-err" : "")"
                                                   @bind="msg.Action.CommandeProposal.NumeroCommande" />
                                            @if (msg.FieldErrors.TryGetValue("NumeroCommande", out var enc))
                                            { <span class="ai-field-err">@enc</span> }
                                        </div>
                                        <div class="ai-form-field">
                                            <label>ID Matériel *</label>
                                            <input type="number" class="ai-inp @(msg.FieldErrors.ContainsKey("MaterielId") ? "ai-inp-err" : "")"
                                                   @bind="msg.Action.CommandeProposal.MaterielId" />
                                            @if (msg.FieldErrors.TryGetValue("MaterielId", out var em))
                                            { <span class="ai-field-err">@em</span> }
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Fournisseur</label>
                                            <input class="ai-inp" @bind="msg.Action.CommandeProposal.NomFournisseur" />
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Quantité *</label>
                                            <input type="number" min="1" class="ai-inp @(msg.FieldErrors.ContainsKey("Quantite") ? "ai-inp-err" : "")"
                                                   @bind="msg.Action.CommandeProposal.QuantiteAchetee"
                                                   @bind:after="() => AjusterArticlesCmdMsg(msg)" />
                                            @if (msg.FieldErrors.TryGetValue("Quantite", out var eq))
                                            { <span class="ai-field-err">@eq</span> }
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Date d'achat</label>
                                            <input type="date" class="ai-inp" @bind="msg.Action.CommandeProposal.DateAchat" />
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Date livraison</label>
                                            <input type="date" class="ai-inp" @bind="msg.Action.CommandeProposal.DateLivraison" />
                                        </div>
                                        <div class="ai-form-field">
                                            <label>Fin de garantie</label>
                                            <input type="date" class="ai-inp" @bind="msg.Action.CommandeProposal.DateFinGarantie" />
                                        </div>
                                    </div>

                                    @* Articles numéros de série *@
                                    @if (msg.Action.CommandeProposal.QuantiteAchetee > 0)
                                    {
                                        <div class="ai-articles-section">
                                            <div class="ai-articles-title">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                                                @msg.Action.CommandeProposal.QuantiteAchetee art. — N° Série <span class="ai-articles-opt">(optionnel)</span>
                                            </div>
                                            <div class="ai-articles-list">
                                                @for (int i = 0; i < msg.Action.CommandeProposal.NumerosSerie.Count; i++)
                                                {
                                                    var idx = i;
                                                    <div class="ai-article-row">
                                                        <span class="ai-article-num">@(idx + 1)</span>
                                                        <input class="ai-inp"
                                                               placeholder="N° SÉRIE (OPTIONNEL)"
                                                               value="@msg.Action.CommandeProposal.NumerosSerie[idx]"
                                                               @onchange="e => msg.Action.CommandeProposal.NumerosSerie[idx] = e.Value?.ToString()" />
                                                        <span class="ai-article-statut">Disponible</span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }

                                @* ════════════════════════════════════════════
                                   FORMULAIRE ARTICLE
                                   ════════════════════════════════════════════ *@
                                @if (msg.Action.Type == "add_article" && msg.Action.ArticleProposal != null)
                                {
                                    @* Infos du matériel associé (lecture seule) *@
                                    @if (msg.MaterielInfo != null)
                                    {
                                        <div class="ai-form-section-title">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                                            Matériel concerné
                                        </div>
                                        <div class="ai-readonly-card">
                                            <div class="ai-readonly-row"><span class="ai-readonly-lbl">Référence</span><span class="ai-readonly-val">@msg.MaterielInfo.Reference</span></div>
                                            <div class="ai-readonly-row"><span class="ai-readonly-lbl">Désignation</span><span class="ai-readonly-val">@msg.MaterielInfo.Designation</span></div>
                                            @if (!string.IsNullOrEmpty(msg.MaterielInfo.Description))
                                            { <div class="ai-readonly-row"><span class="ai-readonly-lbl">Description</span><span class="ai-readonly-val">@msg.MaterielInfo.Description</span></div> }
                                            <div class="ai-readonly-row"><span class="ai-readonly-lbl">Catégorie</span><span class="ai-readonly-val">@msg.MaterielInfo.Categorie</span></div>
                                            <div class="ai-readonly-row"><span class="ai-readonly-lbl">Stock actuel</span><span class="ai-readonly-val">@msg.MaterielInfo.QuantiteStock @msg.MaterielInfo.Unite</span></div>
                                        </div>
                                    }

                                    <div class="ai-form-section-title">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                                        Nouvel article
                                    </div>
                                    <div class="ai-form-grid">
                                        <div class="ai-form-field">
                                            <label>ID Matériel *</label>
                                            <input type="number" class="ai-inp @(msg.FieldErrors.ContainsKey("MaterielId") ? "ai-inp-err" : "")"
                                                   @bind="msg.Action.ArticleProposal.MaterielId" />
                                            @if (msg.FieldErrors.TryGetValue("MaterielId", out var em))
                                            { <span class="ai-field-err">@em</span> }
                                        </div>
                                        <div class="ai-form-field">
                                            <label>ID Commande *</label>
                                            <input type="number" class="ai-inp @(msg.FieldErrors.ContainsKey("CommandeId") ? "ai-inp-err" : "")"
                                                   @bind="msg.Action.ArticleProposal.CommandeId" />
                                            @if (msg.FieldErrors.TryGetValue("CommandeId", out var ecid))
                                            { <span class="ai-field-err">@ecid</span> }
                                        </div>
                                        <div class="ai-form-field ai-form-field-full">
                                            <label>Numéro de série</label>
                                            <input class="ai-inp" @bind="msg.Action.ArticleProposal.NumeroSerie"
                                                   placeholder="Optionnel" />
                                        </div>
                                    </div>
                                }

                                @* ── Boutons d'approbation ── *@
                                <div class="ai-approval-actions">
                                    <button class="ai-approve-btn"
                                            disabled="@_isApproving"
                                            @onclick="() => ApproveAction(msg, true)">
                                        @if (_isApproving) { <div class="ai-spin"></div> }
                                        else { <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> }
                                        Approuver et créer
                                    </button>
                                    <button class="ai-reject-btn"
                                            disabled="@_isApproving"
                                            @onclick="() => ApproveAction(msg, false)">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                        Refuser
                                    </button>
                                </div>
                            </div>
                        }

                        @if (!msg.IsUser)
                        {
                            <div class="ai-msg-time">@msg.Timestamp.ToString("HH:mm")</div>
                        }
                    </div>
                    @if (msg.IsUser)
                    {
                        <div class="ai-msg-avatar ai-msg-user-avatar">
                            @_initiales
                        </div>
                    }
                </div>
            }

            @* ── Indicateur de chargement ── *@
            @if (_isLoading)
            {
                <div class="ai-msg ai-msg-bot">
                    <div class="ai-msg-avatar">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M8 12h8M12 8v8"/>
                        </svg>
                    </div>
                    <div class="ai-msg-content-wrap">
                        <div class="ai-msg-bubble ai-thinking">
                            <div class="ai-dot"></div><div class="ai-dot"></div><div class="ai-dot"></div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Zone de saisie ── *@
        <div class="ai-input-area">
            <div class="ai-input-wrap">
                <textarea
                    id="ai-textarea"
                    class="ai-textarea"
                    placeholder="Posez votre question ou demandez d'ajouter un matériel..."
                    @bind="_inputText"
                    @bind:event="oninput"
                    @onkeydown="OnKeyDown"
                    rows="1"
                    disabled="@_isLoading">
                </textarea>
                <button class="ai-send-btn @(_inputText.Trim().Length > 0 ? "active" : "")"
                        @onclick="SendMessage"
                        disabled="@(_isLoading || _inputText.Trim().Length == 0)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                        <line x1="22" y1="2" x2="11" y2="13"/>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                    </svg>
                </button>
            </div>
            <div class="ai-input-footer">
                <span class="ai-agent-hint">
                    <span class="ai-hint-dot hint-web"></span> Web
                    <span class="ai-hint-dot hint-db"></span> Base de données
                    <span class="ai-hint-dot hint-action"></span> Action
                </span>
                <span class="ai-disclaimer">AssetFlow IA peut faire des erreurs. Vérifiez les informations importantes.</span>
            </div>
        </div>
    </div>
</div>
</RoleAuthGuard>
