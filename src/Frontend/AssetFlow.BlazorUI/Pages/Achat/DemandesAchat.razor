@* ============================================================
   AssetFlow.BlazorUI / Pages / Achat / DemandesAchat.razor
   VERSION FINALE — tableau multi-lignes + bouton scraping amélioré
   ============================================================ *@

@page "/demandes-achat"
@using Microsoft.JSInterop
@using AssetFlow.BlazorUI.Components
@using Microsoft.AspNetCore.Components.Forms

<RoleAuthGuard AllowedRoles="@(new[]{"EquipeAchat"})">
    <div class="layout-shell" data-theme="@_theme">

        @if (_sidebarOpen)
        { <div class="sidebar-overlay" @onclick="ToggleSidebar"></div> }

        @* ══════ SIDEBAR ══════ *@
        <aside class="sidebar @(_sidebarOpen ? "open" : "")">
            <div class="sidebar-header">
                <img src="images/logo.png" alt="AssetFlow" class="sidebar-logo-img" />
            </div>
            <nav class="sidebar-nav">
                <a href="/statistiques" class="nav-link">
                    <span class="nav-icon"><svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg></span>
                    <span class="nav-text">Statistiques</span>
                </a>
                <a href="/achat/equipements" class="nav-link">
                    <span class="nav-icon"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></span>
                    <span class="nav-text">Mes Équipements</span>
                </a>
                <a href="/achat/materiel" class="nav-link">
                    <span class="nav-icon"><svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></span>
                    <span class="nav-text">Matériel</span>
                </a>
                <a href="/achat/fournisseurs" class="nav-link">
                    <span class="nav-icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
                    <span class="nav-text">Fournisseurs</span>
                </a>
                <a href="/demandes-achat" class="nav-link active">
                    <span class="nav-icon"><svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></span>
                    <span class="nav-text">Demande d'achat</span>
                </a>
                <a href="/achat/web-scraping" class="nav-link">
                    <span class="nav-icon"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></span>
                    <span class="nav-text">Scraping Marché</span>
                </a>
            </nav>
            <div class="sidebar-profile">
                <div class="profile-avatar">@_initiales</div>
                <div class="profile-info">
                    <p class="profile-name">@_nomUtilisateur</p>
                    <p class="profile-role">@_roleUtilisateur</p>
                </div>
            </div>
            <LogoutButton />
        </aside>

        @* ══════ ZONE PRINCIPALE ══════ *@
        <main class="main-zone">

            <header class="topbar">
                <div class="topbar-row1">
                    <button class="topbar-menu-btn" @onclick="ToggleSidebar">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <line x1="3" y1="6"  x2="21" y2="6"/>
                            <line x1="3" y1="12" x2="21" y2="12"/>
                            <line x1="3" y1="18" x2="21" y2="18"/>
                        </svg>
                    </button>
                    <div class="topbar-brand">
                        <h1>Demandes d'achat</h1>
                        <span class="topbar-role-badge">Agent Achat</span>
                    </div>
                    <div class="topbar-export-btns">
                        <button class="btn-export" @onclick="ExporterExcel" title="Exporter en Excel">
                            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/></svg>
                            <span>Excel</span>
                        </button>
                        <button class="btn-export btn-export-pdf" @onclick="ExporterPdf" title="Exporter en PDF">
                            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/></svg>
                            <span>PDF</span>
                        </button>
                    </div>
                    <div class="topbar-search topbar-search-desktop">
                        <span class="search-icon"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
                        <input class="search-input" type="text" placeholder="Rechercher une demande…" @oninput="OnRecherche" />
                    </div>
                </div>
                <div class="topbar-row2">
                    <div class="topbar-search topbar-search-mobile">
                        <span class="search-icon"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
                        <input class="search-input" type="text" placeholder="Rechercher une demande…" @oninput="OnRecherche" />
                    </div>
                </div>
            </header>

            <div class="split-layout">

                @* ── LISTE GAUCHE ── *@
                <div class="list-col">
                    <div class="status-tabs">
                        <button class="status-tab @(_tabActive == "tous"       ? "tab-active" : "")" @onclick='() => SetTab("tous")'>
                            Toutes <span class="tab-count">@_demandes.Count(d => d.Statut != "traite" && d.Statut != "refuse")</span>
                        </button>
                        <button class="status-tab @(_tabActive == "en_attente" ? "tab-active" : "")" @onclick='() => SetTab("en_attente")'>
                            En attente <span class="tab-count tab-count-nouveau">@_demandes.Count(d => d.Statut == "en_attente")</span>
                        </button>
                        <button class="status-tab @(_tabActive == "commande"   ? "tab-active" : "")" @onclick='() => SetTab("commande")'>
                            Commandée <span class="tab-count">@_demandes.Count(d => d.Statut == "commande")</span>
                        </button>
                        <button class="status-tab @(_tabActive == "historique" ? "tab-active" : "")" @onclick='() => SetTab("historique")'>
                            Historique <span class="tab-count">@_demandes.Count(d => d.Statut == "traite" || d.Statut == "refuse")</span>
                        </button>
                    </div>

                    <div class="demand-list">
                        @if (_chargement)
                        {
                            <div class="list-empty"><span>Chargement…</span></div>
                        }
                        else if (!DemandesFiltrees.Any())
                        {
                            <div class="list-empty">
                                <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg>
                                <span>Aucune demande</span>
                            </div>
                        }
                        else
                        {
                            @foreach (var d in DemandesFiltrees)
                            {
                                <div class="demand-card @(_demandeSelectionnee?.Id == d.Id ? "card-selected" : "")"
                                     @onclick="() => SelectionnerDemande(d)">
                                    <div class="card-top">
                                        <span class="card-ref">@d.Reference</span>
                                        <span class="card-date">@FormatDateCarte(d.DateCreation)</span>
                                    </div>
                                    <p class="card-titre">@d.NomProduit</p>
                                    @if (d.Lignes.Any())
                                    {
                                        <p class="card-lignes-count">
                                            <svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                                            @d.Lignes.Count matériel(s)
                                        </p>
                                    }
                                    <div class="card-bottom">
                                        <div class="card-demandeur">
                                            <div class="mini-avatar">@d.Initiales</div>
                                            <span>@d.DemandeurNom</span>
                                        </div>
                                        <span class="status-pill status-@d.Statut">@LibelleStatut(d.Statut)</span>
                                    </div>
                                    @if (d.Offres.Any(o => o.EstChoisie))
                                    {
                                        <div class="card-offre-flag">
                                            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                                            Offre choisie par l'IT
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>

                @* ── DÉTAIL DROITE ── *@
                <div class="detail-col">
                    @if (_demandeSelectionnee == null)
                    {
                        <div class="detail-empty">
                            <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                            <p>Sélectionnez une demande<br />pour voir son détail</p>
                        </div>
                    }
                    else
                    {
                        var dem = _demandeSelectionnee;
                        <div class="detail-scroll">

                            @* ── EN-TÊTE ── *@
                            <div class="detail-header">
                                <div class="detail-ref-row">
                                    <span class="detail-ref">@dem.Reference</span>
                                    <span class="status-pill status-@dem.Statut status-pill-lg">@LibelleStatut(dem.Statut)</span>
                                    @if (dem.Statut == "en_attente")
                                    { <span class="nouveau-badge">EN ATTENTE</span> }
                                </div>
                                <div class="detail-meta">
                                    <div class="meta-demandeur">
                                        <div class="meta-avatar">@dem.Initiales</div>
                                        <span class="meta-name">@dem.DemandeurNom</span>
                                    </div>
                                    <span class="meta-sep">·</span>
                                    <span class="meta-date">
                                        Créée le @dem.DateCreation.ToString("dd MMMM yyyy")
                                        à @dem.DateCreation.ToString("HH:mm")
                                    </span>
                                </div>
                            </div>

                            @* ── DESCRIPTION ── *@
                            @if (!string.IsNullOrEmpty(dem.Description))
                            {
                                <section class="detail-section">
                                    <h3 class="section-title">
                                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                                        Description du besoin
                                    </h3>
                                    <p class="section-text">@dem.Description</p>
                                </section>
                            }

                            @* ── DÉTAIL COMMANDE ── *@
                            <section class="detail-section">
                                <div class="section-title-row">
                                    <h3 class="section-title">
                                        <svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                                        Détail de la commande
                                        @if (dem.Lignes.Any())
                                        {
                                            <span class="section-count">@dem.Lignes.Count matériel(s)</span>
                                        }
                                    </h3>
                                    <a href="@($"/achat/web-scraping?q={Uri.EscapeDataString(dem.NomProduit)}")" class="btn-scraping">
                                        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                                        Recherche de prix
                                    </a>
                                </div>

                                @if (dem.Lignes.Any())
                                {
                                    <div class="articles-table">
                                        <div class="articles-head articles-head-multi">
                                            <span>#</span>
                                            <span>Référence</span>
                                            <span>Produit</span>
                                            <span>Description</span>
                                            <span class="col-qty">Qté</span>
                                            <span>Recherche de prix</span>
                                        </div>
                                        @foreach (var (ligne, idx) in dem.Lignes.Select((l, i) => (l, i)))
                                        {
                                            <div class="article-row article-row-multi">
                                                <span class="article-line-num">@(idx + 1)</span>
                                                <span class="article-line-ref">@(string.IsNullOrEmpty(ligne.Reference) ? "—" : ligne.Reference)</span>
                                                <div class="article-name">
                                                    <div class="article-ico">
                                                        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                                                    </div>
                                                    @ligne.NomProduit
                                                </div>
                                                <span class="article-line-desc">@(string.IsNullOrEmpty(ligne.Description) ? "—" : ligne.Description)</span>
                                                <span class="article-qty col-qty">@ligne.Quantite</span>
                                                <div class="btn-scraping-ligne-wrap">
                                                    <a href="@($"/achat/web-scraping?q={Uri.EscapeDataString(ligne.NomProduit)}")"
                                                       class="btn-scraping-ligne"
                                                       title="Rechercher le prix de @ligne.NomProduit">
                                                        <svg viewBox="0 0 24 24">
                                                            <circle cx="11" cy="11" r="8"/>
                                                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                                                            <line x1="11" y1="8"  x2="11" y2="14"/>
                                                            <line x1="8"  y1="11" x2="14" y2="11"/>
                                                        </svg>
                                                        Scraping
                                                    </a>
                                                </div>
                                            </div>
                                        }
                                        <div class="article-row article-total-row">
                                            <span></span>
                                            <span></span>
                                            <span class="article-total-label">Total</span>
                                            <span></span>
                                            <span class="article-qty col-qty article-total-qty">@dem.Lignes.Sum(l => l.Quantite)</span>
                                            <span></span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="articles-table">
                                        <div class="articles-head">
                                            <span>Référence</span>
                                            <span>Produit</span>
                                            <span class="col-qty">Quantité</span>
                                        </div>
                                        <div class="article-row">
                                            <div class="article-name">
                                                <div class="article-ico"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></div>
                                                @dem.Reference
                                            </div>
                                            <span class="article-cat">@dem.NomProduit</span>
                                            <span class="article-qty col-qty">@dem.Quantite</span>
                                        </div>
                                    </div>
                                }
                            </section>

                            @* ── OFFRES PDF ── *@
                            <section class="detail-section">
                                <div class="section-title-row">
                                    <h3 class="section-title">
                                        <svg viewBox="0 0 24 24"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                                        Offres attachées
                                    </h3>
                                    @if (dem.Statut != "traite" && dem.Statut != "refuse")
                                    {
                                        var fileInputId = $"file-{dem.Id}";
                                        <label class="btn-attach" for="@fileInputId">
                                            <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                            Ajouter une offre
                                        </label>
                                        <InputFile id="@fileInputId" style="display:none" accept=".pdf" multiple OnChange="e => AjouterOffres(e, dem.Id)" />
                                    }
                                </div>

                                @if (!dem.Offres.Any())
                                {
                                    <div class="drop-zone">
                                        <div class="drop-icon"><svg viewBox="0 0 24 24"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg></div>
                                        <span class="drop-title">Aucune offre attachée</span>
                                        <span class="drop-sub">Cliquez « Ajouter une offre » pour joindre un PDF (max. 10 Mo)</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="offres-list">
                                        @foreach (var o in dem.Offres)
                                        {
                                            <div class="offre-item @(o.EstChoisie ? "offre-choisie" : "")">
                                                <div class="offre-pdf-ico"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
                                                <div class="offre-info">
                                                    <span class="offre-nom">@o.NomFichier</span>
                                                    <span class="offre-taille">@FormatTaille(o.Taille)</span>
                                                </div>
                                                @if (o.EstChoisie)
                                                {
                                                    <span class="offre-choisie-badge">
                                                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                                                        Choisie par l'IT
                                                    </span>
                                                }
                                                <div class="offre-btns">
                                                    <button class="offre-btn" title="Aperçu" @onclick="() => PrevisualiserOffre(o)">
                                                        <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                                    </button>
                                                    @if (dem.Statut != "traite" && dem.Statut != "refuse")
                                                    {
                                                        <button class="offre-btn offre-btn-del" title="Supprimer" @onclick="() => SupprimerOffre(dem.Id, o.Id)">
                                                            <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </section>

                            @* ── GESTION ── *@
                            @if (dem.Statut != "traite" && dem.Statut != "refuse")
                            {
                                <section class="detail-section section-gestion">
                                    <h3 class="section-title">
                                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                        Gestion de la demande
                                    </h3>
                                    <div class="gestion-grid">
                                        <div class="gestion-block">
                                            <p class="gestion-label">Changer le statut</p>
                                            <div class="statut-btns">
                                                <button class="btn-statut btn-statut-en_cours @(dem.Statut == "en_attente" ? "statut-actif" : "")"
                                                        @onclick='() => ChangerStatut(dem.Id, "en_attente")'
                                                        disabled="@(dem.Statut == "en_attente")">En attente</button>
                                                <button class="btn-statut btn-statut-commande @(dem.Statut == "commande" ? "statut-actif" : "")"
                                                        @onclick='() => ChangerStatut(dem.Id, "commande")'
                                                        disabled="@(dem.Statut == "commande")">Commandée</button>
                                                <button class="btn-statut btn-statut-traite"
                                                        @onclick='() => ChangerStatut(dem.Id, "traite")'>Traitée → Archiver</button>
                                            </div>
                                        </div>
                                        <div class="gestion-block gestion-block-danger">
                                            <p class="gestion-label">Refuser la demande</p>
                                            <textarea class="motif-textarea" rows="2"
                                                      placeholder="Motif du refus (obligatoire)…"
                                                      @bind="_motifRefus" @bind:event="oninput"></textarea>
                                            <button class="btn-refuser"
                                                    disabled="@string.IsNullOrWhiteSpace(_motifRefus)"
                                                    @onclick="() => RefuserDemande(dem.Id)">
                                                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                                Refuser & archiver
                                            </button>
                                        </div>
                                    </div>
                                </section>
                            }

                            @* ── BANNIÈRES ── *@
                            @if (dem.Statut == "refuse" && !string.IsNullOrEmpty(dem.MotifRefus))
                            {
                                <div class="refus-banner">
                                    <div class="refus-banner-ico"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></div>
                                    <div><strong>Demande refusée</strong><p>@dem.MotifRefus</p></div>
                                </div>
                            }
                            @if (dem.Statut == "traite")
                            {
                                <div class="traite-banner">
                                    <div class="traite-banner-ico"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>
                                    <div><strong>Demande traitée</strong><p>Archivée dans l'historique.</p></div>
                                </div>
                            }

                        </div>
                    }
                </div>
            </div>
        </main>

        @* ══════ MODALE PDF ══════ *@
        @if (_offrePreview != null)
        {
            <div class="modal-overlay" @onclick="FermerPreview">
                <div class="modal-pdf" @onclick:stopPropagation="true">
                    <div class="modal-pdf-hdr">
                        <div class="modal-pdf-title">
                            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                            @_offrePreview.NomFichier
                        </div>
                        <button class="modal-close" @onclick="FermerPreview">
                            <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    </div>
                    <div class="modal-pdf-body">
                        @if (!string.IsNullOrEmpty(_offrePreview.PdfUrl))
                        { <iframe src="@_offrePreview.PdfUrl" title="Aperçu PDF"></iframe> }
                        else
                        {
                            <div class="pdf-no-preview">
                                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                <p>Aperçu non disponible</p>
                                <small>@_offrePreview.NomFichier</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        @* ══════ TOAST ══════ *@
        @if (!string.IsNullOrEmpty(_toastMsg))
        { <div class="toast @_toastType">@_toastMsg</div> }

    </div>
</RoleAuthGuard>
