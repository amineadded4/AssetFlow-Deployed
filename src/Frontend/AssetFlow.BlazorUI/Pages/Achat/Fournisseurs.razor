@page "/achat/fournisseurs"
@using AssetFlow.BlazorUI.Pages.Achat
@using AssetFlow.BlazorUI.Components
<RoleAuthGuard AllowedRoles="@(new[]{"EquipeAchat","Admin"})">
    <div class="layout-shell">

        @if (_sidebarOpen)
        {
            <div class="sidebar-overlay" @onclick="ToggleSidebar"></div>
        }

        @if (_estAdmin)
        {
            <AdminSidebar ForceOpen="_sidebarOpen" />
        }
        else
        {
            <AchatSidebar ActivePage="fournisseurs" ForceOpen="_sidebarOpen" />
        }

        <main class="main-zone">

            
            <header class="topbar">
                <button class="topbar-menu-btn" @onclick="ToggleSidebar" aria-label="Menu">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <line x1="3" y1="6"  x2="21" y2="6"/>
                        <line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    </svg>
                </button>

                <div class="search-wrap">
                    <span class="search-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"/>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                    </span>
                    <input class="search-input" type="text"
                        placeholder="Rechercher un fournisseur…"
                        @oninput="OnRecherche" />
                </div>

                <div class="topbar-right">
                    <button class="btn-add" @onclick="() => OuvrirFormulaire(null)">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5"  y1="12" x2="19" y2="12"/>
                        </svg>
                        Nouveau Fournisseur
                    </button>
                </div>
            </header>

            <div class="page-content">

                
                <div class="page-hero">
                    <div class="hero-left">
                        <div class="hero-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                        <div>
                            <h1 class="hero-title">Performance des Fournisseurs</h1>
                            <p class="hero-sub">Analyse temps réel de la fiabilité logistique et opérationnelle.</p>
                        </div>
                    </div>
                    <div class="hero-actions">
                        <button class="btn-export" @onclick="ExporterExcel">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="16" y1="13" x2="8" y2="13"/>
                                <line x1="16" y1="17" x2="8" y2="17"/>
                                <polyline points="10 9 9 9 8 9"/>
                            </svg>
                            Excel
                        </button>
                        <button class="btn-export" @onclick="ExporterPdf">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                            </svg>
                            PDF
                        </button>
                    </div>
                </div>

                
                <div class="kpi-row">
                    <div class="kpi-card kpi-blue">
                        <div class="kpi-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                        <div class="kpi-body">
                            <span class="kpi-label">Fournisseurs</span>
                            <span class="kpi-value">@_totalFournisseurs</span>
                        </div>
                        <span class="kpi-pill">@_totalFournisseurs enregistré@(_totalFournisseurs > 1 ? "s" : "")</span>
                    </div>

                    <div class="kpi-card kpi-teal">
                        <div class="kpi-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                            </svg>
                        </div>
                        <div class="kpi-body">
                            <span class="kpi-label">Commandes totales</span>
                            <span class="kpi-value">@_totalCommandes</span>
                        </div>
                        <span class="kpi-pill">Toutes périodes</span>
                    </div>

                    <div class="kpi-card kpi-amber">
                        <div class="kpi-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                        </div>
                        <div class="kpi-body">
                            <span class="kpi-label">Moy. commandes</span>
                            <span class="kpi-value">@(_totalFournisseurs > 0 ? (_totalCommandes / _totalFournisseurs).ToString("0.0") : "—")</span>
                        </div>
                        <span class="kpi-pill">Par fournisseur</span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_erreurGlobale))
                {
                    <div class="alert-error">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        @_erreurGlobale
                    </div>
                }

                
                <div class="section-header">
                    <div class="section-title-group">
                        <h2 class="section-title">Liste des Fournisseurs</h2>
                        <span class="count-badge">@_fournisseursAffiches.Count résultat@(_fournisseursAffiches.Count > 1 ? "s" : "")</span>
                    </div>
                </div>

                <div class="table-card">
                    <div class="table-scroll">
                        <table>
                            <thead>
                                <tr>
                                    <th>Fournisseur</th>
                                    <th>Commandes</th>
                                    <th>Dernière commande</th>
                                    <th>Contact</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_chargement)
                                {
                                    <tr><td colspan="5" class="td-loading">
                                        <span class="spinner"></span>
                                        Chargement des fournisseurs…
                                    </td></tr>
                                }
                                else if (!_fournisseursAffiches.Any())
                                {
                                    <tr><td colspan="5" class="td-empty">
                                        <div class="empty-state">
                                            <div class="empty-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                                    <circle cx="9" cy="7" r="4"/>
                                                </svg>
                                            </div>
                                            <p>Aucun fournisseur trouvé</p>
                                            <span>Essayez un autre terme ou ajoutez un fournisseur.</span>
                                        </div>
                                    </td></tr>
                                }
                                else
                                {
                                    @foreach (var f in _fournisseursAffiches)
                                    {
                                        <tr class="data-row @(f.Expanded ? "row-active" : "")"
                                            @onclick="() => ToggleDetail(f.Id)">

                                            <td>
                                                <div class="supplier-cell">
                                                    <div class="avatar @(f.Expanded ? "avatar-lit" : "")">
                                                        @f.Nom[0].ToString().ToUpper()
                                                    </div>
                                                    <div class="supplier-info">
                                                        <span class="supplier-name">@f.Nom</span>
                                                        <span class="supplier-loc">
                                                            <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                                            @(string.IsNullOrEmpty(f.Adresse) ? "Adresse non renseignée" : f.Adresse)
                                                        </span>
                                                    </div>
                                                </div>
                                            </td>

                                            <td>
                                                <div class="cmd-badge">
                                                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                                                    @f.CommandesTotales
                                                </div>
                                            </td>

                                            <td class="td-date">
                                                @if (f.DerniereCommande.HasValue)
                                                {
                                                    <div class="date-wrap">
                                                        <span class="date-main">@f.DerniereCommande.Value.ToString("dd MMM")</span>
                                                        <span class="date-year">@f.DerniereCommande.Value.Year</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="td-nil">—</span>
                                                }
                                            </td>

                                            <td>
                                                @if (!string.IsNullOrEmpty(f.Mail))
                                                {
                                                    <div class="contact-chip">
                                                        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                                        @f.Mail
                                                    </div>
                                                }
                                                else if (!string.IsNullOrEmpty(f.Telephone))
                                                {
                                                    <div class="contact-chip">
                                                        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.13 6.13l.87-.87a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                                        @f.Telephone
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="td-nil">—</span>
                                                }
                                            </td>

                                            <td @onclick:stopPropagation="true">
                                                <div class="actions-cell">
                                                    <button class="act-btn act-edit" title="Modifier"
                                                            @onclick="() => OuvrirFormulaire(f)"
                                                            @onclick:stopPropagation="true">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                                        </svg>
                                                    </button>
                                                    <button class="act-btn act-del" title="Supprimer"
                                                            @onclick="() => DemanderSuppression(f)"
                                                            @onclick:stopPropagation="true">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                                            <polyline points="3 6 5 6 21 6"/>
                                                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                                                            <path d="M10 11v6M14 11v6"/>
                                                            <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                                                        </svg>
                                                    </button>
                                                    <button class="act-btn @(f.Expanded ? "act-chevron-up" : "act-more")" title="@(f.Expanded ? "Réduire" : "Détails")"
                                                            @onclick="() => ToggleDetail(f.Id)"
                                                            @onclick:stopPropagation="true">
                                                        @if (f.Expanded)
                                                        {
                                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="18 15 12 9 6 15"/></svg>
                                                        }
                                                        else
                                                        {
                                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                                                <circle cx="12" cy="12" r="1"/>
                                                                <circle cx="19" cy="12" r="1"/>
                                                                <circle cx="5"  cy="12" r="1"/>
                                                            </svg>
                                                        }
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>

                                        @if (f.Expanded)
                                        {
                                            <tr class="detail-row">
                                                <td colspan="5">
                                                    <div class="detail-panel">
                                                        <div class="detail-grid">
                                                            <div class="detail-field">
                                                                <span class="df-label">Téléphone</span>
                                                                <span class="df-value">@(f.Telephone ?? "—")</span>
                                                            </div>
                                                            <div class="detail-field">
                                                                <span class="df-label">Email</span>
                                                                <span class="df-value">@(f.Mail ?? "—")</span>
                                                            </div>
                                                            <div class="detail-field">
                                                                <span class="df-label">Adresse</span>
                                                                <span class="df-value">@(f.Adresse ?? "—")</span>
                                                            </div>
                                                            <div class="detail-field">
                                                                <span class="df-label">Commandes totales</span>
                                                                <span class="df-value df-accent">@f.CommandesTotales cmd.</span>
                                                            </div>
                                                            <div class="detail-field">
                                                                <span class="df-label">Dernière commande</span>
                                                                <span class="df-value">
                                                                    @(f.DerniereCommande.HasValue
                                                                        ? f.DerniereCommande.Value.ToString("dd MMMM yyyy")
                                                                        : "Aucune commande")
                                                                </span>
                                                            </div>
                                                        </div>
                                                        <div class="detail-cta">
                                                            <button class="btn-detail-modify"
                                                                    @onclick="() => OuvrirFormulaire(f)"
                                                                    @onclick:stopPropagation="true">
                                                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                                                </svg>
                                                                Modifier
                                                            </button>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="table-footer">
                        <span>@_fournisseursAffiches.Count sur @_tousLesFournisseurs.Count fournisseur(s)</span>
                    </div>
                </div>

            </div>
        </main>

        
        @if (_fournisseurASupprimer != null)
        {
            <div class="modal-overlay" @onclick="AnnulerSuppression">
                <div class="modal-box" @onclick:stopPropagation="true">
                    <div class="modal-danger-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                            <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
                            <line x1="12" y1="9" x2="12" y2="13"/>
                            <line x1="12" y1="17" x2="12.01" y2="17"/>
                        </svg>
                    </div>
                    <h3 class="modal-title">Supprimer ce fournisseur ?</h3>
                    <p class="modal-body">
                        Vous êtes sur le point de supprimer <strong>@_fournisseurASupprimer.Nom</strong>. Cette action est <em>irréversible</em>.
                    </p>
                    <div class="modal-actions">
                        <button class="btn-cancel" @onclick="AnnulerSuppression">Annuler</button>
                        <button class="btn-danger" @onclick="ConfirmerSuppression">Supprimer définitivement</button>
                    </div>
                </div>
            </div>
        }

        
        @if (_panneauOuvert)
        {
            <div class="form-overlay" @onclick="FermerFormulaire"></div>
            <div class="form-panel">

                <div class="form-panel-head">
                    <div class="form-panel-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                    </div>
                    <h3>@(_modeModif ? "Modifier le fournisseur" : "Nouveau fournisseur")</h3>
                    <button class="form-close" @onclick="FermerFormulaire">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <line x1="18" y1="6"  x2="6"  y2="18"/>
                            <line x1="6"  y1="6"  x2="18" y2="18"/>
                        </svg>
                    </button>
                </div>

                <div class="form-body">
                    <p class="form-section-lbl">Identité</p>

                    <div class="form-group">
                        <label class="form-lbl">Nom du fournisseur <span class="req">*</span></label>
                        <input class="form-inp @(_erreurs.ContainsKey("Nom") ? "inp-error" : "")"
                               type="text" placeholder="ex : Global Tech Solutions"
                               @bind="_form.Nom" @bind:event="oninput" />
                        @if (_erreurs.ContainsKey("Nom"))
                        { <span class="err-msg">@_erreurs["Nom"]</span> }
                    </div>

                    <div class="form-row-2">
                        <div class="form-group">
                            <label class="form-lbl">Téléphone</label>
                            <input class="form-inp" type="tel" placeholder="+216 20 000 000"
                                   @bind="_form.Telephone" @bind:event="oninput" />
                        </div>
                        <div class="form-group">
                            <label class="form-lbl">Email</label>
                            <input class="form-inp @(_erreurs.ContainsKey("Mail") ? "inp-error" : "")"
                                   type="email" placeholder="contact@exemple.com"
                                   @bind="_form.Mail" @bind:event="oninput" />
                            @if (_erreurs.ContainsKey("Mail"))
                            { <span class="err-msg">@_erreurs["Mail"]</span> }
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-lbl">Adresse physique</label>
                        <textarea class="form-inp form-textarea" rows="2"
                                  placeholder="12 Rue de la Paix, Tunis"
                                  @bind="_form.Adresse" @bind:event="oninput"></textarea>
                    </div>

                    <p class="form-section-lbl" style="margin-top:8px">Commande</p>

                    <div class="form-group">
                        <label class="form-lbl">Date de la dernière commande</label>
                        <input class="form-inp" type="date" @bind="_form.DerniereCommande" />
                    </div>
                </div>

                <div class="form-footer">
                    <button class="btn-cancel" @onclick="FermerFormulaire">Annuler</button>
                    <button class="btn-save" @onclick="SauvegarderFournisseur" disabled="@_sauvegarde">
                        @if (_sauvegarde)
                        {
                            <span class="spinner spinner-sm"></span>
                            <span>Enregistrement…</span>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                @if (_modeModif)
                                { <polyline points="20 6 9 17 4 12"/> }
                                else
                                { <line x1="12" y1="5" x2="12" y2="19"/>
                                  <line x1="5" y1="12" x2="19" y2="12"/> }
                            </svg>
                            <span>@(_modeModif ? "Mettre à jour" : "Enregistrer")</span>
                        }
                    </button>
                </div>
            </div>
        }

        
        @if (!string.IsNullOrEmpty(_toastMsg))
        {
            <div class="toast @_toastType">
                @if (_toastType == "toast-success")
                {
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                }
                @_toastMsg
            </div>
        }

    </div>
    <ScrapingToastGlobal />
</RoleAuthGuard>
