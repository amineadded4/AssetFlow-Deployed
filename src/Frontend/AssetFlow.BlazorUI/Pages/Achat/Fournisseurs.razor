@* ============================================================
   FICHIER : Pages/Achat/Fournisseurs.razor
   v4 : Sidebar style Employé + nom utilisateur dynamique
        + headers tableau plus larges
   ============================================================ *@

@page "/achat/fournisseurs"
@using AssetFlow.BlazorUI.Pages.Achat

<div class="layout-shell">

    @if (_sidebarOpen)
    {
        <div class="sidebar-overlay" @onclick="ToggleSidebar"></div>
    }

    @* ══════════════════════════════════════════════════
       SIDEBAR — Design identique au sidebar Employé
    ══════════════════════════════════════════════════ *@
    <aside class="sidebar @(_sidebarOpen ? "open" : "")">

        <div class="sidebar-header">
            <img src="images/logo.png" alt="AssetFlow" class="sidebar-logo-img" />
        </div>

        <nav class="sidebar-nav">

            <a href="/statistiques" class="nav-link">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24">
                        <line x1="18" y1="20" x2="18" y2="10"/>
                        <line x1="12" y1="20" x2="12" y2="4"/>
                        <line x1="6"  y1="20" x2="6"  y2="14"/>
                        <line x1="2"  y1="20" x2="22" y2="20"/>
                    </svg>
                </span>
                <span class="nav-text">Statistiques</span>
            </a>

            <a href="/achat/materiel" class="nav-link">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24">
                        <rect x="2" y="3" width="20" height="14" rx="2"/>
                        <path d="M8 21h8M12 17v4"/>
                    </svg>
                </span>
                <span class="nav-text">Matériel</span>
            </a>

            <a href="/fournisseurs" class="nav-link active">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </span>
                <span class="nav-text">Fournisseurs</span>
            </a>

            <a href="/demandes-achat" class="nav-link">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24">
                        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 0 1-8 0"/>
                    </svg>
                </span>
                <span class="nav-text">Demande d'achat</span>
            </a>

        </nav>

        @* ── Profil utilisateur courant (comme sidebar Employé) ── *@
        <div class="sidebar-profile">
            <div class="profile-avatar">@CurrentUserInitials</div>
            <div class="profile-info">
                <p class="profile-name">@_currentUserName</p>
                <p class="profile-role">@_currentUserRole</p>
            </div>
        </div>

        <div class="sidebar-support">
            <p class="support-label">SUPPORT IT</p>
            <p class="support-text">Besoin d'aide ?</p>
            <button class="support-btn">Contact</button>
        </div>

    </aside>

    @* ══════════════════════════════════════════════════
       ZONE PRINCIPALE
    ══════════════════════════════════════════════════ *@
    <main class="main-zone">

        <header class="topbar">
            <button class="topbar-menu-btn" @onclick="ToggleSidebar" aria-label="Menu">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <line x1="3" y1="6"  x2="21" y2="6"/>
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>

            <div class="search-wrap">
                <span class="search-icon">
                    <svg viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                </span>
                <input class="search-input" type="text"
                       placeholder="Rechercher un fournisseur…"
                       @oninput="OnRecherche" />
            </div>
            <div class="topbar-actions">
                <button class="btn-add" @onclick="() => OuvrirFormulaire(null)">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="3" stroke-linecap="round">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5"  y1="12" x2="19" y2="12"/>
                    </svg>
                    <span>Nouveau Fournisseur</span>
                </button>
            </div>
        </header>

        <div class="page-content">

            <div class="page-title-row">
                <div class="page-title">
                    <h2>Performance des Fournisseurs</h2>
                    <p>Analyse temps réel de la fiabilité logistique et opérationnelle.</p>
                </div>
                <div class="page-title-actions">
                    <button class="btn-export">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </svg>
                        Excel
                    </button>
                    <button class="btn-export">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </svg>
                        PDF
                    </button>
                </div>
            </div>

            @* ── STATS ── *@
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-top">
                        <div class="stat-icon blue">
                            <svg viewBox="0 0 24 24">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                        <span class="badge badge-up">@_totalFournisseurs total</span>
                    </div>
                    <p class="stat-label">Total Fournisseurs</p>
                    <p class="stat-value">@_totalFournisseurs</p>
                </div>

                <div class="stat-card">
                    <div class="stat-top">
                        <div class="stat-icon green">
                            <svg viewBox="0 0 24 24">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                        </div>
                        <span class="badge badge-info">Top tier</span>
                    </div>
                    <p class="stat-label">Meilleur Score</p>
                    <p class="stat-value">@(_meilleurScore.ToString("0.0"))%</p>
                </div>

                <div class="stat-card">
                    <div class="stat-top">
                        <div class="stat-icon amber">
                            <svg viewBox="0 0 24 24">
                                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                            </svg>
                        </div>
                        <span class="badge badge-neutral">Moyenne</span>
                    </div>
                    <p class="stat-label">Score Moyen</p>
                    <p class="stat-value">@(_scoreMoyen.ToString("0.0"))%</p>
                </div>
            </div>

            @* ── TOOLBAR ── *@
            <div class="table-toolbar">
                <div class="table-toolbar-left">
                    <h4>Liste des Fournisseurs</h4>
                    <span class="tag-count">@_fournisseursAffiches.Count résultat(s)</span>
                </div>

                <div class="filter-pills">
                    <span class="filter-pills-label">Score :</span>
                    <button class="pill @(_filtreScore == "all"       ? "pill-active" : "")"
                            @onclick='() => AppliquerFiltreScore("all")'>Tous</button>
                    <button class="pill @(_filtreScore == "excellent" ? "pill-active" : "")"
                            @onclick='() => AppliquerFiltreScore("excellent")'>
                        <span class="pdot pdot-green"></span>&gt;&nbsp;80%
                    </button>
                    <button class="pill @(_filtreScore == "moyen"     ? "pill-active" : "")"
                            @onclick='() => AppliquerFiltreScore("moyen")'>
                        <span class="pdot pdot-amber"></span>50–80%
                    </button>
                    <button class="pill @(_filtreScore == "critique"  ? "pill-active" : "")"
                            @onclick='() => AppliquerFiltreScore("critique")'>
                        <span class="pdot pdot-rose"></span>&lt;&nbsp;50%
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_erreurGlobale))
            {
                <div class="alert-error">@_erreurGlobale</div>
            }

            @* ── TABLEAU ── *@
            <div class="table-container">
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr>
                                <th>Fournisseur</th>
                                <th>Commandes</th>
                                <th>Taux livraison</th>
                                <th>Score fiabilité</th>
                                <th>Dernière commande</th>
                                <th>Contact</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_chargement)
                            {
                                <tr><td colspan="7" class="td-center">Chargement…</td></tr>
                            }
                            else if (!_fournisseursAffiches.Any())
                            {
                                <tr>
                                    <td colspan="7" class="td-empty">
                                        <svg viewBox="0 0 24 24">
                                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                            <circle cx="9" cy="7" r="4"/>
                                        </svg>
                                        Aucun fournisseur trouvé.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var f in _fournisseursAffiches)
                                {
                                    <tr class="@(f.Expanded ? "row-expanded" : "")"
                                        @onclick="() => ToggleDetail(f.Id)">

                                        <td>
                                            <div class="supplier-cell">
                                                <div class="supplier-avatar @(f.Expanded ? "avatar-active" : "")">
                                                    @f.Nom[0].ToString().ToUpper()
                                                </div>
                                                <div>
                                                    <p class="supplier-name">@f.Nom</p>
                                                    <p class="supplier-sub">
                                                        @(string.IsNullOrEmpty(f.Adresse) ? "Adresse non renseignée" : f.Adresse)
                                                    </p>
                                                </div>
                                            </div>
                                        </td>

                                        <td class="td-num">@f.CommandesTotales</td>

                                        <td>
                                            <span class="rate-badge rate-@RateClass(f.TauxLivraisonATemps)">
                                                @f.TauxLivraisonATemps.ToString("0.0")%
                                            </span>
                                        </td>

                                        <td>
                                            <div class="score-cell">
                                                <div class="score-bar">
                                                    <div class="score-fill fill-@ScoreFillClass(f.ScoreFiabilite)"
                                                         style="width:@(Math.Min(f.ScoreFiabilite,100))%">
                                                    </div>
                                                </div>
                                                <span class="score-num score-@ScoreTextClass(f.ScoreFiabilite)">
                                                    @f.ScoreFiabilite.ToString("0.0")
                                                </span>
                                            </div>
                                        </td>

                                        <td class="td-muted td-date">
                                            @(f.DerniereCommande.HasValue
                                                ? f.DerniereCommande.Value.ToString("dd MMM yyyy")
                                                : "—")
                                        </td>

                                        <td class="td-muted">
                                            @if (!string.IsNullOrEmpty(f.Mail))
                                            { <span>@f.Mail</span> }
                                            else if (!string.IsNullOrEmpty(f.Telephone))
                                            { <span>@f.Telephone</span> }
                                            else { <span>—</span> }
                                        </td>

                                        <td @onclick:stopPropagation="true">
                                            <div class="row-actions">
                                                <button class="act-btn act-edit" title="Modifier"
                                                        @onclick="() => OuvrirFormulaire(f)"
                                                        @onclick:stopPropagation="true">
                                                    <svg viewBox="0 0 24 24">
                                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                                    </svg>
                                                </button>
                                                <button class="act-btn act-del" title="Supprimer"
                                                        @onclick="() => DemanderSuppression(f)"
                                                        @onclick:stopPropagation="true">
                                                    <svg viewBox="0 0 24 24">
                                                        <polyline points="3 6 5 6 21 6"/>
                                                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                                                        <path d="M10 11v6M14 11v6"/>
                                                        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                                                    </svg>
                                                </button>
                                                <button class="act-btn @(f.Expanded ? "act-up" : "")" title="Détails"
                                                        @onclick="() => ToggleDetail(f.Id)"
                                                        @onclick:stopPropagation="true">
                                                    @if (f.Expanded)
                                                    {
                                                        <svg viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"/></svg>
                                                    }
                                                    else
                                                    {
                                                        <svg viewBox="0 0 24 24">
                                                            <circle cx="12" cy="12" r="1"/>
                                                            <circle cx="19" cy="12" r="1"/>
                                                            <circle cx="5"  cy="12" r="1"/>
                                                        </svg>
                                                    }
                                                </button>
                                            </div>
                                        </td>
                                    </tr>

                                    @if (f.Expanded)
                                    {
                                        <tr class="detail-row">
                                            <td colspan="7">
                                                <div class="detail-inner">
                                                    <div class="detail-info-section">
                                                        <p class="detail-section-label">INFORMATIONS COMPLÈTES</p>
                                                        <div class="detail-info-grid">
                                                            <div class="detail-info-item">
                                                                <span class="d-lbl">Téléphone</span>
                                                                <span class="d-val">@(f.Telephone ?? "—")</span>
                                                            </div>
                                                            <div class="detail-info-item">
                                                                <span class="d-lbl">Email</span>
                                                                <span class="d-val">@(f.Mail ?? "—")</span>
                                                            </div>
                                                            <div class="detail-info-item">
                                                                <span class="d-lbl">Adresse</span>
                                                                <span class="d-val">@(f.Adresse ?? "—")</span>
                                                            </div>
                                                            <div class="detail-info-item">
                                                                <span class="d-lbl">Commandes totales</span>
                                                                <span class="d-val">@f.CommandesTotales</span>
                                                            </div>
                                                            <div class="detail-info-item">
                                                                <span class="d-lbl">Taux livraison</span>
                                                                <span class="d-val rate-@RateClass(f.TauxLivraisonATemps)">
                                                                    @f.TauxLivraisonATemps.ToString("0.0")%
                                                                </span>
                                                            </div>
                                                            <div class="detail-info-item">
                                                                <span class="d-lbl">Dernière commande</span>
                                                                <span class="d-val">
                                                                    @(f.DerniereCommande.HasValue
                                                                        ? f.DerniereCommande.Value.ToString("dd MMMM yyyy")
                                                                        : "Aucune")
                                                                </span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="detail-side">
                                                        <div class="detail-metric">
                                                            <p class="dm-label">Score fiabilité</p>
                                                            <p class="dm-value score-@ScoreTextClass(f.ScoreFiabilite)">
                                                                @f.ScoreFiabilite.ToString("0.0")<span class="dm-unit">/100</span>
                                                            </p>
                                                        </div>
                                                        <div class="detail-metric">
                                                            <p class="dm-label">Taux livraison</p>
                                                            <p class="dm-value rate-@RateClass(f.TauxLivraisonATemps)">
                                                                @f.TauxLivraisonATemps.ToString("0.0")<span class="dm-unit">%</span>
                                                            </p>
                                                        </div>
                                                        <button class="btn-detail-edit"
                                                                @onclick="() => OuvrirFormulaire(f)"
                                                                @onclick:stopPropagation="true">
                                                            Modifier ce fournisseur
                                                        </button>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="table-footer">
                    <span>@_fournisseursAffiches.Count sur @_tousLesFournisseurs.Count fournisseur(s)</span>
                </div>
            </div>

        </div>
    </main>

    @* ══════════ MODALE SUPPRESSION ══════════ *@
    @if (_fournisseurASupprimer != null)
    {
        <div class="modal-overlay" @onclick="AnnulerSuppression">
            <div class="modal-box" @onclick:stopPropagation="true">
                <div class="modal-icon-wrap">
                    <svg viewBox="0 0 24 24">
                        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
                        <line x1="12" y1="9"  x2="12" y2="13"/>
                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                </div>
                <h3 class="modal-title">Supprimer ce fournisseur ?</h3>
                <p class="modal-text">
                    Vous êtes sur le point de supprimer
                    <strong>@_fournisseurASupprimer.Nom</strong>.
                    Cette action est <em>irréversible</em>.
                </p>
                <div class="modal-actions">
                    <button class="btn-modal-cancel" @onclick="AnnulerSuppression">Annuler</button>
                    <button class="btn-modal-danger" @onclick="ConfirmerSuppression">
                        Supprimer définitivement
                    </button>
                </div>
            </div>
        </div>
    }

    @* ══════════ FORMULAIRE SLIDE-IN ══════════ *@
    @if (_panneauOuvert)
    {
        <div class="form-overlay" @onclick="FermerFormulaire"></div>
        <div class="form-panel">

            <div class="form-panel-header">
                <div class="form-panel-icon">
                    <svg viewBox="0 0 24 24">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
                <h3>@(_modeModif ? "Modifier le fournisseur" : "Nouveau fournisseur")</h3>
                <button class="form-close-btn" @onclick="FermerFormulaire">
                    <svg viewBox="0 0 24 24">
                        <line x1="18" y1="6"  x2="6"  y2="18"/>
                        <line x1="6"  y1="6"  x2="18" y2="18"/>
                    </svg>
                </button>
            </div>

            <div class="form-body">

                <p class="form-section-label">Identité</p>

                <div class="form-group">
                    <label class="form-lbl">Nom du fournisseur <span class="req">*</span></label>
                    <input class="form-inp @(_erreurs.ContainsKey("Nom") ? "inp-invalid" : "")"
                           type="text" placeholder="ex : Global Tech Solutions"
                           @bind="_form.Nom" @bind:event="oninput" />
                    @if (_erreurs.ContainsKey("Nom"))
                    { <span class="inp-error">@_erreurs["Nom"]</span> }
                </div>

                <div class="form-group">
                    <label class="form-lbl">Téléphone</label>
                    <input class="form-inp" type="tel" placeholder="ex : +216 20 000 000"
                           @bind="_form.Telephone" @bind:event="oninput" />
                </div>

                <div class="form-group">
                    <label class="form-lbl">Adresse e-mail</label>
                    <input class="form-inp @(_erreurs.ContainsKey("Mail") ? "inp-invalid" : "")"
                           type="email" placeholder="ex : contact@fournisseur.com"
                           @bind="_form.Mail" @bind:event="oninput" />
                    @if (_erreurs.ContainsKey("Mail"))
                    { <span class="inp-error">@_erreurs["Mail"]</span> }
                </div>

                <div class="form-group">
                    <label class="form-lbl">Adresse physique</label>
                    <textarea class="form-inp form-textarea" rows="2"
                              placeholder="ex : 12 Rue de la Paix, Tunis"
                              @bind="_form.Adresse" @bind:event="oninput"></textarea>
                </div>

                <p class="form-section-label" style="margin-top:8px">Performance</p>

                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-lbl">Commandes totales</label>
                        <input class="form-inp" type="number" min="0" placeholder="0"
                               @bind="_form.CommandesTotales" @bind:event="oninput" />
                    </div>
                    <div class="form-group">
                        <label class="form-lbl">Score fiabilité (0–100) <span class="req">*</span></label>
                        <input class="form-inp @(_erreurs.ContainsKey("Score") ? "inp-invalid" : "")"
                               type="number" min="0" max="100" step="0.1" placeholder="ex : 85.5"
                               @bind="_form.ScoreFiabilite" @bind:event="oninput" />
                        @if (_erreurs.ContainsKey("Score"))
                        { <span class="inp-error">@_erreurs["Score"]</span> }
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-lbl">Taux livraison à temps (%) <span class="req">*</span></label>
                    <input class="form-inp @(_erreurs.ContainsKey("Taux") ? "inp-invalid" : "")"
                           type="number" min="0" max="100" step="0.1" placeholder="ex : 92.5"
                           @bind="_form.TauxLivraisonATemps" @bind:event="oninput" />
                    @if (_erreurs.ContainsKey("Taux"))
                    { <span class="inp-error">@_erreurs["Taux"]</span> }
                </div>

                <div class="form-group">
                    <label class="form-lbl">Date de la dernière commande</label>
                    <input class="form-inp" type="date" @bind="_form.DerniereCommande" />
                </div>

            </div>

            <div class="form-footer">
                <button class="btn-form-cancel" @onclick="FermerFormulaire">Annuler</button>
                <button class="btn-form-save" @onclick="SauvegarderFournisseur"
                        disabled="@_sauvegarde">
                    @if (_sauvegarde)
                    { <span>Enregistrement…</span> }
                    else
                    {
                        <svg viewBox="0 0 24 24">
                            @if (_modeModif)
                            { <polyline points="20 6 9 17 4 12"/> }
                            else
                            { <line x1="12" y1="5" x2="12" y2="19"/>
                              <line x1="5" y1="12" x2="19" y2="12"/> }
                        </svg>
                        <span>@(_modeModif ? "Mettre à jour" : "Enregistrer")</span>
                    }
                </button>
            </div>

        </div>
    }

    @* Toast *@
    @if (!string.IsNullOrEmpty(_toastMsg))
    {
        <div class="toast @_toastType">@_toastMsg</div>
    }

</div>
