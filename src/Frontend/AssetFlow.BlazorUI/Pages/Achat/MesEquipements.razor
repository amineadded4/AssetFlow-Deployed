@* ============================================================
   AssetFlow.BlazorUI / Pages / Employe / MesEquipements.razor
   MISE À JOUR : Grille groupée par matériel + modal articles
   ============================================================ *@

@page "/achat/equipements"
@using AssetFlow.BlazorUI.Services
@using AssetFlow.BlazorUI.Components

    <div class="employe-layout">

        @* === SIDEBAR === *@
        <aside class="employe-sidebar">
            <div class="sidebar-header">
                <img src="images/logo.png" alt="AssetFlow" class="sidebar-logo" />
            </div>

            <nav class="sidebar-nav">
                <a href="/statistiques" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24">
                        <line x1="18" y1="20" x2="18" y2="10"/>
                        <line x1="12" y1="20" x2="12" y2="4"/>
                        <line x1="6"  y1="20" x2="6"  y2="14"/>
                        <line x1="2"  y1="20" x2="22" y2="20"/>
                    </svg>
                    <span class="nav-text">Statistiques</span>
                </a>
                <a href="/achat/equipements" class="nav-link active">
                    <svg class="nav-icon" viewBox="0 0 24 24">
                        <rect x="2" y="3" width="20" height="14" rx="2" />
                        <path d="M8 21h8M12 17v4" />
                    </svg>
                    <span class="nav-text">Mes Équipements</span>
                </a>
                <a href="/achat/materiel" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24">
                        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 0 1-8 0"/>
                    </svg>
                    <span class="nav-text">Matériel</span>
                </a>
                <a href="/achat/fournisseurs" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    <span class="nav-text">Fournisseurs</span>
                </a>
                <a href="/demandes-achat" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24">
                        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 0 1-8 0"/>
                    </svg>
                    <span class="nav-text">Demande d'achat</span>
                </a>
                <a href="/achat/web-scraping" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        <line x1="11" y1="8"  x2="11"    y2="14"/>
                        <line x1="8"  y1="11" x2="14"    y2="11"/>
                    </svg>
                    <span class="nav-text">Scraping Marché</span>
                </a>
            </nav>

            <div class="sidebar-profile">
                <div class="profile-avatar">@GetInitials()</div>
                <div class="profile-info">
                    <p class="profile-name">@UserName</p>
                    <p class="profile-role">@UserRole</p>
                </div>
            </div>

            <LogoutButton />
        </aside>

        @* === MAIN CONTENT === *@
        <main class="employe-main">

            <header class="employe-header">
                <div class="header-title-group">
                    <h1 class="header-title">Mes Équipements</h1>
                    <span class="header-badge">@MaterielsGroupesFiltres.Count</span>
                </div>
                <div class="header-search">
                    <svg class="search-icon" viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8" />
                        <path d="m21 21-4.3-4.3" />
                    </svg>
                    <input type="text"
                        class="search-input"
                        placeholder="Rechercher un équipement..."
                        value="@SearchQuery"
                        @oninput="OnSearchInput" />
                </div>
            </header>

            <div class="employe-content">
                @if (IsLoading)
                {
                    <div class="loading-state">
                        <div class="spinner"></div>
                        <p>Chargement de vos équipements...</p>
                    </div>
                }
                else if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="error-state">
                        <svg class="error-icon" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" />
                            <path d="m15 9-6 6M9 9l6 6" />
                        </svg>
                        <p>@ErrorMessage</p>
                    </div>
                }
                else if (MaterielsGroupesFiltres.Count == 0 && !string.IsNullOrEmpty(SearchQuery))
                {
                    <div class="empty-state">
                        <svg class="empty-icon" viewBox="0 0 24 24">
                            <circle cx="11" cy="11" r="8" />
                            <path d="m21 21-4.3-4.3" />
                        </svg>
                        <p>Aucun équipement trouvé pour "@SearchQuery"</p>
                    </div>
                }
                else if (MaterielsGroupesFiltres.Count == 0)
                {
                    <div class="empty-state">
                        <svg class="empty-icon" viewBox="0 0 24 24">
                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                        </svg>
                        <p>Aucun équipement affecté pour le moment.</p>
                    </div>
                }
                else
                {
                    <div class="equipements-grid">
                        @foreach (var materiel in MaterielsGroupesFiltres.Where(m => m.NombreArticles > 0))
                        {
                            <div class="equipment-card @(materiel.StatutDominant == "Endommage" ? "card-damaged" : "")">

                                @* ── Image ── *@
                                <div class="card-image">
                                    @if (!string.IsNullOrEmpty(materiel.ImageUrl))
                                    {
                                        <img src="@materiel.ImageUrl" alt="@materiel.Designation" />
                                    }
                                    else
                                    {
                                        <div class="image-placeholder">
                                            <svg viewBox="0 0 24 24">
                                                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                                            </svg>
                                        </div>
                                    }
                                    @* Badge nombre d'articles *@
                                    <div class="articles-count-badge">
                                        <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM16 3H8"/></svg>
                                        @materiel.NombreArticles article@(materiel.NombreArticles > 1 ? "s" : "")
                                    </div>
                                </div>

                                @* ── Contenu ── *@
                                <div class="card-content">
                                    <div class="card-header">
                                        <h3 class="card-title">@materiel.Designation</h3>
                                        @* <span class="status-badge" style="--badge-color: @materiel.StatutBadgeColor;">
                                            <span class="badge-dot"></span>
                                            @GetStatutLabel(materiel.StatutDominant)
                                        </span> *@
                                    </div>

                                    <p class="card-reference">@materiel.Reference</p>
                                    <p class="card-categorie">@materiel.Categorie</p>

                                    <div class="card-date">
                                        <svg class="date-icon" viewBox="0 0 24 24">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                            <path d="M16 2v4M8 2v4M3 10h18" />
                                        </svg>
                                        Assigné le @materiel.DerniereAffectation.ToString("dd/MM/yyyy")
                                    </div>

                                    @* ── Bouton articles (nouveau) ── *@
                                    <button class="card-btn-articles" @onclick="() => OuvrirModal(materiel)">
                                        <svg viewBox="0 0 24 24">
                                            <path d="M9 11l3 3L22 4" />
                                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                                        </svg>
                                        Voir les @materiel.NombreArticles article@(materiel.NombreArticles > 1 ? "s" : "")
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

        </main>

    </div>

    @* ═══════════════════════════════════════════════════════
    MODAL ARTICLES
    ═══════════════════════════════════════════════════════ *@
    @if (ModalOuvert && MaterielSelectionne != null)
    {
        <div class="modal-backdrop" @onclick="FermerModal">
            <div class="modal-container" @onclick:stopPropagation="true">

                @* Header modal *@
                <div class="modal-header">
                    <div class="modal-header-left">
                        <div class="modal-icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z" />
                                <path d="M16 3H8" />
                            </svg>
                        </div>
                        <div>
                            <h2 class="modal-title">@MaterielSelectionne.Designation</h2>
                            <p class="modal-subtitle">
                                @MaterielSelectionne.NombreArticles article@(MaterielSelectionne.NombreArticles > 1 ? "s" : "") affecté@(MaterielSelectionne.NombreArticles > 1 ? "s" : "") · @MaterielSelectionne.Categorie
                            </p>
                        </div>
                    </div>
                    <button class="modal-close" @onclick="FermerModal">
                        <svg viewBox="0 0 24 24">
                            <path d="M18 6L6 18M6 6l12 12" />
                        </svg>
                    </button>
                </div>

                @* Recherche dans le modal *@
                <div class="modal-search">
                    <svg viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8" />
                        <path d="m21 21-4.3-4.3" />
                    </svg>
                    <input type="text"
                        placeholder="Rechercher par numéro de série..."
                        value="@ModalSearchQuery"
                        @oninput="OnModalSearchInput" />
                </div>

                @* Liste des articles *@
                <div class="modal-body">
                    @{
                        var articlesFiltres = string.IsNullOrWhiteSpace(ModalSearchQuery)
                            ? MaterielSelectionne.Articles
                            : MaterielSelectionne.Articles
                                .Where(a => a.NumeroSerie.Contains(ModalSearchQuery, StringComparison.OrdinalIgnoreCase)
                                        || (a.Observations ?? "").Contains(ModalSearchQuery, StringComparison.OrdinalIgnoreCase))
                                .ToList();
                    }

                    @if (!articlesFiltres.Any())
                    {
                        <div class="modal-empty">
                            <svg viewBox="0 0 24 24">
                                <circle cx="11" cy="11" r="8" />
                                <path d="m21 21-4.3-4.3" />
                            </svg>
                            <p>Aucun article trouvé.</p>
                        </div>
                    }
                    else
                    {
                        @* Header colonnes *@
                        <div class="articles-table-header">
                            <span>N° Série / Identifiant</span>
                            <span>Statut</span>
                            <span>Date affectation</span>
                            <span></span>
                        </div>

                        <div class="articles-list">
                            @foreach (var article in articlesFiltres)
                            {
                                <div class="article-row" @onclick="() => NaviguerVersDetail(article.AffectationId,article.ArticleId)">
                                    @* Icône + numéro de série *@
                                    <div class="article-serie">
                                        <div class="article-icon">
                                            <svg viewBox="0 0 24 24">
                                                <rect x="2" y="3" width="20" height="14" rx="2" />
                                                <path d="M8 21h8M12 17v4" />
                                            </svg>
                                        </div>
                                        <div>
                                            <p class="serie-number">@article.NumeroSerie</p>
                                            @if (!string.IsNullOrEmpty(article.Observations))
                                            {
                                                <p class="serie-obs">@article.Observations</p>
                                            }
                                        </div>
                                    </div>

                                    @* Badge statut *@
                                    <div class="article-statut">
                                        @* Badge état dans le modal *@
                                        <span class="statut-pill-sm" style="--pill-color: @article.StatutBadgeColor;">
                                            <span class="pill-dot"></span>
                                            @article.EtatArticle  @* ← était StatutAffectation *@
                                        </span>
                                    </div>

                                    @* Date *@
                                    <div class="article-date">
                                        @article.DateAffectation.ToString("dd MMM yyyy")
                                    </div>

                                    @* Bouton voir détail *@
                                    <div class="article-action">
                                        <button class="btn-voir-detail" @onclick:stopPropagation="true"
                                                @onclick="() => NaviguerVersDetail(article.AffectationId,article.ArticleId)">
                                            Voir détail
                                            <svg viewBox="0 0 24 24">
                                                <path d="M5 12h14M12 5l7 7-7 7" />
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                @* Footer modal *@
                <div class="modal-footer">
                    <span class="modal-footer-info">
                        @articlesFiltres.Count() article@(articlesFiltres.Count() > 1 ? "s" : "") affiché@(articlesFiltres.Count() > 1 ? "s" : "")
                    </span>
                    <button class="modal-btn-fermer" @onclick="FermerModal">Fermer</button>
                </div>

            </div>
        </div>
    }
