@* ============================================================
   FICHIER  : Pages/Statistiques.razor — v3
   FIX      : .chart-body a une hauteur CSS fixe (px) définie
              dans le .razor.css. ApexCharts lit offsetHeight.
   ============================================================ *@

@page "/statistiques"
@using AssetFlow.BlazorUI.Components
@using Microsoft.JSInterop

<RoleAuthGuard AllowedRoles="@(new[]{"EquipeAchat","Admin"})">
<div class="layout-shell" data-theme="@_theme">

    @if (_sidebarOpen)
    { <div class="sidebar-overlay" @onclick="ToggleSidebar"></div> }

    @if (_estAdmin)
        {
            <AdminSidebar ForceOpen="_sidebarOpen" />
        }
        else
        {
            <AchatSidebar ActivePage="statistiques" ForceOpen="_sidebarOpen" />
        }

    @* ══════ ZONE PRINCIPALE ══════ *@
    <main class="main-zone">

        <header class="topbar">
            <button class="topbar-menu-btn" @onclick="ToggleSidebar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <line x1="3" y1="6"  x2="21" y2="6"/>
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>
            <div class="topbar-brand">
                <h1>Tableau de bord</h1>
                <span class="topbar-role-badge">Statistiques</span>
            </div>
        </header>

        <div class="dashboard-scroll">

            @if (_chargement)
            {
                <div class="loading-overlay">
                    <div class="loading-spinner"></div>
                    <span>Chargement des données…</span>
                </div>
            }
            else if (_stats == null)
            {
                <div class="error-state">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <p>Impossible de charger les statistiques.</p>
                    <button class="btn-retry" @onclick="ChargerDonnees">Réessayer</button>
                </div>
            }
            else
            {
                @* ── KPI ── *@
                <div class="kpi-row">
                    <div class="kpi-card kpi-blue">
                        <div class="kpi-ico"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
                        <div class="kpi-info"><span class="kpi-val">@_stats.TotalMateriels</span><span class="kpi-lbl">Matériels</span></div>
                    </div>
                    <div class="kpi-card kpi-indigo">
                        <div class="kpi-ico"><svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></div>
                        <div class="kpi-info"><span class="kpi-val">@_stats.TotalCommandes</span><span class="kpi-lbl">Commandes</span></div>
                    </div>
                    <div class="kpi-card kpi-emerald">
                        <div class="kpi-ico"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>
                        <div class="kpi-info"><span class="kpi-val">@_stats.TotalArticles</span><span class="kpi-lbl">Articles inventoriés</span></div>
                    </div>
                    <div class="kpi-card kpi-amber">
                        <div class="kpi-ico"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
                        <div class="kpi-info"><span class="kpi-val">@_stats.TotalDemandesActives</span><span class="kpi-lbl">Demandes actives</span></div>
                    </div>
                </div>

                @* ══ ROW 1 : Articles/catégorie  +  État demandes ══ *@
                <div class="charts-grid charts-grid-2">

                    <div class="chart-card">
                        <div class="chart-header">
                            <div class="chart-title-row">
                                <div class="chart-title">
                                    <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                                    Articles par catégorie
                                </div>
                                <div class="filter-chips">
                                    <button class="chip @(_filtreArticlesCat=="all"?"chip-active":"")"        @onclick='()=>SetFiltreArticlesCat("all")'>Tous</button>
                                    <button class="chip @(_filtreArticlesCat=="disponible"?"chip-active":"")" @onclick='()=>SetFiltreArticlesCat("disponible")'>Disponibles</button>
                                    <button class="chip @(_filtreArticlesCat=="affecte"?"chip-active":"")"    @onclick='()=>SetFiltreArticlesCat("affecte")'>Affectés</button>
                                </div>
                            </div>
                            <span class="chart-sub">Nombre d'articles individuels par catégorie</span>
                        </div>
                        <div class="chart-body" id="chart-articles-categorie"></div>
                    </div>

                    <div class="chart-card">
                        <div class="chart-header">
                            <div class="chart-title-row">
                                <div class="chart-title">
                                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                                    État des demandes
                                </div>
                                <div class="inline-filters">
                                    <select class="mini-select" @onchange="OnEtatAnneeChange">
                                        @foreach (var a in _annees)
                                        { <option value="@a" selected="@(_etatAnnee==a)">@a</option> }
                                    </select>
                                    <select class="mini-select" @onchange="OnEtatMoisChange">
                                        <option value="0" selected="@(_etatMois==0)">Tous les mois</option>
                                        @foreach (var m in _moisOptions)
                                        { <option value="@m.Value" selected="@(_etatMois==m.Value)">@m.Label</option> }
                                    </select>
                                </div>
                            </div>
                            <span class="chart-sub">Répartition par statut</span>
                        </div>
                        <div class="chart-body" id="chart-etat-demandes"></div>
                    </div>
                </div>

                @* ══ ROW 2 : Évolution semaines ══ *@
                <div class="charts-grid charts-grid-1">
                    <div class="chart-card">
                        <div class="chart-header">
                            <div class="chart-title-row">
                                <div class="chart-title">
                                    <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                                    Évolution des demandes — 8 semaines
                                </div>
                                <div class="inline-filters">
                                    <label class="mini-label">Du</label>
                                    <input type="date" class="mini-date"
                                           value="@_semDebut.ToString("yyyy-MM-dd")"
                                           @onchange="OnSemDebutChange" />
                                    <label class="mini-label">Au</label>
                                    <input type="date" class="mini-date"
                                           value="@_semFin.ToString("yyyy-MM-dd")"
                                           @onchange="OnSemFinChange" />
                                    <button class="btn-apply" @onclick="AppliquerSemaines">↻ Appliquer</button>
                                </div>
                            </div>
                            <span class="chart-sub">Area stacked · statuts par semaine</span>
                        </div>
                        <div class="chart-body" id="chart-demandes-semaine"></div>
                    </div>
                </div>

                @* ══ ROW 3 : Affectation + Articles/matériel ══ *@
                <div class="charts-grid charts-grid-2">

                    <div class="chart-card">
                        <div class="chart-header">
                            <div class="chart-title">
                                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                                Affectation du matériel
                            </div>
                            <span class="chart-sub">@_stats.AffectationMateriel.Affecte affecté(s) · @_stats.AffectationMateriel.NonAffecte non-affecté(s)</span>
                        </div>
                        <div class="chart-body" id="chart-affectation"></div>
                    </div>

                    <div class="chart-card">
                        <div class="chart-header">
                            <div class="chart-title-row">
                                <div class="chart-title">
                                    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                                    Articles par matériel
                                </div>
                                <div class="filter-chips">
                                    <button class="chip @(_filtreArticlesMat=="all"?"chip-active":"")"        @onclick='()=>SetFiltreArticlesMat("all")'>Tous</button>
                                    <button class="chip @(_filtreArticlesMat=="disponible"?"chip-active":"")" @onclick='()=>SetFiltreArticlesMat("disponible")'>Disponibles</button>
                                    <button class="chip @(_filtreArticlesMat=="affecte"?"chip-active":"")"    @onclick='()=>SetFiltreArticlesMat("affecte")'>Affectés</button>
                                </div>
                            </div>
                            <span class="chart-sub">Top 15 matériels · bar stacked horizontal</span>
                        </div>
                        <div class="chart-body" id="chart-articles-materiel"></div>
                    </div>
                </div>

                @* ══ ROW 4 : Demandes 4 semaines du mois ══ *@
                <div class="charts-grid charts-grid-1">
                    <div class="chart-card">
                        <div class="chart-header">
                            <div class="chart-title-row">
                                <div class="chart-title">
                                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                    Demandes d'achat — 4 semaines du mois
                                </div>
                                <div class="inline-filters">
                                    <select class="mini-select" @onchange="OnMoisDemandesChange">
                                        @foreach (var m in _moisOptions)
                                        { <option value="@m.Value" selected="@(_moisDemandes==m.Value)">@m.Label</option> }
                                    </select>
                                    <select class="mini-select" @onchange="OnAnneeDemandesChange">
                                        @foreach (var a in _annees)
                                        { <option value="@a" selected="@(_anneeDemandes==a)">@a</option> }
                                    </select>
                                    <button class="btn-apply" @onclick="AppliquerDemandesMois">↻ Appliquer</button>
                                </div>
                            </div>
                            <span class="chart-sub">Semaine 1-2-3-4 du mois sélectionné · grouped bar</span>
                        </div>
                        <div class="chart-body" id="chart-demandes-mois"></div>
                    </div>
                </div>
            }
        </div>
    </main>

    @if (!string.IsNullOrEmpty(_toastMsg))
    { <div class="toast @_toastType">@_toastMsg</div> }

</div>
</RoleAuthGuard>
