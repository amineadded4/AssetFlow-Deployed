@* ============================================================
   FICHIER  : Pages/Achat/WebScraping.razor
   ============================================================ *@

@page "/achat/web-scraping"
@using Microsoft.JSInterop
@using AssetFlow.BlazorUI.Pages.Achat
@using AssetFlow.BlazorUI.Components

<RoleAuthGuard AllowedRoles="@(new[]{"EquipeAchat","Admin"})">
    <div class="ws-shell" data-theme="@_theme">

        @if (_sidebarOpen)
        {
            <div class="sidebar-overlay" @onclick="ToggleSidebar"></div>
        }

        @* ══════ MODAL D'ATTENTE SCRAPING ══════ *@
        @if (_chargement)
        {
            <div class="ws-modal-overlay">
                <div class="ws-modal-box">
                    <div class="ws-modal-ring"></div>
                    <h3 class="ws-modal-title">Recherche en cours…</h3>
                    <p class="ws-modal-desc">
                        Nous interrogeons <strong>MyTek</strong>, <strong>Tunisianet</strong> et <strong>SpaceNet</strong>
                        simultanément.<br />Cette opération peut prendre <strong>1.5 à 2 minutes</strong>.
                    </p>
                    <div class="ws-modal-sites">
                        <span class="ws-modal-site">
                            <span class="ws-modal-dot dot-pulse1"></span>MyTek
                        </span>
                        <span class="ws-modal-site">
                            <span class="ws-modal-dot dot-pulse2"></span>Tunisianet
                        </span>
                        <span class="ws-modal-site">
                            <span class="ws-modal-dot dot-pulse3"></span>SpaceNet
                        </span>
                    </div>
                    <p class="ws-modal-hint">Merci de patienter, ne fermez pas la page.</p>
                </div>
            </div>
        }
        @if (_estAdmin)
        {
            <AdminSidebar ForceOpen="_sidebarOpen" />
        }
        else
        {
            <AchatSidebar ActivePage="scraping" ForceOpen="_sidebarOpen" />
        }

        @* ══════ ZONE PRINCIPALE ══════ *@
        <main class="ws-main">

            <header class="ws-topbar">
                <div class="ws-topbar-inner">
                    <button class="topbar-menu-btn" @onclick="ToggleSidebar">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <line x1="3" y1="6"  x2="21" y2="6"/>
                            <line x1="3" y1="12" x2="21" y2="12"/>
                            <line x1="3" y1="18" x2="21" y2="18"/>
                        </svg>
                    </button>
                    <div class="ws-topbar-brand">
                        <h1>Scraping Marché</h1>
                        <span class="ws-role-badge">Recherche de prix</span>
                    </div>
                </div>
            </header>

            <div class="ws-content">

                <section class="ws-search-section">
                    <div class="ws-search-header">
                        <div>
                            <h2 class="ws-section-title">Résultats du marché en temps réel</h2>
                            @if (_derniereRecherche != null)
                            {
                                <p class="ws-last-update">
                                    <svg viewBox="0 0 24 24" width="14" height="14"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                    Dernière recherche : @_nomRecherche
                                </p>
                            }
                            else
                            {
                                <p class="ws-last-update">Saisissez un produit pour lancer la recherche</p>
                            }
                        </div>
                        @if (_resultats.Any())
                        {
                            <div class="ws-segmented">
                                <button class="ws-seg-btn @(_filtreActif == "prix" ? "seg-active" : "")" @onclick='() => _filtreActif = "prix"'>Prix</button>
                                <button class="ws-seg-btn @(_filtreActif == "dispo" ? "seg-active" : "")" @onclick='() => _filtreActif = "dispo"'>Disponibilité</button>
                            </div>
                        }
                    </div>

                    <div class="ws-search-bar">
                        <div class="ws-input-wrap">
                            <span class="ws-search-ico">
                                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            </span>
                            <input class="ws-input" type="text"
                                placeholder="Ex: Dell XPS 15, Souris Logitech, Switch Cisco…"
                                @bind="_recherche" @bind:event="oninput" @onkeydown="OnKeyDown" />
                            @if (!string.IsNullOrWhiteSpace(_recherche))
                            {
                                <button class="ws-clear-btn" @onclick="ViderRecherche" title="Effacer">
                                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                </button>
                            }
                        </div>
                        <button class="ws-search-btn"
                                disabled="@(string.IsNullOrWhiteSpace(_recherche) || _chargement)"
                                @onclick="LancerRecherche">
                            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            <span>Rechercher</span>
                        </button>
                    </div>
                </section>

                @* ── ÉTAT INITIAL ── *@
                @if (_derniereRecherche == null && !_chargement)
                {
                    <div class="ws-empty-state">
                        <div class="ws-empty-ico">
                            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                        </div>
                        <h3>Recherche de prix en temps réel</h3>
                        <p>Saisissez le nom d'un produit pour comparer les prix<br />sur les principales marketplaces tunisiennes.</p>
                    </div>
                }

                @* ── RÉSULTATS ── *@
                @if (_resultats.Any() && !_chargement)
                {
                    var resultatsAffiches = _filtreActif == "dispo"
                        ? _resultats.Where(r => r.EnStock).ToList()
                        : _resultats.OrderBy(r => r.Prix).ToList();

                    @* ── PANNEAU DE FILTRES (style MyTek) ── *@
                    <div class="ws-filters-panel">

                        @* Filtre Site *@
                        <div class="ws-filter-group">
                            <p class="ws-filter-label">
                                <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                Site
                            </p>
                            <div class="ws-filter-sites">
                                @foreach (var site in _resultats.Select(r => r.Site).Distinct().OrderBy(s => s))
                                {
                                    var isChecked = _filtresSites.Contains(site);
                                    <label class="ws-filter-checkbox">
                                        <input type="checkbox" checked="@isChecked" @onchange="() => ToggleSite(site)" />
                                        <span class="ws-checkbox-custom"></span>
                                        <span class="ws-checkbox-label">@site</span>
                                    </label>
                                }
                            </div>
                        </div>

                        <div class="ws-filter-sep"></div>

                        @* Filtre Prix *@
                        <div class="ws-filter-group">
                            <p class="ws-filter-label">
                                <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                                Prix (DT)
                            </p>
                            <div class="ws-price-range-display">
                                <span class="ws-price-val">@_prixMin.ToString("N0") DT</span>
                                <span class="ws-price-sep">—</span>
                                <span class="ws-price-val">@_prixMax.ToString("N0") DT</span>
                            </div>
                            <div class="ws-slider-wrap">
                                <div class="ws-range-track">
    <div class="ws-range-fill" style="left:@((double)(_prixMin - _prixAbsoluMin) * 100.0 / (double)(_prixAbsoluMax - _prixAbsoluMin))%;right:@((1.0 - (double)(_prixMax - _prixAbsoluMin) / (double)(_prixAbsoluMax - _prixAbsoluMin)) * 100.0)%"></div>                            </div>
                                <input type="range" class="ws-range"
                                    min="@_prixAbsoluMin" max="@_prixAbsoluMax" step="1"
                                    value="@_prixMin"
                                    @oninput="OnPrixMinChange" />
                                <input type="range" class="ws-range"
                                    min="@_prixAbsoluMin" max="@_prixAbsoluMax" step="1"
                                    value="@_prixMax"
                                    @oninput="OnPrixMaxChange" />
                            </div>
                            <div class="ws-price-inputs">
                                <input type="number" class="ws-price-input"
                                    value="@_prixMin" min="@_prixAbsoluMin" max="@_prixMax"
                                    @oninput="OnPrixMinChange" />
                                <input type="number" class="ws-price-input"
                                    value="@_prixMax" min="@_prixMin" max="@_prixAbsoluMax"
                                    @oninput="OnPrixMaxChange" />
                            </div>
                        </div>

                        <button class="ws-filter-reset" @onclick="ResetFiltres">
                            <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.73"/></svg>
                            Réinitialiser
                        </button>
                    </div>

                    
                        var resultatsFiltrés = resultatsAffiches
                            .Where(r =>
                                (!_filtresSites.Any() || _filtresSites.Contains(r.Site)) &&
                                r.Prix >= _prixMin && r.Prix <= _prixMax
                            ).ToList();
                    

                    @* Cards top 3 *@
                    <div class="ws-cards-grid">
                        @foreach (var r in resultatsFiltrés.Take(3))
                        {
                            <div class="ws-card @(!r.EnStock ? "ws-card-rupture" : "")">
                                <div class="ws-card-top">
                                    <div class="ws-store-ico">
                                        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                    </div>
                                    <span class="ws-badge @(r.EnStock ? "badge-stock" : "badge-rupture")">
                                        <span class="badge-dot"></span>
                                        @(r.EnStock ? "En stock" : "Rupture")
                                    </span>
                                </div>
                                <p class="ws-card-site">@r.Site</p>
                                <h4 class="ws-card-produit">@r.NomProduit</h4>
                                <div class="ws-card-prix">
                                    <span class="prix-val">@r.Prix.ToString("N3")</span>
                                    <span class="prix-devise">DT</span>
                                </div>
                                <div class="ws-card-infos">
                                    <div class="ws-card-info-row">
                                        <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                                        <span>@(r.EnStock ? r.Livraison : "Indisponible")</span>
                                    </div>
                                    <div class="ws-card-info-row">
                                        <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                        <span>@r.Garantie</span>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(r.Url))
                                {
                                    <a href="@r.Url" target="_blank" class="ws-card-btn">
                                        Voir sur le site
                                        <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                                    </a>
                                }
                            </div>
                        }
                    </div>

                    @* Tableau scrollable *@
                    <div class="ws-table-section">
                        <div class="ws-table-header">
                            <div class="ws-table-header-left">
                                <h3>Tous les résultats détaillés</h3>
                                <span class="ws-table-count">@resultatsFiltrés.Count résultat(s)</span>
                            </div>
                            <button class="ws-export-btn" @onclick="ExporterCsv">
                                <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                Exporter CSV
                            </button>
                        </div>
                        <div class="ws-table-scroll">
                            <table class="ws-table">
                                <thead>
                                    <tr>
                                        <th>Site</th>
                                        <th>Produit</th>
                                        <th>Prix</th>
                                        <th>Disponibilité</th>
                                        <th class="col-right">Lien</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (resultatsFiltrés.Any())
                                    {
                                        @foreach (var r in resultatsFiltrés)
                                        {
                                            <tr>
                                                <td class="td-site">@r.Site</td>
                                                <td class="td-produit">@r.NomProduit</td>
                                                <td class="td-prix">@r.Prix.ToString("N3") DT</td>
                                                <td>
                                                    <span class="tbl-badge @(r.EnStock ? "badge-stock" : "badge-rupture")">
                                                        @(r.EnStock ? "EN STOCK" : "RUPTURE")
                                                    </span>
                                                </td>
                                                <td class="col-right">
                                                    @if (!string.IsNullOrEmpty(r.Url))
                                                    {
                                                        <a href="@r.Url" target="_blank" class="tbl-link">Ouvrir</a>
                                                    }
                                                    else
                                                    {
                                                        <span class="tbl-link-off">—</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="5" class="td-empty">Aucun résultat pour ces filtres.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                @if (_derniereRecherche != null && !_resultats.Any() && !_chargement)
                {
                    <div class="ws-empty-state">
                        <div class="ws-empty-ico ws-empty-warn">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        </div>
                        <h3>Aucun résultat trouvé</h3>
                        <p>Le produit « @_nomRecherche » n'a pas été trouvé<br />sur les marketplaces disponibles.</p>
                    </div>
                }
            </div>
        </main>

        @if (!string.IsNullOrEmpty(_toastMsg))
        {
            <div class="ws-toast @_toastType">@_toastMsg</div>
        }
    </div>
</RoleAuthGuard>    