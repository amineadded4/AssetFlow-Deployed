@* ============================================================
   AdminFaceSetup.razor — Enregistrement du visage admin
   Route : /admin/face-setup
   ============================================================ *@

@page "/admin/face-setup"
@using AssetFlow.BlazorUI.Components

<div class="admin-shell">

    <AdminSidebar ForceOpen="_sidebarOpen" />

    <main class="admin-main">
        <RoleAuthGuard AllowedRoles="@(new[]{"Admin"})">
        <div class="facesetup-page">

            @* ── EN-TÊTE ── *@
            <div class="facesetup-header">
                <div class="facesetup-header-left">
                    @* Bouton hamburger — visible uniquement en mobile *@
                    <button class="facesetup-hamburger" @onclick="() => _sidebarOpen = !_sidebarOpen">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <line x1="3" y1="6"  x2="21" y2="6"/>
                            <line x1="3" y1="12" x2="21" y2="12"/>
                            <line x1="3" y1="18" x2="21" y2="18"/>
                        </svg>
                    </button>
                    <div>
                        <h1 class="facesetup-title">Reconnaissance faciale</h1>
                        <p class="facesetup-subtitle">Enregistrez votre visage pour vous connecter sans mot de passe.</p>
                    </div>
                </div>
            </div>

            @* ── ÉTAPES ── *@
            <div class="facesetup-steps">
                <div class="facesetup-step @(Step > 1 ? "done" : Step == 1 ? "active" : "")">
                    <div class="step-circle">@(Step > 1 ? "✓" : "1")</div>
                    <span class="step-label">Préparer</span>
                </div>
                <div class="step-line @(Step >= 2 ? "done" : "")"></div>
                <div class="facesetup-step @(Step > 2 ? "done" : Step == 2 ? "active" : "")">
                    <div class="step-circle">@(Step > 2 ? "✓" : "2")</div>
                    <span class="step-label">Scanner</span>
                </div>
                <div class="step-line @(Step >= 3 ? "done" : "")"></div>
                <div class="facesetup-step @(Step == 3 ? "active" : "")">
                    <div class="step-circle">3</div>
                    <span class="step-label">Confirmer</span>
                </div>
            </div>

            @* ── STEP 1 : Instructions ── *@
            @if (Step == 1)
            {
                <div class="facesetup-card">
                    <div class="intro-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 10h.01M15 10h.01"/>
                            <path d="M12 2a8 8 0 0 0-8 8v1a8 8 0 0 0 16 0v-1a8 8 0 0 0-8-8z"/>
                            <path d="M9 14s.5 1 3 1 3-1 3-1"/>
                        </svg>
                    </div>
                    <h2 class="intro-title">Prêt à configurer ?</h2>
                    <p class="intro-desc">Assurez-vous d'être dans un endroit bien éclairé et de regarder directement la caméra.</p>
                    <ul class="intro-tips">
                        <li><svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Bonne luminosité, évitez le contre-jour</li>
                        <li><svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Visage bien centré dans la caméra</li>
                        <li><svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Restez immobile pendant la capture</li>
                        <li><svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Retirez les lunettes de soleil si possible</li>
                    </ul>
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="facesetup-alert error">@ErrorMessage</div>
                    }
                    <button class="facesetup-btn primary" @onclick="GoToScan">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2"/>
                        </svg>
                        Démarrer la caméra
                    </button>
                </div>
            }

            @* ── STEP 2 : Caméra ── *@
            @if (Step == 2)
            {
                <div class="facesetup-card facesetup-scan">
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="facesetup-alert error">@ErrorMessage</div>
                    }
                    <div class="position-guide">
                        <div class="position-guide-label">
                            <span class="position-step-badge">@(CaptureCount + 1) / @MaxCaptures</span>
                            <span class="position-instruction">@CurrentPosition.Instruction</span>
                        </div>
                        <div class="position-faces">
                            @for (int i = 0; i < Positions.Length; i++)
                            {
                                var pos   = Positions[i];
                                var index = i;
                                <div class="position-face-item @(index < CaptureCount ? "done" : index == CaptureCount ? "active" : "pending")">
                                    <svg viewBox="0 0 60 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        @((MarkupString)pos.SvgContent)
                                    </svg>
                                    <span class="position-face-label">@pos.Label</span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="camera-wrapper">
                        <video id="fs-video" autoplay muted playsinline style="display:none;"></video>
                        <canvas id="fs-canvas" class="camera-canvas"></canvas>
                        <div class="camera-status @(FaceDetected ? "detected" : "waiting")">
                            @if (FaceDetected)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <span>Visage détecté — prêt à capturer</span>
                            }
                            else
                            {
                                <span class="camera-dot"></span>
                                <span>Positionnez votre visage dans l'ovale</span>
                            }
                        </div>
                    </div>
                    <div class="capture-counter">
                        <span class="capture-count">@CaptureCount / @MaxCaptures</span>
                        <span class="capture-label">captures effectuées</span>
                        <div class="capture-bar">
                            <div class="capture-bar-fill" style="width: @(CaptureCount * 100 / MaxCaptures)%"></div>
                        </div>
                    </div>
                    <div class="facesetup-actions">
                        <button class="facesetup-btn secondary" @onclick="GoBack" disabled="@IsCapturing">Retour</button>
                        <button class="facesetup-btn primary" @onclick="CaptureFrame" disabled="@(!FaceDetected || IsCapturing)">
                            @if (IsCapturing)
                            {
                                <span class="btn-spinner"></span>
                                <span>Capture...</span>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="3"/><path d="M6.94 6.94A8 8 0 1 0 17.06 17.06"/>
                                    <path d="M2 12h1M12 2v1M21 12h-1M12 21v-1"/>
                                </svg>
                                <span>Capturer (@(MaxCaptures - CaptureCount) restant@(MaxCaptures - CaptureCount > 1 ? "s" : ""))</span>
                            }
                        </button>
                    </div>
                </div>
            }

            @* ── STEP 3 : Confirmation ── *@
            @if (Step == 3)
            {
                <div class="facesetup-card facesetup-confirm">
                    @if (SaveSuccess)
                    {
                        <div class="confirm-icon success">
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </div>
                        <h2 class="confirm-title">Visage enregistré !</h2>
                        <p class="confirm-desc">Vous pouvez maintenant vous connecter via l'onglet "Reconnaissance faciale" du modal admin.</p>
                        <button class="facesetup-btn primary" @onclick="Reset">Recommencer l'enregistrement</button>
                    }
                    else
                    {
                        <div class="confirm-icon warning">
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                                <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                            </svg>
                        </div>
                        <h2 class="confirm-title">Prêt à enregistrer</h2>
                        <p class="confirm-desc">@CaptureCount captures effectuées. Cliquez sur Enregistrer pour sauvegarder votre profil facial.</p>
                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div class="facesetup-alert error">@ErrorMessage</div>
                        }
                        <div class="facesetup-actions">
                            <button class="facesetup-btn secondary" @onclick="GoBack" disabled="@IsSaving">Retour</button>
                            <button class="facesetup-btn primary" @onclick="SaveFace" disabled="@IsSaving">
                                @if (IsSaving)
                                {
                                    <span class="btn-spinner"></span>
                                    <span>Enregistrement...</span>
                                }
                                else
                                {
                                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                                        <polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
                                    </svg>
                                    <span>Enregistrer mon visage</span>
                                }
                            </button>
                        </div>
                    }
                </div>
            }

        </div>
        </RoleAuthGuard>
    </main>

</div>

@code {
    private bool _sidebarOpen = false;
}
