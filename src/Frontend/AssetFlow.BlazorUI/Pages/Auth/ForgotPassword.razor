@page "/forgot-password"
@using AssetFlow.BlazorUI.Components

<div class="login-page">
    <div class="mobile-header">
        <img src="images/logo.png" alt="AssetFlow" class="mobile-header-logo" />
        <ThemeToggle />
    </div>

    <div class="left-panel">
        <div class="left-panel-content">
            <img src="images/logo.png" alt="AssetFlow" class="panel-logo" />
            <p class="panel-app-subtitle">Système intelligent de gestion de stock</p>
        </div>
    </div>

    <div class="right-panel">
        <div class="form-container">

            @if (Step == 1)
            {
                <div class="form-header">
                    <h1 class="form-title">Mot de passe oublié</h1>
                    <p class="form-subtitle">Entrez votre email pour recevoir un code à 6 chiffres.</p>
                </div>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-error">@ErrorMessage</div>
                }

                <InputField Label="E-mail" Placeholder="votre@email.com"
                    @bind-Value="Email" InputType="email"
                    HasError="EmailError" ErrorMessage="Adresse email invalide" />

                <button class="btn-primary" style="background-color:#136dec;box-shadow:0 4px 20px rgba(19,109,236,0.35)"
                        @onclick="HandleSendCode" disabled="@IsLoading">
                    @if (IsLoading) { <span>Envoi en cours...</span> }
                    else            { <span>Envoyer le code</span>  }
                </button>
            }

            @if (Step == 2)
            {
                <div class="form-header">
                    <h1 class="form-title">Vérification</h1>
                    <p class="form-subtitle">
                        Un code a été envoyé à <strong>@Email</strong>. 
                        Entrez-le ci-dessous avec votre nouveau mot de passe.
                    </p>
                </div>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-error">@ErrorMessage</div>
                }
                @if (!string.IsNullOrEmpty(SuccessMessage))
                {
                    <div class="alert alert-success">@SuccessMessage</div>
                }

                @* Token 6 chiffres *@
                <div class="token-input-wrap">
                    <label class="input-label">CODE À 6 CHIFFRES</label>
                    <div class="token-boxes">
                        @for (int i = 0; i < 6; i++)
                        {
                            var index = i;
                            <input class="token-box @(TokenError ? "error" : "")"
                                maxlength="1"
                                inputmode="numeric"
                                value="@TokenDigits[index]"
                                @oninput="e => OnTokenDigitInput(e, index)"
                                @onkeydown="e => OnTokenKeyDown(e, index)"
                                @onpaste="e => OnTokenPaste(e, index)"
                                id="token-@index" />
                        }
                    </div>
                </div>

                <InputField Label="Nouveau mot de passe" Placeholder="••••••••"
                    @bind-Value="NewPassword" InputType="password" ShowPasswordToggle="true" />

                <InputField Label="Confirmer le mot de passe" Placeholder="••••••••"
                    @bind-Value="ConfirmPassword" InputType="password" ShowPasswordToggle="true"
                    HasError="PasswordMismatch" ErrorMessage="Les mots de passe ne correspondent pas" />

                <button class="btn-primary" style="background-color:#136dec;box-shadow:0 4px 20px rgba(19,109,236,0.35)"
                        @onclick="HandleResetPassword" disabled="@IsLoading">
                    @if (IsLoading) { <span>Réinitialisation...</span> }
                    else            { <span>Changer le mot de passe</span> }
                </button>

                <div class="back-link" style="margin-top:0.75rem">
                    <a @onclick="() => Step = 1" @onclick:preventDefault href="#" 
                       style="cursor:pointer;font-size:0.83rem;color:var(--text-faint)">
                        ← Changer d'email
                    </a>
                </div>
            }

            <div class="back-link">
                <a href="/login?role=@Role">← Retour à la connexion</a>
            </div>
        </div>

        <div class="legal-footer">
            <p>© 2025 AssetFlow Technologies. Tous droits réservés.</p>
        </div>
    </div>
</div>