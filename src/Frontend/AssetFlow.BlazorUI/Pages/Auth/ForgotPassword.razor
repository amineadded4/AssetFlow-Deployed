@page "/forgot-password"
@using AssetFlow.BlazorUI.Components

<div class="login-page">
    <div class="mobile-header">
        <img src="images/logo.png" alt="AssetFlow" class="mobile-header-logo" />
        <ThemeToggle />
    </div>

    <div class="left-panel">
        <div class="left-panel-content">
            <img src="images/logo.png" alt="AssetFlow" class="panel-logo" />
            <p class="panel-app-subtitle">Système intelligent de gestion de stock</p>
        </div>
    </div>

    <div class="right-panel">
        <div class="fp-card">

            @* ── STEP 1 : Email ── *@
            @if (Step == 1)
            {
                <div class="fp-header">
                    <div class="fp-icon-wrap" style="background:@RoleColor15;border-color:@RoleColor30">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="@RoleColor" stroke-width="2" stroke-linecap="round">
                            <rect x="2" y="4" width="20" height="16" rx="3"/><path d="m2 7 10 7 10-7"/>
                        </svg>
                    </div>
                    <div>
                        <h1 class="fp-title">Mot de passe oublié</h1>
                        <p class="fp-subtitle">Entrez votre adresse email pour recevoir un code de réinitialisation.</p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="fp-alert fp-alert-error">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                        @ErrorMessage
                    </div>
                }

                @if (IsLoading)
                {
                    <div class="fp-sending">
                        <div class="fp-sending-dots"><span></span><span></span><span></span></div>
                        <p>Envoi du code à <strong>@Email</strong>…</p>
                    </div>
                }
                else
                {
                    <div class="fp-field">
                        <label class="fp-label">ADRESSE EMAIL</label>
                        <div class="fp-input-wrap @(EmailError ? "has-error" : "")">
                            <svg class="fp-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                <rect x="2" y="4" width="20" height="16" rx="3"/><path d="m2 7 10 7 10-7"/>
                            </svg>
                            <input class="fp-input" type="email" placeholder="votre@email.com"
                                   @bind="Email" @bind:event="oninput" />
                        </div>
                        @if (EmailError)
                        {
                            <span class="fp-field-error">Adresse email invalide.</span>
                        }
                    </div>

                    <button class="fp-btn" style="background:@RoleColor;box-shadow:0 6px 24px @RoleColorShadow"
                            @onclick="HandleSendCode">
                        Envoyer le code
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </button>
                }

                <div class="fp-back">
                    <a href="/login?role=@Role">← Retour à la connexion</a>
                </div>
            }

            @* ── STEP 2 : Code + nouveau mot de passe ── *@
            @if (Step == 2)
            {
                @if (PasswordChanged)
                {
                    <div class="fp-success">
                        <div class="fp-success-icon">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </div>
                        <h2 class="fp-success-title">Mot de passe modifié !</h2>
                        <p class="fp-success-sub">Vous pouvez maintenant vous connecter avec votre nouveau mot de passe.</p>
                        <a href="/login?role=@Role" class="fp-btn"
                           style="background:@RoleColor;box-shadow:0 6px 24px @RoleColorShadow;text-decoration:none;margin-top:0.25rem">
                            Se connecter
                        </a>
                    </div>
                }
                else
                {
                    <div class="fp-header">
                        <div class="fp-icon-wrap" style="background:@RoleColor15;border-color:@RoleColor30">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="@RoleColor" stroke-width="2" stroke-linecap="round">
                                <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </div>
                        <div>
                            <h1 class="fp-title">Réinitialisation</h1>
                            <p class="fp-subtitle">Code envoyé à <strong>@Email</strong>. Saisissez-le ci-dessous.</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="fp-alert fp-alert-error">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                            @ErrorMessage
                        </div>
                    }

                    <div class="fp-field">
                        <label class="fp-label">CODE À 6 CHIFFRES</label>
                        <div class="fp-token-boxes">
                            @for (int i = 0; i < 6; i++)
                            {
                                var index = i;
                                <input class="fp-token @(TokenError ? "fp-token-error" : "")"
                                       maxlength="1" inputmode="numeric"
                                       value="@TokenDigits[index]"
                                       @oninput="e => OnTokenDigitInput(e, index)"
                                       @onkeydown="e => OnTokenKeyDown(e, index)"
                                       @onpaste="e => OnTokenPaste(e, index)"
                                       id="token-@index" />
                            }
                        </div>
                        @if (TokenError)
                        {
                            <span class="fp-field-error">Veuillez saisir les 6 chiffres.</span>
                        }
                    </div>

                    <div class="fp-field">
                        <label class="fp-label">NOUVEAU MOT DE PASSE</label>
                        <div class="fp-input-wrap">
                            <svg class="fp-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                            <input class="fp-input" type="password" placeholder="••••••••" @bind="NewPassword" @bind:event="oninput" />
                        </div>
                    </div>

                    <div class="fp-field">
                        <label class="fp-label">CONFIRMER LE MOT DE PASSE</label>
                        <div class="fp-input-wrap @(PasswordMismatch ? "has-error" : "")">
                            <svg class="fp-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                            <input class="fp-input" type="password" placeholder="••••••••" @bind="ConfirmPassword" @bind:event="oninput" />
                        </div>
                        @if (PasswordMismatch)
                        {
                            <span class="fp-field-error">Les mots de passe ne correspondent pas.</span>
                        }
                    </div>

                    <button class="fp-btn" style="background:@RoleColor;box-shadow:0 6px 24px @RoleColorShadow"
                            @onclick="HandleResetPassword" disabled="@IsLoading">
                        @if (IsLoading) { <span>Réinitialisation…</span> }
                        else
                        {
                            <span>Changer le mot de passe</span>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        }
                    </button>

                    <div class="fp-back">
                        <a @onclick="() => Step = 1" @onclick:preventDefault href="#">← Changer d'email</a>
                    </div>
                }
            }

        </div>

        <div class="fp-legal">
            <p>© 2025 AssetFlow Technologies. Tous droits réservés.</p>
        </div>
    </div>
</div>