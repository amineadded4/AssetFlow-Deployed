@page "/it/biographie"
@using AssetFlow.BlazorUI.DTOs
@using AssetFlow.BlazorUI.Services
@using AssetFlow.BlazorUI.Components


<div class="bio-layout">
        @* ══════ SIDEBAR ══════ *@
        <ITSidebar ActivePage="biographie"/>

    <div class="bio-page">

        @* ── En-tête ── *@
        <div class="bio-header">
            <div class="bio-header-title">
                <svg class="bio-header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                </svg>
                <div>
                    <h1>Biographie des articles</h1>
                    <p>Consultez toute la vie d'un article : affectations, incidents, réparations et durées.</p>
                </div>
            </div>
        </div>

        @* ── Sélecteur matériel → article ── *@
        <div class="bio-selector-card">
            @if (_loading)
            {
                <div class="bio-spinner-wrap"><span class="bio-spinner"></span><span>Chargement des matériels…</span></div>
            }
            else if (_materiels == null || !_materiels.Any())
            {
                <p class="bio-empty">Aucun matériel disponible.</p>
            }
            else
            {
                <div class="bio-selector-row">
                    <div class="bio-selector-group">
                        <label>Matériel</label>
                        <select @onchange="OnMaterielChanged">
                            <option value="">— Choisir un matériel —</option>
                            @foreach (var m in _materiels)
                            {
                                <option value="@m.MaterielId">
                                    [@m.Reference] @m.Designation — @m.Categorie
                                    (@m.Articles.Count article@(m.Articles.Count > 1 ? "s" : ""))
                                </option>
                            }
                        </select>
                    </div>

                    @if (_materielSelectionne != null)
                    {
                        <div class="bio-selector-group">
                            <label>Article (unité physique)</label>
                            <select @onchange="OnArticleChanged">
                                <option value="">— Choisir un article —</option>
                                @foreach (var a in _materielSelectionne.Articles)
                                {
                                    <option value="@a.ArticleId">
                                        @a.NumeroSerie — @a.Statut / @a.Etat
                                        @(a.AffecteA != null ? $" → {a.AffecteA}" : " (en stock)")
                                    </option>
                                }
                            </select>
                        </div>
                    }
                </div>
            }
        </div>

        @* ── Biographie ── *@
        @if (_loadingBio)
        {
            <div class="bio-spinner-wrap"><span class="bio-spinner"></span><span>Chargement de la biographie…</span></div>
        }
        else if (_bio != null)
        {
            @* Carte d'identité *@
            <div class="bio-identity-card">
                <div class="bio-identity-avatar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
                    </svg>
                </div>
                <div class="bio-identity-info">
                    <h2>@_bio.MaterielDesignation</h2>
                    <p class="bio-identity-model">Réf. @_bio.MaterielReference — @_bio.MaterielCategorie</p>
                    <p class="bio-identity-serial">N° série : <strong>@_bio.NumeroSerie</strong></p>
                    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:0.4rem;">
                        <span class="bio-etat-badge bio-statut-@_bio.Statut.ToLower()">@_bio.Statut</span>
                        <span class="bio-etat-badge bio-etat-@_bio.Etat.ToLower()">@_bio.Etat</span>
                    </div>
                </div>
                <div class="bio-identity-affectation">
                    @if (_bio.AffectationActuelle != null)
                    {
                        <div class="bio-affectation-current">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                            </svg>
                            <span>Chez <strong>@_bio.AffectationActuelle</strong></span>
                        </div>
                    }
                </div>
            </div>

            @* ── Statistiques ── *@
            <div class="bio-stats-grid">

                @* Âge total *@
                <div class="bio-stat-card">
                    <div class="bio-stat-icon bio-stat-age">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                        </svg>
                    </div>
                    <div class="bio-stat-value">@_bio.AgeTotalJours <span>j</span></div>
                    <div class="bio-stat-label">Âge total</div>
                    <div class="bio-stat-sub">Depuis le @_bio.DateAcquisition.ToString("dd/MM/yyyy")</div>
                </div>

                @* Personnes *@
                <div class="bio-stat-card">
                    <div class="bio-stat-icon bio-stat-people">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                    </div>
                    <div class="bio-stat-value">@_bio.NombrePersonnes</div>
                    <div class="bio-stat-label">Personnes</div>
                    <div class="bio-stat-sub">ayant eu cet article</div>
                </div>

                @* Incidents *@
                <div class="bio-stat-card">
                    <div class="bio-stat-icon bio-stat-incident">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3ZM12 9v4M12 17h.01"/>
                        </svg>
                    </div>
                    <div class="bio-stat-value">@_bio.NombreIncidents</div>
                    <div class="bio-stat-label">Incidents</div>
                    <div class="bio-stat-sub">pannes déclarées</div>
                </div>

                @* Réparations *@
                <div class="bio-stat-card">
                    <div class="bio-stat-icon bio-stat-repair">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                        </svg>
                    </div>
                    <div class="bio-stat-value">@_bio.NombreReparations</div>
                    <div class="bio-stat-label">Réparations</div>
                    <div class="bio-stat-sub">effectuées</div>
                </div>

                @* ── NOUVEAU : Projets ── *@
                <div class="bio-stat-card">
                    <div class="bio-stat-icon bio-stat-projet">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                        </svg>
                    </div>
                    <div class="bio-stat-value">@_bio.NombreProjets </div>
                    <div class="bio-stat-label">Projets</div>
                    <div class="bio-stat-sub">participations</div>
                </div>

            </div>

            @* Timeline *@
            <div class="bio-timeline-section">
                <h3 class="bio-timeline-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
                        <line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/>
                        <line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
                    </svg>
                    Chronologie de vie
                </h3>

                @if (!_bio.Historique.Any())
                {
                    <p class="bio-empty">Aucun événement enregistré pour cet article.</p>
                }
                else
                {
                    <div class="bio-timeline">
                        @foreach (var evt in _bio.Historique)
                        {
                            <div class="bio-timeline-item bio-evt-@evt.TypeEvenement.ToLower()">
                                <div class="bio-timeline-dot">
                                    @GetEvenementIcon(evt.TypeEvenement)
                                </div>
                                <div class="bio-timeline-content">
                                    <div class="bio-timeline-header">
                                        <span class="bio-evt-type">@GetEvenementLabel(evt.TypeEvenement)</span>
                                        <span class="bio-evt-date">@evt.DateEvenement.ToString("dd/MM/yyyy")</span>
                                    </div>
                                    @if (evt.UtilisateurNom != null)
                                    {
                                        <div class="bio-evt-employe">
                                            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                                            </svg>
                                            @evt.UtilisateurNom
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(evt.Description))
                                    {
                                        <div class="bio-evt-desc">@evt.Description</div>
                                    }
                                    @if (evt.DureeDepuisPrecedent.HasValue)
                                    {
                                        <div class="bio-evt-duree">⏱ @evt.DureeDepuisPrecedent j depuis l'événement précédent</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }

    </div>@* fin bio-page *@
</div>@* fin bio-layout *@
