@page "/dashboard/it"
@using AssetFlow.BlazorUI.Components
@using Microsoft.JSInterop

<RoleAuthGuard AllowedRoles="@(new[]{"IT","Admin"})">
<div class="it-layout" data-theme="@_theme">

    @* ══════ SIDEBAR ══════ *@
    @if (_estAdmin)
    {
        <AdminSidebar ForceOpen="_sidebarOpen" />
    }
    else
    {
        <ITSidebar ActivePage="dashboard" ForceOpen="_sidebarOpen" />
    }

    @* ══════ ZONE PRINCIPALE ══════ *@
    <main class="it-main">

        <header class="it-topbar">
            <button class="emp-hamburger" @onclick="() => _sidebarOpen = !_sidebarOpen" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>

            <div class="it-topbar-brand">
                <div class="it-top-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                        <rect x="2" y="3" width="20" height="14" rx="2"/>
                        <line x1="8" y1="21" x2="16" y2="21"/>
                        <line x1="12" y1="17" x2="12" y2="21"/>
                    </svg>
                </div>
                <h1>Tableau de bord IT</h1>
                <span class="it-topbar-role-badge">Statistiques</span>
            </div>

            <div class="it-topbar-actions">
                <span class="it-last-update">Mis à jour à @_lastUpdate</span>
                <button class="it-btn-refresh" @onclick="ChargerDonnees" title="Actualiser">
                    <svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
                </button>
            </div>
        </header>

        <div class="it-scroll">

            @if (_chargement)
            {
                <div class="it-loading">
                    <div class="it-spinner"></div>
                    <span>Chargement des données IT…</span>
                </div>
            }
            else if (_stats == null)
            {
                <div class="it-error">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <p>Impossible de charger les statistiques IT.</p>
                    <button class="it-btn-retry" @onclick="ChargerDonnees">Réessayer</button>
                </div>
            }
            else
            {
                @* ── KPI Row ── *@
                <div class="it-kpi-row">
                    <div class="it-kpi-card it-kpi-blue">
                        <div class="it-kpi-ico">
                            <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                        </div>
                        <div class="it-kpi-info">
                            <span class="it-kpi-val">@_stats.TotalMateriels</span>
                            <span class="it-kpi-lbl">Matériels</span>
                        </div>
                    </div>
                    <div class="it-kpi-card it-kpi-indigo">
                        <div class="it-kpi-ico">
                            <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                        </div>
                        <div class="it-kpi-info">
                            <span class="it-kpi-val">@_stats.TotalArticles</span>
                            <span class="it-kpi-lbl">Articles inventoriés</span>
                        </div>
                    </div>
                    <div class="it-kpi-card it-kpi-rose">
                        <div class="it-kpi-ico">
                            <svg viewBox="0 0 24 24"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3ZM12 9v4M12 17h.01"/></svg>
                        </div>
                        <div class="it-kpi-info">
                            <span class="it-kpi-val">@_stats.IncidentsActifs</span>
                            <span class="it-kpi-lbl">Incidents actifs</span>
                        </div>
                        @if (_stats.IncidentsActifs > 0)
                        {
                            <div class="it-kpi-badge urgent">!</div>
                        }
                    </div>
                    <div class="it-kpi-card it-kpi-emerald">
                        <div class="it-kpi-ico">
                            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                        </div>
                        <div class="it-kpi-info">
                            <span class="it-kpi-val">@_stats.AffectationsEnCours</span>
                            <span class="it-kpi-lbl">Affectations en cours</span>
                        </div>
                    </div>
                    <div class="it-kpi-card it-kpi-amber">
                        <div class="it-kpi-ico">
                            <svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        </div>
                        <div class="it-kpi-info">
                            <span class="it-kpi-val">@_stats.ArticlesHorsService</span>
                            <span class="it-kpi-lbl">Hors service / Réparation</span>
                        </div>
                    </div>
                    <div class="it-kpi-card it-kpi-purple">
                        <div class="it-kpi-ico">
                            <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        </div>
                        <div class="it-kpi-info">
                            <span class="it-kpi-val">@_stats.DemandesAchatEnAttente</span>
                            <span class="it-kpi-lbl">Demandes d'achat</span>
                        </div>
                    </div>
                </div>

                @* ── Heatmap incidents par jour ── *@
                <div class="it-charts-grid it-grid-1">
                    <div class="it-chart-card it-heatmap-card">
                        <div class="it-chart-header">
                            <div class="it-chart-title-row">
                                <div class="it-chart-title">
                                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                    Activité des incidents — Vue calendrier
                                </div>
                                <div class="it-inline-filters">
                                    <label class="it-mini-label">Année</label>
                                    <select class="it-mini-select" @onchange="OnHeatmapAnneeChange">
                                        @foreach (var y in _heatmapAnnees)
                                        {
                                            <option value="@y" selected="@(_heatmapAnnee == y)">@y</option>
                                        }
                                    </select>
                                    <label class="it-mini-label">Matériel</label>
                                    <select class="it-mini-select it-mini-select-wide" @onchange="OnHeatmapMaterielChange">
                                        <option value="0">Tous les matériels</option>
                                        @foreach (var m in _stats.MaterielsDisponibles)
                                        {
                                            <option value="@m.MaterielId"
                                                    selected="@(_heatmapMaterielId == m.MaterielId)">
                                                @m.Designation
                                            </option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <span class="it-chart-sub">Nombre d'incidents par jour · intensité selon la fréquence</span>
                        </div>
                        <div class="it-heatmap-container">
                            <div class="it-heatmap-months" id="heatmap-months-labels"></div>
                            <div class="it-heatmap-body">
                                <div class="it-heatmap-days-labels">
                                    <span>Lun</span><span></span><span>Mer</span><span></span>
                                    <span>Ven</span><span></span><span>Dim</span>
                                </div>
                                <div class="it-heatmap-grid" id="heatmap-grid"></div>
                            </div>
                            <div class="it-heatmap-legend">
                                <span class="it-heatmap-legend-label">Moins</span>
                                <div class="it-heatmap-legend-cell" data-level="0"></div>
                                <div class="it-heatmap-legend-cell" data-level="1"></div>
                                <div class="it-heatmap-legend-cell" data-level="2"></div>
                                <div class="it-heatmap-legend-cell" data-level="3"></div>
                                <div class="it-heatmap-legend-cell" data-level="4"></div>
                                <span class="it-heatmap-legend-label">Plus</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* ── Row 1 : Incidents par type + Statut des incidents ── *@
                <div class="it-charts-grid it-grid-2">
                    <div class="it-chart-card">
                        <div class="it-chart-header">
                            <div class="it-chart-title">
                                <svg viewBox="0 0 24 24"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/></svg>
                                Incidents par type
                            </div>
                            <span class="it-chart-sub">Répartition par catégorie d'incident</span>
                        </div>
                        <div class="it-chart-body" id="chart-incidents-type"></div>
                    </div>

                    <div class="it-chart-card">
                        <div class="it-chart-header">
                            <div class="it-chart-title">
                                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                                Statut des incidents
                            </div>
                            <span class="it-chart-sub">Vue d'ensemble · En attente, En cours, Résolus, Clôturés</span>
                        </div>
                        <div class="it-chart-body" id="chart-incidents-statut"></div>
                    </div>
                </div>

                @* ── Row 2 : Évolution incidents ── *@
                <div class="it-charts-grid it-grid-1">
                    <div class="it-chart-card">
                        <div class="it-chart-header">
                            <div class="it-chart-title-row">
                                <div class="it-chart-title">
                                    <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                                    Évolution des incidents — 8 semaines
                                </div>
                                <div class="it-inline-filters">
                                    <label class="it-mini-label">Du</label>
                                    <input type="date" class="it-mini-date"
                                           value="@_semDebut.ToString("yyyy-MM-dd")"
                                           @onchange="OnSemDebutChange" />
                                    <label class="it-mini-label">Au</label>
                                    <input type="date" class="it-mini-date"
                                           value="@_semFin.ToString("yyyy-MM-dd")"
                                           @onchange="OnSemFinChange" />
                                    <button class="it-btn-apply" @onclick="AppliquerSemaines">↻ Appliquer</button>
                                </div>
                            </div>
                            <span class="it-chart-sub">Area stacked · En attente / En cours / Résolus par semaine</span>
                        </div>
                        <div class="it-chart-body" id="chart-incidents-evolution"></div>
                    </div>
                </div>

                @* ── Row 3 : Articles par statut + Affectations par département ── *@
                <div class="it-charts-grid it-grid-2">
                    <div class="it-chart-card">
                        <div class="it-chart-header">
                            <div class="it-chart-title">
                                <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                                Statut des articles
                            </div>
                            <span class="it-chart-sub">
                                @_stats.ArticlesParStatut.Disponible disponibles ·
                                @_stats.ArticlesParStatut.Affecte affectés ·
                                @_stats.ArticlesParStatut.HorsService H.S ·
                                @_stats.ArticlesParStatut.EnReparation en réparation
                            </span>
                        </div>
                        <div class="it-chart-body" id="chart-articles-statut"></div>
                    </div>

                    <div class="it-chart-card">
                        <div class="it-chart-header">
                            <div class="it-chart-title">
                                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                                Affectations par département
                            </div>
                            <span class="it-chart-sub">Top 10 départements · affectations actives</span>
                        </div>
                        <div class="it-chart-body" id="chart-affectations-dept"></div>
                    </div>
                </div>

                @* ── Row 4 : Tendance résolution + Équipements par catégorie ── *@
                <div class="it-charts-grid it-grid-2">
                    <div class="it-chart-card">
                        <div class="it-chart-header">
                            <div class="it-chart-title">
                                <svg viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                                Temps de résolution moyen
                            </div>
                            <span class="it-chart-sub">Tendance 8 semaines · durée en heures</span>
                        </div>
                        <div class="it-chart-body" id="chart-tendance-resolution"></div>
                    </div>

                    <div class="it-chart-card">
                        <div class="it-chart-header">
                            <div class="it-chart-title">
                                <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                                Taux d'affectation par catégorie
                            </div>
                            <span class="it-chart-sub">% articles affectés / total par catégorie</span>
                        </div>
                        <div class="it-chart-body" id="chart-equipements-categorie"></div>
                    </div>
                </div>
            }
        </div>
    </main>

    @if (!string.IsNullOrEmpty(_toastMsg))
    { <div class="it-toast @_toastType">@_toastMsg</div> }

</div>
</RoleAuthGuard>
