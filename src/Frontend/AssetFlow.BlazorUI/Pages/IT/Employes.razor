@page "/it/employes"
@using AssetFlow.BlazorUI.Services
@using AssetFlow.BlazorUI.Components

<RoleAuthGuard AllowedRoles="@(new[]{"IT"})">
<div class="emp-layout">

    @* ── SIDEBAR (identique à Affectation) ── *@
    <aside class="emp-sidebar">
        <div class="sidebar-logo-wrap">
            <img src="images/logo.png" alt="AssetFlow" class="emp-sidebar-logo" />
        </div>
        <nav class="emp-sidebar-nav">
            <a href="/dashboard/it"  class="emp-nav-link"><svg class="emp-nav-icon" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg><span>Dashboard</span></a>
            <a href="/it/employes"   class="emp-nav-link active"><svg class="emp-nav-icon" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg><span>Employés</span></a>
            <a href="/it/affectation" class="emp-nav-link"><svg class="emp-nav-icon" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg><span>Affectations</span></a>
            <a href="/it/incidents"  class="emp-nav-link"><svg class="emp-nav-icon" viewBox="0 0 24 24"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3ZM12 9v4M12 17h.01"/></svg><span>Incidents</span></a>
            <a href="/it/inventaire" class="emp-nav-link"><svg class="emp-nav-icon" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg><span>Inventaire</span></a>
            <a href="/it/retours"    class="emp-nav-link"><svg class="emp-nav-icon" viewBox="0 0 24 24"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg><span>Retours</span></a>
        </nav>
        <div class="emp-sidebar-profile">
            <div class="emp-profile-avatar">@GetInitials()</div>
            <div>
                <p class="emp-profile-name">@UserName</p>
                <p class="emp-profile-role">IT</p>
            </div>
        </div>
        <LogoutButton />
    </aside>

    @* ── OVERLAY MENU MOBILE ── *@
    @if (_menuOpen)
    {
        <div class="emp-menu-overlay" @onclick="() => _menuOpen = false">
            <div class="emp-menu-drawer" @onclick:stopPropagation="true">
                <div class="emp-menu-drawer-logo">
                    <img src="images/logo.png" alt="AssetFlow" class="emp-sidebar-logo" />
                </div>
                <nav class="emp-menu-drawer-nav">
                    <a href="/dashboard/it"   class="emp-nav-link" @onclick="() => _menuOpen = false"><svg class="emp-nav-icon" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg><span>Dashboard</span></a>
                    <a href="/it/employes"    class="emp-nav-link active" @onclick="() => _menuOpen = false"><svg class="emp-nav-icon" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg><span>Employés</span></a>
                    <a href="/it/affectation" class="emp-nav-link" @onclick="() => _menuOpen = false"><svg class="emp-nav-icon" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg><span>Affectations</span></a>
                    <a href="/it/incidents"   class="emp-nav-link" @onclick="() => _menuOpen = false"><svg class="emp-nav-icon" viewBox="0 0 24 24"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3ZM12 9v4M12 17h.01"/></svg><span>Incidents</span></a>
                    <a href="/it/inventaire"  class="emp-nav-link" @onclick="() => _menuOpen = false"><svg class="emp-nav-icon" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg><span>Inventaire</span></a>
                    <a href="/it/retours"     class="emp-nav-link" @onclick="() => _menuOpen = false"><svg class="emp-nav-icon" viewBox="0 0 24 24"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg><span>Retours</span></a>
                </nav>
                <div class="emp-sidebar-profile">
                    <div class="emp-profile-avatar">@GetInitials()</div>
                    <div><p class="emp-profile-name">@UserName</p><p class="emp-profile-role">IT</p></div>
                </div>
                <LogoutButton />
            </div>
        </div>
    }

    @* ── MAIN ── *@
    <main class="emp-main">

        <header class="emp-header">
            <button class="emp-hamburger" @onclick="() => _menuOpen = !_menuOpen" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
            <div>
                <h1 class="emp-page-title">Gestion des Employés</h1>
                <p class="emp-page-sub">Consultez les employés et gérez leurs affectations</p>
            </div>
            <div class="emp-header-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text" placeholder="Rechercher un employé..."
                       value="@Search" @oninput="OnSearchInput" />
            </div>
        </header>

        @* Alerts *@
        @if (!string.IsNullOrEmpty(SuccessMsg))
        {
            <div class="emp-alert emp-alert-success">
                <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                @SuccessMsg
            </div>
        }
        @if (!string.IsNullOrEmpty(ErrorMsg))
        {
            <div class="emp-alert emp-alert-error">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
                @ErrorMsg
            </div>
        }

        <div class="emp-body">

            @* ══ COLONNE GAUCHE : liste employés ══ *@
            <div class="emp-col-left">
                <div class="emp-col-header">
                    <span class="emp-col-title">Employés</span>
                    <span class="emp-badge">@Employees.Count</span>
                </div>

                @if (LoadingEmployes)
                {
                    <div class="emp-loading"><div class="emp-spinner"></div><span>Chargement...</span></div>
                }
                else if (!Employees.Any())
                {
                    <div class="emp-empty">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                        <p>Aucun employé trouvé</p>
                    </div>
                }
                else
                {
                    <div class="emp-list">
                        @foreach (var emp in Employees)
                        {
                            var isSelected = EmployeSelectionne?.Id == emp.Id;
                            <div class="emp-card @(isSelected ? "selected" : "")"
                                 @onclick="() => SelectEmploye(emp)">
                                <div class="emp-card-avatar @(isSelected ? "sel" : "")">@emp.Initials</div>
                                <div class="emp-card-info">
                                    <p class="emp-card-name">@emp.FullName</p>
                                    <p class="emp-card-dept">@emp.Department</p>
                                    <p class="emp-card-email">@emp.Email</p>
                                </div>
                                <div class="emp-card-right">
                                    @if (emp.NbAffectationsActives > 0)
                                    {
                                        <span class="emp-card-count">@emp.NbAffectationsActives actif(s)</span>
                                    }
                                    else
                                    {
                                        <span class="emp-card-none">Aucun</span>
                                    }
                                    <svg class="emp-card-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            @* ══ COLONNE DROITE : affectations de l'employé ══ *@
            <div class="emp-col-right">
                @if (EmployeSelectionne == null)
                {
                    <div class="emp-placeholder">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        <p>Sélectionnez un employé<br/>pour voir ses affectations</p>
                    </div>
                }
                else
                {
                    @* ── En-tête employé sélectionné ── *@
                    <div class="emp-detail-header">
                        <div class="emp-detail-avatar">@EmployeSelectionne.Initials</div>
                        <div class="emp-detail-info">
                            <h2 class="emp-detail-name">@EmployeSelectionne.FullName</h2>
                            <p class="emp-detail-meta">@EmployeSelectionne.Department · @EmployeSelectionne.Email</p>
                        </div>
                        <span class="emp-detail-count">
                            @(Affectations.Count(a => a.Etat == "Courante")) affectation(s) active(s)
                        </span>
                    </div>

                    @* ── Filtre Courante / Terminée ── *@
                    <div class="emp-filter-tabs">
                        <button class="emp-filter-tab @(FiltreEtat == "tous" ? "active" : "")"    @onclick='() => FiltreEtat = "tous"'>Toutes (@Affectations.Count)</button>
                        <button class="emp-filter-tab @(FiltreEtat == "Courante" ? "active" : "")" @onclick='() => FiltreEtat = "Courante"'>Courantes (@Affectations.Count(a => a.Etat == "Courante"))</button>
                        <button class="emp-filter-tab @(FiltreEtat == "Terminee" ? "active" : "")" @onclick='() => FiltreEtat = "Terminee"'>Terminées (@Affectations.Count(a => a.Etat == "Terminee"))</button>
                    </div>

                    @if (LoadingAffectations)
                    {
                        <div class="emp-loading"><div class="emp-spinner"></div><span>Chargement des affectations...</span></div>
                    }
                    else if (!AffectationsFiltrees.Any())
                    {
                        <div class="emp-empty">
                            <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                            <p>Aucune affectation @(FiltreEtat != "tous" ? FiltreEtat.ToLower() : "")</p>
                        </div>
                    }
                    else
                    {
                        <div class="emp-aff-list">
                            @foreach (var aff in AffectationsFiltrees)
                            {
                                var isCourante = aff.Etat == "Courante";
                                <div class="emp-aff-card @(isCourante ? "" : "terminee")">

                                    @* Image + infos *@
                                    <div class="emp-aff-top">
                                        <div class="emp-aff-img">
                                            @if (!string.IsNullOrEmpty(aff.ImageUrl))
                                            { <img src="@aff.ImageUrl" alt="@aff.Designation" /> }
                                            else
                                            { <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg> }
                                        </div>
                                        <div class="emp-aff-info">
                                            <div class="emp-aff-title-row">
                                                <h4 class="emp-aff-name">@aff.Designation</h4>
                                                <span class="emp-etat-badge @(isCourante ? "courante" : "terminee")">
                                                    <span class="emp-etat-dot"></span>
                                                    @aff.Etat
                                                </span>
                                            </div>
                                            <p class="emp-aff-ref">@aff.Reference · @aff.Categorie</p>
                                            <div class="emp-aff-dates">
                                                <span>
                                                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                                                    Affecté le @aff.DateAffectation.ToString("dd/MM/yyyy")
                                                </span>
                                                @if (aff.DateRetourPrevue.HasValue)
                                                {
                                                    <span class="@(aff.DateRetourPrevue < DateTime.Now && isCourante ? "overdue" : "")">
                                                        <svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                                                        Retour prévu @aff.DateRetourPrevue.Value.ToString("dd/MM/yyyy")
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    @* Articles *@
                                    @if (aff.Articles.Any())
                                    {
                                        <div class="emp-aff-articles">
                                            @foreach (var art in aff.Articles)
                                            {
                                                <span class="emp-art-pill @(art.Etat == "Panne" ? "panne" : "bon")">
                                                    @art.NumeroSerie
                                                </span>
                                            }
                                        </div>
                                    }

                                    @* Observations *@
                                    @if (!string.IsNullOrEmpty(aff.Observations))
                                    {
                                        <p class="emp-aff-obs">💬 @aff.Observations</p>
                                    }

                                    @* Bouton retirer *@
                                    @if (isCourante)
                                    {
                                        <div class="emp-aff-footer">
                                            <button class="emp-btn-retirer"
                                                    disabled="@IsRetiring"
                                                    @onclick="() => DemanderConfirmation(aff)">
                                                <svg viewBox="0 0 24 24"><path d="M3 6h18M19 6l-1 14H6L5 6M10 11v6M14 11v6M9 6V4h6v2"/></svg>
                                                Retirer l'affectation
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>

        </div>
    </main>
</div>

@* ══ MODAL CONFIRMATION ══ *@
@if (AffectationARetirer != null)
{
    <div class="emp-modal-backdrop" @onclick="AnnulerConfirmation">
        <div class="emp-modal" @onclick:stopPropagation="true">
            <div class="emp-modal-icon">
                <svg viewBox="0 0 24 24"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3ZM12 9v4M12 17h.01"/></svg>
            </div>
            <h3 class="emp-modal-title">Retirer l'affectation ?</h3>
            <p class="emp-modal-body">
                Vous allez retirer <strong>@AffectationARetirer.Designation</strong>
                de <strong>@EmployeSelectionne?.FullName</strong>.<br/>
                Les @AffectationARetirer.Articles.Count article(s) seront remis en stock.
            </p>
            <div class="emp-modal-actions">
                <button class="emp-modal-cancel" @onclick="AnnulerConfirmation">Annuler</button>
                <button class="emp-modal-confirm" disabled="@IsRetiring" @onclick="ConfirmerRetrait">
                    @if (IsRetiring)
                    { <div class="emp-btn-spinner"></div> <span>Traitement...</span> }
                    else
                    { <span>Confirmer le retrait</span> }
                </button>
            </div>
        </div>
    </div>
}
</RoleAuthGuard>