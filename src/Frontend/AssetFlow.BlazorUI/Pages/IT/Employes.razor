@page "/it/employes"
@using AssetFlow.BlazorUI.Services
@using AssetFlow.BlazorUI.Components
@using AssetFlow.BlazorUI.DTOs

<RoleAuthGuard AllowedRoles="@(new[]{"IT","Admin"})">
<div class="emp-layout">

    @* ══════ SIDEBAR ══════ *@
    @if (_estAdmin)
        {
            <AdminSidebar ForceOpen="_menuOpen" />
        }
        else
        {
            <ITSidebar ActivePage="employes" ForceOpen="_menuOpen" />
        }

    @* ══════ MAIN ══════ *@
    <main class="emp-main">

        <header class="emp-header">
            <button class="emp-hamburger" @onclick="() => _menuOpen = !_menuOpen" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
            <div>
                <h1 class="emp-page-title">Gestion des Affectations</h1>
                <p class="emp-page-sub">Consultez et révoquez les affectations par employé ou par projet</p>
            </div>

            @* ── Toggle Employés / Projets ── *@
            <div class="emp-tab-toggle">
                <button class="emp-tab-btn @(!ModeProjet ? "active" : "")" @onclick='() => SetMode(false)'>
                    <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Employés
                </button>
                <button class="emp-tab-btn @(ModeProjet ? "active" : "")" @onclick='() => SetMode(true)'>
                    <svg viewBox="0 0 24 24"><path d="M2 7a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7z"/><path d="M16 3v4M8 3v4M2 11h20"/></svg>
                    Projets
                </button>
            </div>

            @if (!ModeProjet)
            {
                <div class="emp-header-search">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input type="text" placeholder="Rechercher un employé..." value="@Search" @oninput="OnSearchInput" />
                </div>
            }
            else
            {
                <div class="emp-header-search">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input type="text" placeholder="Rechercher un projet..." value="@ProjetSearch" @oninput="OnProjetSearchInput" />
                </div>
            }

            @* ── Cloche de Notifications ── *@
            <div class="notif-bell-wrapper" @onclick:stopPropagation="true">
                <button class="notif-bell-btn @(_notifOpen ? "active" : "")"
                        @onclick="ToggleNotifications"
                        aria-label="Notifications">
                    <svg viewBox="0 0 24 24" class="notif-bell-icon">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                    </svg>
                    @if (_nbNonLues > 0)
                    {
                        <span class="notif-badge @(_nbNonLues > 9 ? "large" : "")">
                            @(_nbNonLues > 99 ? "99+" : _nbNonLues.ToString())
                        </span>
                    }
                </button>

                @* ── Panneau Notifications ── *@
                @if (_notifOpen)
                {
                    <div class="notif-panel">
                        <div class="notif-panel-header">
                            <div class="notif-panel-title-row">
                                <span class="notif-panel-title">Notifications</span>
                                @if (_nbNonLues > 0)
                                {
                                    <span class="notif-count-badge">@_nbNonLues non lue(s)</span>
                                }
                            </div>
                            @if (_notifications.Any(n => !n.EstLue))
                            {
                                <button class="notif-tout-lire-btn" @onclick="MarquerToutesLues">
                                    <svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/><path d="m27 6-11 11" opacity="0"/></svg>
                                    Tout marquer lu
                                </button>
                            }
                        </div>

                        @if (_loadingNotifs)
                        {
                            <div class="notif-loading">
                                <div class="notif-spinner"></div>
                                <span>Chargement...</span>
                            </div>
                        }
                        else if (!_notifications.Any())
                        {
                            <div class="notif-empty">
                                <div class="notif-empty-icon">
                                    <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                                </div>
                                <p>Aucune notification</p>
                                <span>Tout est à jour ✓</span>
                            </div>
                        }
                        else
                        {
                            <div class="notif-list">
                                @foreach (var notif in _notifications)
                                {
                                    <div class="notif-item @(!notif.EstLue ? "unread" : "") @GetNiveauClass(notif.Niveau)"
                                         @onclick="() => MarquerLue(notif)">
                                        <div class="notif-item-icon-wrap @GetNiveauClass(notif.Niveau)">
                                            @if (notif.EstCritique)
                                            {
                                                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                                            }
                                            else if (notif.EstPreventif)
                                            {
                                                <svg viewBox="0 0 24 24"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3ZM12 9v4M12 17h.01"/></svg>
                                            }
                                            else
                                            {
                                                <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                                            }
                                        </div>
                                        <div class="notif-item-body">
                                            <p class="notif-item-titre">@notif.Titre</p>
                                            <p class="notif-item-msg">@notif.Message</p>
                                            <div class="notif-item-meta">
                                                <span class="notif-item-time">@notif.TempsRelatif</span>
                                                @if (notif.JoursRetard.HasValue && notif.JoursRetard > 0)
                                                {
                                                    <span class="notif-retard-pill">@notif.JoursRetard j de retard</span>
                                                }
                                            </div>
                                        </div>
                                        @if (!notif.EstLue)
                                        {
                                            <div class="notif-unread-dot"></div>
                                        }
                                    </div>
                                }
                            </div>
                        }

                        <div class="notif-panel-footer">
                            <span class="notif-footer-info">
                                Affectations expirées surveillées en temps réel
                            </span>
                        </div>
                    </div>

                    @* Overlay transparent pour fermer le panneau *@
                    <div class="notif-overlay" @onclick="() => _notifOpen = false"></div>
                }
            </div>
        </header>

        @* Alertes *@
        @if (!string.IsNullOrEmpty(SuccessMsg))
        {
            <div class="emp-alert emp-alert-success">
                <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                @SuccessMsg
            </div>
        }
        @if (!string.IsNullOrEmpty(ErrorMsg))
        {
            <div class="emp-alert emp-alert-error">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
                @ErrorMsg
            </div>
        }

        <div class="emp-body">

            @* ════ COLONNE GAUCHE ════ *@
            <div class="emp-col-left">

                @if (!ModeProjet)
                {
                    @* ── Liste Employés ── *@
                    <div class="emp-col-header">
                        <span class="emp-col-title">Employés</span>
                        <span class="emp-badge">@Employees.Count</span>
                    </div>
                    <div class="emp-role-filter">
                        <button class="emp-role-btn @(FiltreRoleEmp == "tous"        ? "active" : "")" @onclick='() => FiltreRoleEmp = "tous"'>Tous</button>
                        <button class="emp-role-btn @(FiltreRoleEmp == "Employe"     ? "active" : "")" @onclick='() => FiltreRoleEmp = "Employe"'>Employés</button>
                        <button class="emp-role-btn @(FiltreRoleEmp == "EquipeAchat" ? "active" : "")" @onclick='() => FiltreRoleEmp = "EquipeAchat"'>Achats</button>
                        <button class="emp-role-btn @(FiltreRoleEmp == "IT"          ? "active" : "")" @onclick='() => FiltreRoleEmp = "IT"'>IT</button>
                        <button class="emp-role-btn @(FiltreRoleEmp == "Admin"          ? "active" : "")" @onclick='() => FiltreRoleEmp = "Admin"'>Admin</button>
                    </div>
                    @if (LoadingEmployes)
                    {
                        <div class="emp-loading"><div class="emp-spinner"></div><span>Chargement...</span></div>
                    }
                    else if (!Employees.Any())
                    {
                        <div class="emp-empty">
                            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                            <p>Aucun employé trouvé</p>
                        </div>
                    }
                    else
                    {
                        <div class="emp-list">
                            @foreach (var emp in Employees)
                            {
                                var isSelected = EmployeSelectionne?.Id == emp.Id;
                                <div class="emp-card @(isSelected ? "selected" : "")" @onclick="() => SelectEmploye(emp)">
                                    <div class="emp-card-avatar @(isSelected ? "sel" : "")">@emp.Initials</div>
                                    <div class="emp-card-info">
                                        <p class="emp-card-name">@emp.FullName</p>
                                        <p class="emp-card-dept">@emp.Role</p>
                                        <p class="emp-card-email">@emp.Email</p>
                                    </div>
                                    <div class="emp-card-right">
                                        @if (emp.NbAffectationsActives > 0)
                                        { <span class="emp-card-count">@emp.NbAffectationsActives actif(s)</span> }
                                        else
                                        { <span class="emp-card-none">Aucun</span> }
                                        <svg class="emp-card-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    @* ── Liste Projets ── (inchangé) *@
                    <div class="emp-col-header">
                        <span class="emp-col-title">Projets</span>
                        <span class="emp-badge">@Projets.Count</span>
                    </div>
                    @if (LoadingProjets)
                    {
                        <div class="emp-loading"><div class="emp-spinner"></div><span>Chargement...</span></div>
                    }
                    else if (!Projets.Any())
                    {
                        <div class="emp-empty">
                            <svg viewBox="0 0 24 24"><path d="M2 7a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7z"/><path d="M16 3v4M8 3v4M2 11h20"/></svg>
                            <p>Aucun projet trouvé</p>
                        </div>
                    }
                    else
                    {
                        <div class="emp-list">
                            @foreach (var proj in Projets)
                            {
                                var isSel = ProjetSelectionne?.Id == proj.Id;
                                <div class="emp-card @(isSel ? "selected" : "")" @onclick="() => SelectProjet(proj)">
                                    <div class="emp-projet-icon @(isSel ? "sel" : "")">
                                        <svg viewBox="0 0 24 24"><path d="M2 7a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7z"/><path d="M16 3v4M8 3v4M2 11h20"/></svg>
                                    </div>
                                    <div class="emp-card-info">
                                        <p class="emp-card-name">@proj.Nom</p>
                                        <div class="emp-proj-meta">
                                            <span class="emp-proj-badge @GetStatutClass(proj.Statut)">@proj.Statut</span>
                                            <span class="emp-proj-badge @GetPrioriteClass(proj.Priorite)">@proj.Priorite</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(proj.Responsable))
                                        { <p class="emp-card-email">@proj.Responsable</p> }
                                    </div>
                                    <div class="emp-card-right">
                                        @if (proj.NbAffectationsActives > 0)
                                        { <span class="emp-card-count">@proj.NbAffectationsActives actif(s)</span> }
                                        else
                                        { <span class="emp-card-none">Aucun</span> }
                                        <svg class="emp-card-arrow" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>

            @* ════ COLONNE DROITE ════ *@
            <div class="emp-col-right">
                @if ((!ModeProjet && EmployeSelectionne == null) || (ModeProjet && ProjetSelectionne == null))
                {
                    <div class="emp-placeholder">
                        <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        <p>Sélectionnez un @(ModeProjet ? "projet" : "employé")<br/>pour voir ses affectations</p>
                    </div>
                }
                else
                {
                    <div class="emp-detail-header">
                        @if (!ModeProjet)
                        {
                            <div class="emp-detail-avatar">@EmployeSelectionne!.Initials</div>
                            <div class="emp-detail-info">
                                <h2 class="emp-detail-name">@EmployeSelectionne.FullName</h2>
                                <p class="emp-detail-meta">@EmployeSelectionne.Role · @EmployeSelectionne.Email</p>
                            </div>
                        }
                        else
                        {
                            <div class="emp-detail-avatar emp-detail-avatar-proj">
                                <svg viewBox="0 0 24 24"><path d="M2 7a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7z"/><path d="M16 3v4M8 3v4M2 11h20"/></svg>
                            </div>
                            <div class="emp-detail-info">
                                <h2 class="emp-detail-name">@ProjetSelectionne!.Nom</h2>
                                <p class="emp-detail-meta">
                                    <span class="emp-proj-badge @GetStatutClass(ProjetSelectionne.Statut)">@ProjetSelectionne.Statut</span>
                                    &nbsp;·&nbsp;
                                    <span class="emp-proj-badge @GetPrioriteClass(ProjetSelectionne.Priorite)">@ProjetSelectionne.Priorite</span>
                                    @if (!string.IsNullOrEmpty(ProjetSelectionne.Responsable))
                                    { <span>&nbsp;· @ProjetSelectionne.Responsable</span> }
                                </p>
                            </div>
                        }
                        <span class="emp-detail-count">@NbActives affectation(s) active(s)</span>
                    </div>

                    <div class="emp-filter-tabs">
                        <button class="emp-filter-tab @(FiltreEtat == "tous"     ? "active" : "")" @onclick='() => FiltreEtat = "tous"'>Toutes (@AffectationsCourantes.Count)</button>
                        <button class="emp-filter-tab @(FiltreEtat == "Courante" ? "active" : "")" @onclick='() => FiltreEtat = "Courante"'>Courantes (@AffectationsCourantes.Count(a => a.Etat == "Courante"))</button>
                        <button class="emp-filter-tab @(FiltreEtat == "Terminee" ? "active" : "")" @onclick='() => FiltreEtat = "Terminee"'>Terminées (@AffectationsCourantes.Count(a => a.Etat == "Terminee"))</button>
                    </div>

                    @if (LoadingAffectations)
                    {
                        <div class="emp-loading"><div class="emp-spinner"></div><span>Chargement des affectations...</span></div>
                    }
                    else if (!AffectationsFiltrees.Any())
                    {
                        <div class="emp-empty">
                            <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                            <p>Aucune affectation @(FiltreEtat != "tous" ? FiltreEtat.ToLower() : "")</p>
                        </div>
                    }
                    else
                    {
                        <div class="emp-aff-list">
                            @foreach (var aff in AffectationsFiltrees)
                            {
                                var isCourante = aff.Etat == "Courante";
                                <div class="emp-aff-card @(isCourante ? "" : "terminee")">
                                    <div class="emp-aff-top">
                                        <div class="emp-aff-img">
                                            @if (!string.IsNullOrEmpty(aff.ImageUrl))
                                            { <img src="@aff.ImageUrl" alt="@aff.Designation" /> }
                                            else
                                            { <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg> }
                                        </div>
                                        <div class="emp-aff-info">
                                            <div class="emp-aff-title-row">
                                                <h4 class="emp-aff-name">@aff.Designation</h4>
                                                <span class="emp-etat-badge @(isCourante ? "courante" : "terminee")">
                                                    <span class="emp-etat-dot"></span>@aff.Etat
                                                </span>
                                            </div>
                                            <p class="emp-aff-ref">@aff.Reference · @aff.Categorie</p>
                                            <div class="emp-aff-dates">
                                                <span>
                                                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                                                    Affecté le @aff.DateAffectation.ToString("dd/MM/yyyy")
                                                </span>
                                                @if (aff.DateRetourPrevue.HasValue)
                                                {
                                                    <span class="@(aff.DateRetourPrevue < DateTime.Now && isCourante ? "overdue" : "")">
                                                        <svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                                                        Retour prévu @aff.DateRetourPrevue.Value.ToString("dd/MM/yyyy")
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    @if (aff.Articles.Any())
                                    {
                                        <div class="emp-aff-articles">
                                            @foreach (var art in aff.Articles)
                                            { <span class="emp-art-pill @(art.Etat == "Panne" ? "panne" : "bon")">@art.NumeroSerie</span> }
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(aff.Observations))
                                    { <p class="emp-aff-obs">💬 @aff.Observations</p> }
                                    @if (isCourante)
                                    {
                                        <div class="emp-aff-footer">
                                            <button class="emp-btn-retirer" disabled="@IsRetiring" @onclick="() => DemanderConfirmation(aff)">
                                                <svg viewBox="0 0 24 24"><path d="M3 6h18M19 6l-1 14H6L5 6M10 11v6M14 11v6M9 6V4h6v2"/></svg>
                                                Retirer l'affectation
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>

        </div>
    </main>
</div>

@* ══ MODAL CONFIRMATION ══ *@
@if (AffectationARetirer != null)
 {
    <div class="emp-modal-backdrop" @onclick="AnnulerConfirmation">
        <div class="emp-modal" @onclick:stopPropagation="true">
            <div class="emp-modal-icon">
                <svg viewBox="0 0 24 24"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3ZM12 9v4M12 17h.01"/></svg>
            </div>
            <h3 class="emp-modal-title">Retirer l'affectation ?</h3>
            <p class="emp-modal-body">
                Vous allez retirer <strong>@AffectationARetirer.Designation</strong>
                de <strong>@(ModeProjet ? ProjetSelectionne?.Nom : EmployeSelectionne?.FullName)</strong>.<br/>
                Les @AffectationARetirer.Articles.Count article(s) seront remis en stock.
            </p>
            <div class="emp-modal-actions">
                <button class="emp-modal-cancel"  @onclick="AnnulerConfirmation">Annuler</button>
                <button class="emp-modal-confirm" disabled="@IsRetiring" @onclick="ConfirmerRetrait">
                    @if (IsRetiring) { <div class="emp-btn-spinner"></div><span>Traitement...</span> }
                    else             { <span>Confirmer le retrait</span> }
                </button>
            </div>
        </div>
    </div>
}
</RoleAuthGuard>
