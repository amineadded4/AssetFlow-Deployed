@page "/it/demandes-IT"
@using AssetFlow.BlazorUI.Services
@using AssetFlow.BlazorUI.Components

<RoleAuthGuard AllowedRoles="@(new[]{"IT","Admin"})">
<div class="mda-layout">

    @* ══════ SIDEBAR ══════ *@
    @if (_estAdmin)
        {
            <AdminSidebar ForceOpen="_menuOpen" />
        }
        else
        {
            <ITSidebar ActivePage="achats" ForceOpen="_menuOpen" />
        }

    @* ── DRAWER MOBILE ── *@
    @if (_menuOpen)
    { <div  @onclick="() => _menuOpen = !_menuOpen"></div> } 

    <div class="mda-body-wrap">
        <main class="mda-main">

            <header class="mda-header">
                <div class="mda-header-top-row">
                    <button class="mda-hamburger" @onclick="() => _menuOpen = !_menuOpen" aria-label="Menu">
                        <span></span><span></span><span></span>
                    </button>
                    <div class="mda-header-left">
                        <h1 class="mda-page-title">Mes demandes d'achat</h1>
                        <p class="mda-page-sub">Consultez l'état de vos demandes et accédez aux offres fournisseurs</p>
                    </div>
                    <button class="mda-btn-new mda-btn-new-desktop" @onclick="OpenCreatePanel">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        <span class="mda-btn-new-label">Nouvelle demande</span>
                    </button>
                </div>
            </header>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="mda-alert mda-alert-error">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
                    @ErrorMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <div class="mda-alert mda-alert-success">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                    @SuccessMessage
                </div>
            }

            <div class="mda-stats-bar">
                <button class="mda-stat-pill mda-stat-all @(FilterStatut==null?"active":"")"                        @onclick="()=>SetFilter(null)">
                    <span class="mda-stat-num">@Demandes.Count</span><span class="mda-stat-lbl">Toutes</span>
                </button>
                <button class="mda-stat-pill mda-stat-attente @(FilterStatut=="en_attente"?"active":"")"             @onclick='()=>SetFilter("en_attente")'>
                    <span class="mda-stat-num">@Demandes.Count(d=>d.Statut=="en_attente")</span><span class="mda-stat-lbl">En attente</span>
                </button>
                <button class="mda-stat-pill mda-stat-encours @(FilterStatut=="en_cours_traitement"?"active":"")"   @onclick='()=>SetFilter("en_cours_traitement")'>
                    <span class="mda-stat-num">@Demandes.Count(d=>d.Statut=="en_cours_traitement")</span><span class="mda-stat-lbl">En cours</span>
                </button>
                <button class="mda-stat-pill mda-stat-traite @(FilterStatut=="traite"?"active":"")"                  @onclick='()=>SetFilter("traite")'>
                    <span class="mda-stat-num">@Demandes.Count(d=>d.Statut=="traite")</span><span class="mda-stat-lbl">Traité</span>
                </button>
                <button class="mda-stat-pill mda-stat-refuse @(FilterStatut=="refuse"?"active":"")"                  @onclick='()=>SetFilter("refuse")'>
                    <span class="mda-stat-num">@Demandes.Count(d=>d.Statut=="refuse")</span><span class="mda-stat-lbl">Refusé</span>
                </button>
            </div>

            <div class="mda-toolbar">
                <div class="mda-search-wrap">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input type="text" class="mda-search-input" placeholder="Rechercher par référence, produit..."
                           value="@SearchQuery" @oninput="OnSearchInput" />
                    @if (!string.IsNullOrEmpty(SearchQuery))
                    {
                        <button class="mda-search-clear" @onclick="ClearSearch">
                            <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    }
                </div>
                <div class="mda-sort-wrap">
                    <svg viewBox="0 0 24 24"><path d="M3 6h18M7 12h10M11 18h2"/></svg>
                    <select class="mda-sort-select" @onchange="OnSortChange">
                        <option value="date_desc">Plus récent</option>
                        <option value="date_asc">Plus ancien</option>
                        <option value="produit_asc">Produit A→Z</option>
                        <option value="quantite_desc">Quantité ↓</option>
                    </select>
                    <button class="mda-btn-new add" @onclick="OpenCreatePanel">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Nouvelle demande
                    </button>
                </div>
            </div>

            <div class="mda-content">
                @if (IsLoading)
                {
                    <div class="mda-loading-state"><div class="mda-big-spinner"></div><p>Chargement des demandes...</p></div>
                }
                else if (!DemandesFiltrees.Any())
                {
                    <div class="mda-empty-state">
                        <div class="mda-empty-icon"><svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></div>
                        <h3>Aucune demande trouvée</h3>
                        <p>@(string.IsNullOrEmpty(SearchQuery) && FilterStatut==null ? "Vous n'avez pas encore soumis de demande d'achat." : "Aucune demande ne correspond à vos critères.")</p>
                        @if (string.IsNullOrEmpty(SearchQuery) && FilterStatut==null)
                        {
                            <button class="mda-btn-new mda-btn-new-sm" @onclick="OpenCreatePanel">
                                <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                Créer ma première demande
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="mda-table">
                        <div class="mda-table-head">
                            <div class="mda-th mda-th-produit">Demande</div>
                            <div class="mda-th mda-th-qty">Matériels</div>
                            <div class="mda-th mda-th-date">Date</div>
                            <div class="mda-th mda-th-statut">Statut</div>
                            <div class="mda-th mda-th-actions">Actions</div>
                        </div>

                        <div class="mda-table-body">
                            @foreach (var demande in PagedDemandes)
                            {
                                bool isExpanded   = SelectedDemandeId == demande.IdDemande;
                                @* ── L'IT peut modifier/supprimer UNIQUEMENT si en_attente ── *@
                                bool peutModifier = demande.Statut == "en_attente";

                                <div class="mda-row @(isExpanded ? "expanded" : "")">
                                    <div class="mda-row-main">
                                        <div class="mda-td mda-td-produit">
                                            <div class="mda-produit-info">
                                                <span class="mda-produit-name">@demande.NomProduit</span>
                                                @if (!string.IsNullOrEmpty(demande.Description))
                                                { <span class="mda-produit-desc">@demande.Description</span> }
                                            </div>
                                        </div>
                                        <div class="mda-td mda-td-qty">
                                            <span class="mda-qty-badge">@demande.Lignes.Count</span>
                                        </div>
                                        <div class="mda-td mda-td-date">
                                            <span class="mda-date-val">@demande.DateCreation.ToLocalTime().ToString("dd MMMM yyyy à HH:mm")</span>
                                            <span class="mda-date-rel">@GetRelativeDate(demande.DateCreation)</span>
                                        </div>
                                        <div class="mda-td mda-td-statut">
                                            <span class="mda-statut-badge mda-statut-@demande.Statut.ToLower().Replace("_","-")">
                                                @GetStatutLabel(demande.Statut)
                                            </span>
                                        </div>
                                        <div class="mda-td mda-td-actions" @onclick:stopPropagation="true">

                                            @* ── Offres — toujours visible ── *@
                                            <button class="mda-btn-offres" @onclick="() => NavigateToOffres(demande.IdDemande)">
                                                <svg viewBox="0 0 24 24"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                                                Offres
                                            </button>

                                            @* ── Modifier ── *@
                                            @if (peutModifier)
                                            {
                                                <button class="mda-btn-edit"
                                                        @onclick="() => OpenEditPanel(demande)"
                                                        title="Modifier la demande">
                                                    <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="mda-btn-edit mda-btn-disabled" disabled
                                                        title="Modification impossible — demande prise en charge par l'agent achat">
                                                    <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                </button>
                                            }

                                            @* ── Supprimer ── *@
                                            @if (peutModifier)
                                            {
                                                <button class="mda-btn-delete"
                                                        @onclick="() => OuvrirConfirmSuppression(demande)"
                                                        title="Supprimer la demande">
                                                    <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="mda-btn-delete mda-btn-disabled" disabled
                                                        title="Suppression impossible — demande prise en charge par l'agent achat">
                                                    <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                                </button>
                                            }

                                            <button class="mda-btn-details" @onclick="() => ToggleExpand(demande.IdDemande)">
                                                <svg viewBox="0 0 24 24" class="mda-chevron @(isExpanded?"rotated":"")"><path d="m6 9 6 6 6-6"/></svg>
                                                Détails
                                            </button>
                                        </div>
                                    </div>

                                    @if (isExpanded)
                                    {
                                        <div class="mda-row-detail">
                                            <div class="mda-detail-grid">
                                                <div class="mda-detail-block">
                                                    <p class="mda-detail-label">Référence demande</p>
                                                    <p class="mda-detail-val mda-mono">@demande.Reference</p>
                                                </div>
                                                <div class="mda-detail-block">
                                                    <p class="mda-detail-label">Statut</p>
                                                    <span class="mda-statut-badge mda-statut-@demande.Statut.ToLower().Replace("_","-")">@GetStatutLabel(demande.Statut)</span>
                                                </div>
                                                <div class="mda-detail-block">
                                                    <p class="mda-detail-label">Date de création</p>
                                                    <p class="mda-detail-val">@demande.DateCreation.ToLocalTime().ToString("dd MMMM yyyy à HH:mm")</p>
                                                </div>
                                                @if (!string.IsNullOrEmpty(demande.Description))
                                                {
                                                    <div class="mda-detail-block mda-detail-full">
                                                        <p class="mda-detail-label">Description</p>
                                                        <p class="mda-detail-val mda-detail-desc">@demande.Description</p>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(demande.MotifRefus))
                                                {
                                                    <div class="mda-detail-block mda-detail-full mda-detail-refus">
                                                        <p class="mda-detail-label">Motif de refus</p>
                                                        <p class="mda-detail-val">@demande.MotifRefus</p>
                                                    </div>
                                                }
                                            </div>

                                            @if (demande.Lignes.Any())
                                            {
                                                <div class="mda-lignes-section">
                                                    <p class="mda-lignes-title">
                                                        <svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                                                        Matériels demandés (@demande.Lignes.Count)
                                                    </p>
                                                    <div class="mda-lignes-table">
                                                        <div class="mda-lignes-head"><span>#</span><span>Référence</span><span>Produit</span><span>Qté</span><span>Description</span></div>
                                                        @foreach (var (ligne, idx) in demande.Lignes.Select((l,i)=>(l,i)))
                                                        {
                                                            <div class="mda-ligne-row">
                                                                <span class="mda-ligne-num">@(idx+1)</span>
                                                                <span class="mda-ligne-ref">@(string.IsNullOrEmpty(ligne.Reference) ? "—" : ligne.Reference)</span>
                                                                <span class="mda-ligne-nom">@ligne.NomProduit</span>
                                                                <span class="mda-ligne-qty">@ligne.Quantite</span>
                                                                <span class="mda-ligne-desc">@(ligne.Description ?? "—")</span>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }

                                            <div class="mda-detail-actions">
                                                <button class="mda-btn-offres mda-btn-offres-lg" @onclick="() => NavigateToOffres(demande.IdDemande)">
                                                    <svg viewBox="0 0 24 24"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                                                    Voir les offres fournisseurs
                                                </button>
                                            </div>

                                            @* ── Bannière verrouillage — visible si statut != en_attente ── *@
                                            @if (!peutModifier)
                                            {
                                                <div class="mda-locked-banner">
                                                    <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                                    <div>
                                                        <strong>Demande verrouillée</strong>
                                                        <p>
                                                            Cette demande est à l'état <em>@GetStatutLabel(demande.Statut)</em>.
                                                            L'agent achat l'a prise en charge — modification et suppression désactivées.
                                                        </p>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mda-pagination">
                        <span class="mda-pag-info">
                            Affichage de @Math.Min((CurrentPage-1)*PageSize+1, DemandesFiltrees.Count)
                            à @Math.Min(CurrentPage*PageSize, DemandesFiltrees.Count)
                            sur @DemandesFiltrees.Count demande(s)
                        </span>
                    </div>
                }
            </div>

        </main>

        @* ══════ OVERLAY ══════ *@
        @if (_showCreatePanel || _showEditPanel)
        { <div class="mda-panel-overlay" @onclick="() => { CloseCreatePanel(); CloseEditPanel(); }"></div> }

        @* ══════ PANNEAU CRÉATION ══════ *@
        <div class="mda-create-panel @(_showCreatePanel ? "open" : "")" @onclick:stopPropagation="true">
            <div class="mda-create-panel-header">
                <div>
                    <h2 class="mda-create-title">Nouvelle demande d'achat</h2>
                    <p class="mda-create-sub">Ajoutez un ou plusieurs matériels</p>
                </div>
            </div>
            <div class="mda-create-body">
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="mda-form-error-banner">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        @_formError
                    </div>
                }
                <div class="mda-field">
                    <label class="mda-field-label">Titre de la demande <span class="mda-required">*</span></label>
                    <input type="text" class="mda-field-input" placeholder="Ex: Équipements pour la salle de réunion B" @bind="_form.NomDemande" />
                </div>
                <div class="mda-field">
                    <label class="mda-field-label">Justification globale <span class="mda-optional">(facultatif)</span></label>
                    <textarea class="mda-field-input mda-field-textarea" rows="2" placeholder="Contexte général de la demande…" @bind="_form.Description"></textarea>
                </div>
                <div class="mda-lignes-header">
                    <p class="mda-lignes-label"><svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>Matériels demandés</p>
                    <button class="mda-btn-add-ligne" @onclick="AjouterLigne"><svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Ajouter</button>
                </div>
                @foreach (var (ligne, idx) in _form.Lignes.Select((l,i)=>(l,i)))
                {
                    <div class="mda-ligne-form @(!string.IsNullOrEmpty(ligne.Erreur) ? "has-error" : "")">
                        <div class="mda-ligne-form-header">
                            <span class="mda-ligne-badge">Matériel @(idx+1)</span>
                            @if (_form.Lignes.Count > 1)
                            { <button class="mda-ligne-del" @onclick="() => SupprimerLigne(ligne)"><svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg></button> }
                        </div>
                        <div class="mda-ligne-row-inputs">
                            <div class="mda-field mda-field-product" style="flex:1">
                                <label class="mda-field-label">Produit <span class="mda-required">*</span></label>
                                <input type="text" class="mda-field-input @(!string.IsNullOrEmpty(ligne.Erreur) ? "input-error" : "")" placeholder="Ex: RAM DDR4 32GB" @bind="ligne.NomProduit" @bind:event="oninput" />
                            </div>
                            <div class="mda-field mda-field-qty">
                                <label class="mda-field-label">Qté <span class="mda-required">*</span></label>
                                <input type="number" min="1" class="mda-field-input" @bind="ligne.Quantite" />
                            </div>
                        </div>
                        <div class="mda-field">
                            <label class="mda-field-label">Référence <span class="mda-optional">(facultatif)</span></label>
                            <input type="text" class="mda-field-input" placeholder="Ex: CMD-2026-001" @bind="ligne.Reference" @bind:event="oninput" />
                        </div>
                        <div class="mda-field">
                            <label class="mda-field-label">Description <span class="mda-optional">(facultatif)</span></label>
                            <input type="text" class="mda-field-input" placeholder="Ex: Extension mémoire serveur SRV-DB-01" @bind="ligne.Description" @bind:event="oninput" />
                        </div>
                        @if (!string.IsNullOrEmpty(ligne.Erreur))
                        { <span class="mda-field-error">@ligne.Erreur</span> }
                    </div>
                }
                <button class="mda-btn-add-ligne-full" @onclick="AjouterLigne"><svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>+ Ajouter un autre matériel</button>
            </div>
            <div class="mda-create-footer">
                @if (_isSaving) { <button class="mda-btn-save" disabled><div class="mda-mini-spinner"></div>Envoi en cours...</button> }
                else            { <button class="mda-btn-save" @onclick="SubmitCreate"><svg viewBox="0 0 24 24"><path d="M5 12l5 5L20 7"/></svg>Soumettre la demande</button> }
                <button class="mda-btn-cancel" @onclick="CloseCreatePanel">Annuler</button>
            </div>
        </div>

        @* ══════ PANNEAU ÉDITION ══════ *@
        <div class="mda-create-panel @(_showEditPanel ? "open" : "")" @onclick:stopPropagation="true">
            <div class="mda-create-panel-header">
                <div>
                    <h2 class="mda-create-title">Modifier la demande</h2>
                    <p class="mda-create-sub">Modifiez le titre, la description ou les matériels</p>
                </div>
            </div>
            <div class="mda-create-body">
                @if (!string.IsNullOrEmpty(_editFormError))
                {
                    <div class="mda-form-error-banner">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        @_editFormError
                    </div>
                }
                <div class="mda-field">
                    <label class="mda-field-label">Titre de la demande <span class="mda-required">*</span></label>
                    <input type="text" class="mda-field-input" @bind="_editForm.NomDemande" />
                </div>
                <div class="mda-field">
                    <label class="mda-field-label">Justification globale <span class="mda-optional">(facultatif)</span></label>
                    <textarea class="mda-field-input mda-field-textarea" rows="2" @bind="_editForm.Description"></textarea>
                </div>
                <div class="mda-lignes-header">
                    <p class="mda-lignes-label"><svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>Matériels demandés</p>
                    <button class="mda-btn-add-ligne" @onclick="AjouterLigneEdit"><svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Ajouter</button>
                </div>
                @foreach (var (ligne, idx) in _editForm.Lignes.Select((l,i)=>(l,i)))
                {
                    <div class="mda-ligne-form @(!string.IsNullOrEmpty(ligne.Erreur) ? "has-error" : "")">
                        <div class="mda-ligne-form-header">
                            <span class="mda-ligne-badge">Matériel @(idx+1)</span>
                            @if (_editForm.Lignes.Count > 1)
                            { <button class="mda-ligne-del" @onclick="() => SupprimerLigneEdit(ligne)"><svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg></button> }
                        </div>
                        <div class="mda-ligne-row-inputs">
                            <div class="mda-field mda-field-product" style="flex:1">
                                <label class="mda-field-label">Produit <span class="mda-required">*</span></label>
                                <input type="text" class="mda-field-input @(!string.IsNullOrEmpty(ligne.Erreur) ? "input-error" : "")" @bind="ligne.NomProduit" @bind:event="oninput" />
                            </div>
                            <div class="mda-field mda-field-qty">
                                <label class="mda-field-label">Qté <span class="mda-required">*</span></label>
                                <input type="number" min="1" class="mda-field-input" @bind="ligne.Quantite" />
                            </div>
                        </div>
                        <div class="mda-field">
                            <label class="mda-field-label">Référence <span class="mda-optional">(facultatif)</span></label>
                            <input type="text" class="mda-field-input" @bind="ligne.Reference" @bind:event="oninput" />
                        </div>
                        <div class="mda-field">
                            <label class="mda-field-label">Description <span class="mda-optional">(facultatif)</span></label>
                            <input type="text" class="mda-field-input" @bind="ligne.Description" @bind:event="oninput" />
                        </div>
                        @if (!string.IsNullOrEmpty(ligne.Erreur))
                        { <span class="mda-field-error">@ligne.Erreur</span> }
                    </div>
                }
                <button class="mda-btn-add-ligne-full" @onclick="AjouterLigneEdit"><svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>+ Ajouter un autre matériel</button>
            </div>
            <div class="mda-create-footer">
                @if (_isUpdating) { <button class="mda-btn-save" disabled><div class="mda-mini-spinner"></div>Sauvegarde...</button> }
                else              { <button class="mda-btn-save" @onclick="SubmitEdit"><svg viewBox="0 0 24 24"><path d="M5 12l5 5L20 7"/></svg>Enregistrer les modifications</button> }
                <button class="mda-btn-cancel" @onclick="CloseEditPanel">Annuler</button>
            </div>
        </div>

    </div>
</div>

@* ══════ MODAL CONFIRMATION SUPPRESSION ══════ *@
@if (_showDeleteModal && _demandeASupprimer != null)
{
    <div class="mda-modal-backdrop" @onclick="AnnulerSuppression">
        <div class="mda-modal" @onclick:stopPropagation="true">

            @* ── Icône destructive animée ── *@
            <div class="mda-modal-icon-wrap">
                <div class="mda-modal-icon-halo"></div>
                <div class="mda-modal-icon">
                    <svg viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                        <path d="M10 11v6M14 11v6"/>
                        <path d="M9 6V4h6v2"/>
                    </svg>
                </div>
            </div>

            @* ── Texte ── *@
            <div class="mda-modal-content">
                <h3 class="mda-modal-title">Supprimer la demande ?</h3>
                <p class="mda-modal-body">
                    Vous allez supprimer
                    <strong class="mda-modal-highlight">@_demandeASupprimer.NomProduit</strong>
                    <span class="mda-modal-ref">(@_demandeASupprimer.Reference)</span>.
                    <br/>Toutes les offres fournisseurs associées seront également supprimées.
                </p>
                <div class="mda-modal-warning">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                    Cette action est irréversible.
                </div>
            </div>

            @* ── Actions ── *@
            <div class="mda-modal-actions">
                <button class="mda-modal-cancel" @onclick="AnnulerSuppression">Annuler</button>
                <button class="mda-modal-confirm" disabled="@_isDeleting" @onclick="ConfirmerSuppression">
                    @if (_isDeleting)
                    {
                        <div class="mda-mini-spinner"></div>
                        <span>Suppression...</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:15px;height:15px">
                            <polyline points="3 6 5 6 21 6"/>
                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                        </svg>
                        <span>Confirmer la suppression</span>
                    }
                </button>
            </div>

        </div>
    </div>
}
</RoleAuthGuard>
