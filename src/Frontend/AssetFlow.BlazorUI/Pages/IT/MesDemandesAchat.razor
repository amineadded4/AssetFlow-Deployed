@* ============================================================
   AssetFlow.BlazorUI / Pages / IT / MesDemandesAchat.razor
   MODIF : Référence par ligne de matériel (supprimée du niveau global)
   ============================================================ *@

@page "/it/demandes-achat"
@using AssetFlow.BlazorUI.Services
@using AssetFlow.BlazorUI.Components

<RoleAuthGuard AllowedRoles="@(new[]{"IT","Admin"})">
<div class="mda-layout">

    @* ══════ SIDEBAR ══════ *@
    <aside class="mda-sidebar">
        <div class="sidebar-logo-wrap">
            <img src="images/logo.png" alt="AssetFlow" class="mda-sidebar-logo" />
        </div>
        <nav class="mda-sidebar-nav">
            <a href="/dashboard/it" class="mda-nav-link">
                <svg class="mda-nav-icon" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="7" height="7" rx="1"/>
                    <rect x="14" y="3" width="7" height="7" rx="1"/>
                    <rect x="3" y="14" width="7" height="7" rx="1"/>
                    <rect x="14" y="14" width="7" height="7" rx="1"/>
                </svg>
                <span class="mda-nav-text">Dashboard</span>
            </a>
            <a href="/employe/equipements" class="mda-nav-link">
                    <svg class="mda-nav-icon" viewBox="0 0 24 24">
                        <rect x="2" y="3" width="20" height="14" rx="2" />
                        <path d="M8 21h8M12 17v4" />
                    </svg>
                    <span class="mda-nav-text">Mes Équipements</span>
            </a>
            <a href="/it/employes" class="mda-nav-link">
                <svg class="mda-nav-icon" viewBox="0 0 24 24">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <span class="mda-nav-text">Gestion d'affectations</span>
            </a>
            <a href="/it/affectation" class="mda-nav-link">
                <svg class="mda-nav-icon" viewBox="0 0 24 24">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/>
                </svg>
                <span class="mda-nav-text">Affectations</span>
            </a>
            <a href="/it/incidents" class="mda-nav-link">
                <svg class="mda-nav-icon" viewBox="0 0 24 24">
                    <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3ZM12 9v4M12 17h.01"/>
                </svg>
                <span class="mda-nav-text">Incidents</span>
            </a>
            <a href="/it/inventaire" class="mda-nav-link">
                <svg class="mda-nav-icon" viewBox="0 0 24 24">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <path d="M3.27 6.96 12 12.01l8.73-5.05M12 22.08V12"/>
                </svg>
                <span class="mda-nav-text">Inventaire</span>
            </a>
            <a href="/it/demandes-achat" class="mda-nav-link active">
                <svg class="mda-nav-icon" viewBox="0 0 24 24">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
                <span class="mda-nav-text">Mes achats</span>
            </a>
            <a href="/it/messagerie"  class="mda-nav-link"><svg class="mda-nav-icon" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg><span>Messagerie</span></a>

        </nav>
        <div class="mda-sidebar-profile">
            <div class="mda-profile-avatar">@GetInitials()</div>
            <div class="mda-profile-info">
                <p class="mda-profile-name">@UserName</p>
                <p class="mda-profile-role">IT</p>
            </div>
        </div>
        <LogoutButton />
    </aside>

    @* ── DRAWER MOBILE ── *@
    @if (_menuOpen)
    {
        <div class="mda-menu-overlay" @onclick="() => _menuOpen = false">
            <div class="mda-menu-drawer" @onclick:stopPropagation="true">
                <div class="mda-menu-drawer-logo"><img src="images/logo.png" alt="AssetFlow" class="mda-sidebar-logo" /></div>
                <nav class="mda-menu-drawer-nav">
                    <a href="/dashboard/it"       class="mda-nav-link" @onclick="() => _menuOpen = false"><svg class="mda-nav-icon" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg><span class="mda-nav-text">Dashboard</span></a>
                       <a href="/employe/equipements" class="mda-nav-link">
                            <svg class="mda-nav-icon" viewBox="0 0 24 24">
                                <rect x="2" y="3" width="20" height="14" rx="2" />
                                <path d="M8 21h8M12 17v4" />
                            </svg>
                            <span class="mda-nav-text">Mes Équipements</span>
                    </a>
                    <a href="/it/employes" class="mda-nav-link">
                        <svg class="mda-nav-icon" viewBox="0 0 24 24">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                        <span class="mda-nav-text">Gestion d'affectations</span>
                    </a>
                    <a href="/it/affectation" class="mda-nav-link">
                        <svg class="mda-nav-icon" viewBox="0 0 24 24">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/>
                        </svg>
                        <span class="mda-nav-text">Affectations</span>
                    </a>
                    <a href="/it/incidents" class="mda-nav-link">
                        <svg class="mda-nav-icon" viewBox="0 0 24 24">
                            <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3ZM12 9v4M12 17h.01"/>
                        </svg>
                        <span class="mda-nav-text">Incidents</span>
                    </a>
                    <a href="/it/inventaire" class="mda-nav-link">
                        <svg class="mda-nav-icon" viewBox="0 0 24 24">
                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                            <path d="M3.27 6.96 12 12.01l8.73-5.05M12 22.08V12"/>
                        </svg>
                        <span class="mda-nav-text">Inventaire</span>
                    </a>
                    <a href="/it/demandes-achat" class="mda-nav-link active">
                        <svg class="mda-nav-icon" viewBox="0 0 24 24">
                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                            <line x1="3" y1="6" x2="21" y2="6"/>
                            <path d="M16 10a4 4 0 0 1-8 0"/>
                        </svg>
                        <span class="mda-nav-text">Mes achats</span>
                    </a>
                    <a href="/it/messagerie"  class="mda-nav-link"><svg class="mda-nav-icon" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg><span>Messagerie</span></a>
                </nav>
                <div class="mda-sidebar-profile">
                    <div class="mda-profile-avatar">@GetInitials()</div>
                    <div class="mda-profile-info"><p class="mda-profile-name">@UserName</p><p class="mda-profile-role">IT</p></div>
                </div>
                <LogoutButton />
            </div>
        </div>
    }

    <div class="mda-body-wrap">
        <main class="mda-main">

            <header class="mda-header">
                <button class="mda-hamburger" @onclick="() => _menuOpen = !_menuOpen"><span></span><span></span><span></span></button>
                <div class="mda-header-left">
                    <h1 class="mda-page-title">Mes demandes d'achat</h1>
                    <p class="mda-page-sub">Consultez l'état de vos demandes et accédez aux offres fournisseurs</p>
                </div>
                <button class="mda-btn-new" @onclick="OpenCreatePanel">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Nouvelle demande
                </button>
            </header>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="mda-alert mda-alert-error">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
                    @ErrorMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <div class="mda-alert mda-alert-success">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                    @SuccessMessage
                </div>
            }

            <div class="mda-stats-bar">
                <button class="mda-stat-pill mda-stat-all @(FilterStatut==null?"active":"")" @onclick="()=>SetFilter(null)"><span class="mda-stat-num">@Demandes.Count</span><span class="mda-stat-lbl">Toutes</span></button>
                <button class="mda-stat-pill mda-stat-attente @(FilterStatut=="en_attente"?"active":"")" @onclick='()=>SetFilter("en_attente")'><span class="mda-stat-num">@Demandes.Count(d=>d.Statut=="en_attente")</span><span class="mda-stat-lbl">En attente</span></button>
                <button class="mda-stat-pill mda-stat-traite @(FilterStatut=="traite"?"active":"")" @onclick='()=>SetFilter("traite")'><span class="mda-stat-num">@Demandes.Count(d=>d.Statut=="traite")</span><span class="mda-stat-lbl">Traité</span></button>
                <button class="mda-stat-pill mda-stat-approuve @(FilterStatut=="approuve"?"active":"")" @onclick='()=>SetFilter("approuve")'><span class="mda-stat-num">@Demandes.Count(d=>d.Statut=="approuve")</span><span class="mda-stat-lbl">Approuvé</span></button>
                <button class="mda-stat-pill mda-stat-refuse @(FilterStatut=="refuse"?"active":"")" @onclick='()=>SetFilter("refuse")'><span class="mda-stat-num">@Demandes.Count(d=>d.Statut=="refuse")</span><span class="mda-stat-lbl">Refusé</span></button>
            </div>

            <div class="mda-toolbar">
                <div class="mda-search-wrap">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input type="text" class="mda-search-input" placeholder="Rechercher par référence, produit..."
                           value="@SearchQuery" @oninput="OnSearchInput" />
                    @if (!string.IsNullOrEmpty(SearchQuery))
                    {
                        <button class="mda-search-clear" @onclick="ClearSearch">
                            <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    }
                </div>
                <div class="mda-sort-wrap">
                    <svg viewBox="0 0 24 24"><path d="M3 6h18M7 12h10M11 18h2"/></svg>
                    <select class="mda-sort-select" @onchange="OnSortChange">
                        <option value="date_desc">Plus récent</option>
                        <option value="date_asc">Plus ancien</option>
                        <option value="produit_asc">Produit A→Z</option>
                        <option value="quantite_desc">Quantité ↓</option>
                    </select>
                </div>
            </div>

            <div class="mda-content">
                @if (IsLoading)
                {
                    <div class="mda-loading-state"><div class="mda-big-spinner"></div><p>Chargement des demandes...</p></div>
                }
                else if (!DemandesFiltrees.Any())
                {
                    <div class="mda-empty-state">
                        <div class="mda-empty-icon"><svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></div>
                        <h3>Aucune demande trouvée</h3>
                        <p>@(string.IsNullOrEmpty(SearchQuery) && FilterStatut==null ? "Vous n'avez pas encore soumis de demande d'achat." : "Aucune demande ne correspond à vos critères.")</p>
                        @if (string.IsNullOrEmpty(SearchQuery) && FilterStatut==null)
                        {
                            <button class="mda-btn-new mda-btn-new-sm" @onclick="OpenCreatePanel">
                                <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                Créer ma première demande
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="mda-table">
                        <div class="mda-table-head">
                            <div class="mda-th mda-th-produit">Demande</div>
                            <div class="mda-th mda-th-qty">Matériels</div>
                            <div class="mda-th mda-th-date">Date</div>
                            <div class="mda-th mda-th-statut">Statut</div>
                            <div class="mda-th mda-th-actions">Actions</div>
                        </div>

                        <div class="mda-table-body">
                            @foreach (var demande in PagedDemandes)
                            {
                                bool isExpanded = SelectedDemandeId == demande.IdDemande;
                                <div class="mda-row @(isExpanded ? "expanded" : "")">
                                    <div class="mda-row-main">
                                        <div class="mda-td mda-td-produit">
                                            <div class="mda-produit-info">
                                                <span class="mda-produit-name">@demande.NomProduit</span>
                                                @if (!string.IsNullOrEmpty(demande.Description))
                                                { <span class="mda-produit-desc">@demande.Description</span> }
                                            </div>
                                        </div>
                                        <div class="mda-td mda-td-qty">
                                            <span class="mda-qty-badge" title="@demande.Lignes.Count ligne(s)">@demande.Lignes.Count</span>
                                        </div>
                                        <div class="mda-td mda-td-date">
                                            <span class="mda-date-val">@demande.DateCreation.ToString("dd MMM yyyy")</span>
                                            <span class="mda-date-rel">@GetRelativeDate(demande.DateCreation)</span>
                                        </div>
                                        <div class="mda-td mda-td-statut">
                                            <span class="mda-statut-badge mda-statut-@demande.Statut.ToLower().Replace("_","-")">@GetStatutLabel(demande.Statut)</span>
                                        </div>
                                        <div class="mda-td mda-td-actions" @onclick:stopPropagation="true">
                                            <button class="mda-btn-offres" @onclick="() => NavigateToOffres(demande.IdDemande)">
                                                <svg viewBox="0 0 24 24"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                                                Offres
                                            </button>
                                            <button class="mda-btn-details" @onclick="() => ToggleExpand(demande.IdDemande)" @onclick:stopPropagation="true">
                                                <svg viewBox="0 0 24 24" class="mda-chevron @(isExpanded?"rotated":"")"><path d="m6 9 6 6 6-6"/></svg>
                                                Détails
                                            </button>
                                        </div>
                                    </div>

                                    @if (isExpanded)
                                    {
                                        <div class="mda-row-detail">
                                            <div class="mda-detail-grid">
                                                <div class="mda-detail-block">
                                                    <p class="mda-detail-label">Référence demande</p>
                                                    <p class="mda-detail-val mda-mono">@demande.Reference</p>
                                                </div>
                                                <div class="mda-detail-block">
                                                    <p class="mda-detail-label">Statut</p>
                                                    <span class="mda-statut-badge mda-statut-@demande.Statut.ToLower().Replace("_","-")">@GetStatutLabel(demande.Statut)</span>
                                                </div>
                                                <div class="mda-detail-block">
                                                    <p class="mda-detail-label">Date de création</p>
                                                    <p class="mda-detail-val">@demande.DateCreation.ToString("dd MMMM yyyy à HH:mm")</p>
                                                </div>
                                                @if (!string.IsNullOrEmpty(demande.Description))
                                                {
                                                    <div class="mda-detail-block mda-detail-full">
                                                        <p class="mda-detail-label">Description</p>
                                                        <p class="mda-detail-val mda-detail-desc">@demande.Description</p>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(demande.MotifRefus))
                                                {
                                                    <div class="mda-detail-block mda-detail-full mda-detail-refus">
                                                        <p class="mda-detail-label">Motif de refus</p>
                                                        <p class="mda-detail-val">@demande.MotifRefus</p>
                                                    </div>
                                                }
                                            </div>

                                            @* ── Tableau matériels ── *@
                                            @if (demande.Lignes.Any())
                                            {
                                                <div class="mda-lignes-section">
                                                    <p class="mda-lignes-title">
                                                        <svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                                                        Matériels demandés (@demande.Lignes.Count)
                                                    </p>
                                                    <div class="mda-lignes-table">
                                                        <div class="mda-lignes-head">
                                                            <span>#</span>
                                                            <span>Référence</span>
                                                            <span>Produit</span>
                                                            <span>Qté</span>
                                                            <span>Description</span>
                                                        </div>
                                                        @foreach (var (ligne, idx) in demande.Lignes.Select((l,i)=>(l,i)))
                                                        {
                                                            <div class="mda-ligne-row">
                                                                <span class="mda-ligne-num">@(idx+1)</span>
                                                                <span class="mda-ligne-ref">@(string.IsNullOrEmpty(ligne.Reference) ? "—" : ligne.Reference)</span>
                                                                <span class="mda-ligne-nom">@ligne.NomProduit</span>
                                                                <span class="mda-ligne-qty">@ligne.Quantite</span>
                                                                <span class="mda-ligne-desc">@(ligne.Description ?? "—")</span>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }

                                            <div class="mda-detail-actions">
                                                <button class="mda-btn-offres mda-btn-offres-lg" @onclick="() => NavigateToOffres(demande.IdDemande)">
                                                    <svg viewBox="0 0 24 24"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                                                    Voir les offres fournisseurs
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mda-pagination">
                        <span class="mda-pag-info">
                            Affichage de @Math.Min((CurrentPage-1)*PageSize+1, DemandesFiltrees.Count)
                            à @Math.Min(CurrentPage*PageSize, DemandesFiltrees.Count)
                            sur @DemandesFiltrees.Count demande(s)
                        </span>
                    </div>
                }
            </div>

        </main>

        @* ══════ PANNEAU CRÉATION ══════ *@
        @if (_showCreatePanel)
        { <div class="mda-panel-overlay" @onclick="CloseCreatePanel"></div> }

        <div class="mda-create-panel @(_showCreatePanel ? "open" : "")" @onclick:stopPropagation="true">
            <div class="mda-create-panel-header">
                <div>
                    <h2 class="mda-create-title">Nouvelle demande d'achat</h2>
                    <p class="mda-create-sub">Ajoutez un ou plusieurs matériels</p>
                </div>
            </div>

            <div class="mda-create-body">

                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="mda-form-error-banner">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        @_formError
                    </div>
                }

                @* ── Titre global ── *@
                <div class="mda-field">
                    <label class="mda-field-label">Titre de la demande <span class="mda-required">*</span></label>
                    <input type="text" class="mda-field-input"
                           placeholder="Ex: Équipements pour la salle de réunion B"
                           @bind="_form.NomDemande" />
                </div>

                @* ── Justification globale ── *@
                <div class="mda-field">
                    <label class="mda-field-label">Justification globale <span class="mda-optional">(facultatif)</span></label>
                    <textarea class="mda-field-input mda-field-textarea" rows="2"
                              placeholder="Contexte général de la demande…"
                              @bind="_form.Description"></textarea>
                </div>

                @* ── Séparateur lignes ── *@
                <div class="mda-lignes-header">
                    <p class="mda-lignes-label">
                        <svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                        Matériels demandés
                    </p>
                    <button class="mda-btn-add-ligne" @onclick="AjouterLigne">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Ajouter un matériel
                    </button>
                </div>

                @* ── Cartes lignes ── *@
                @foreach (var (ligne, idx) in _form.Lignes.Select((l,i)=>(l,i)))
                {
                    <div class="mda-ligne-form @(!string.IsNullOrEmpty(ligne.Erreur) ? "has-error" : "")">

                        <div class="mda-ligne-form-header">
                            <span class="mda-ligne-badge">Matériel @(idx+1)</span>
                            @if (_form.Lignes.Count > 1)
                            {
                                <button class="mda-ligne-del" @onclick="() => SupprimerLigne(ligne)" title="Supprimer">
                                    <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                                </button>
                            }
                        </div>

                        @* Produit + Quantité *@
                        <div class="mda-ligne-row-inputs">
                            <div class="mda-field" style="flex:1">
                                <label class="mda-field-label">Produit <span class="mda-required">*</span></label>
                                <input type="text"
                                       class="mda-field-input @(!string.IsNullOrEmpty(ligne.Erreur) ? "input-error" : "")"
                                       placeholder="Ex: RAM DDR4 32GB ECC"
                                       @bind="ligne.NomProduit" @bind:event="oninput" />
                            </div>
                            <div class="mda-field mda-field-qty">
                                <label class="mda-field-label">Qté <span class="mda-required">*</span></label>
                                <input type="number" min="1" class="mda-field-input"
                                       @bind="ligne.Quantite" @bind:event="oninput" />
                            </div>
                        </div>

                        @* Référence par matériel ← NOUVEAU *@
                        <div class="mda-field">
                            <label class="mda-field-label">Référence <span class="mda-optional">(facultatif)</span></label>
                            <input type="text" class="mda-field-input"
                                   placeholder="Ex: CMD-2026-001"
                                   @bind="ligne.Reference" @bind:event="oninput" />
                        </div>

                        @* Description *@
                        <div class="mda-field">
                            <label class="mda-field-label">Description <span class="mda-optional">(facultatif)</span></label>
                            <input type="text" class="mda-field-input"
                                   placeholder="Ex: Extension mémoire serveur SRV-DB-01"
                                   @bind="ligne.Description" @bind:event="oninput" />
                        </div>

                        @if (!string.IsNullOrEmpty(ligne.Erreur))
                        { <span class="mda-field-error">@ligne.Erreur</span> }

                    </div>
                }

                <button class="mda-btn-add-ligne-full" @onclick="AjouterLigne">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    + Ajouter un autre matériel
                </button>

            </div>

            <div class="mda-create-footer">
                @if (_isSaving)
                {
                    <button class="mda-btn-save" disabled><div class="mda-mini-spinner"></div>Envoi en cours...</button>
                }
                else
                {
                    <button class="mda-btn-save" @onclick="SubmitCreate">
                        <svg viewBox="0 0 24 24"><path d="M5 12l5 5L20 7"/></svg>
                        Soumettre la demande
                    </button>
                }
                <button class="mda-btn-cancel" @onclick="CloseCreatePanel">Annuler</button>
            </div>
        </div>

    </div>

</div>
</RoleAuthGuard>
