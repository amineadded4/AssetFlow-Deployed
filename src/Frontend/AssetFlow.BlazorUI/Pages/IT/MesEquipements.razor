@* ============================================================
   AssetFlow.BlazorUI / Pages / IT / MesEquipements.razor
   Sidebar identique à Affectation IT
   ============================================================ *@

@page "/it/equipements"
@using AssetFlow.BlazorUI.Services
@using AssetFlow.BlazorUI.Components

<RoleAuthGuard AllowedRoles="@(new[]{"IT"})">
<div class="aff-layout">

    @* ══════ SIDEBAR ══════ *@
    <aside class="aff-sidebar">
        <div class="sidebar-logo-wrap">
            <img src="images/logo.png" alt="AssetFlow" class="aff-sidebar-logo" />
        </div>
        <nav class="aff-sidebar-nav">
            <a href="/dashboard/it" class="aff-nav-link">
                <svg class="aff-nav-icon" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                <span class="aff-nav-text">Dashboard</span>
            </a>
            <a href="/it/equipements" class="aff-nav-link active">
                <svg class="aff-nav-icon" viewBox="0 0 24 24">
                    <rect x="2" y="3" width="20" height="14" rx="2" />
                    <path d="M8 21h8M12 17v4" />
                </svg>
                <span class="aff-nav-text">Mes Équipements</span>
            </a>
            <a href="/it/employes" class="aff-nav-link">
                <svg class="aff-nav-icon" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span class="aff-nav-text">Matériels affectés</span>
            </a>
            <a href="/it/affectation" class="aff-nav-link">
                <svg class="aff-nav-icon" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>
                <span class="aff-nav-text">Assigner matériels</span>
            </a>
            <a href="/it/incidents" class="aff-nav-link">
                <svg class="aff-nav-icon" viewBox="0 0 24 24"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3ZM12 9v4M12 17h.01"/></svg>
                <span class="aff-nav-text">Incidents</span>
            </a>
            <a href="/it/inventaire" class="aff-nav-link">
                <svg class="aff-nav-icon" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="M3.27 6.96 12 12.01l8.73-5.05M12 22.08V12"/></svg>
                <span class="aff-nav-text">Inventaire</span>
            </a>
            <a href="/it/demandes-achat" class="aff-nav-link">
                <svg class="aff-nav-icon" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                <span class="aff-nav-text">Mes achats</span>
            </a>
            <a href="/it/messagerie" class="aff-nav-link">
                <svg class="aff-nav-icon" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <span class="aff-nav-text">Messagerie</span>
            </a>
        </nav>
        <div class="aff-sidebar-profile">
            <div class="aff-profile-avatar">@GetInitials()</div>
            <div class="aff-profile-info">
                <p class="aff-profile-name">@UserName</p>
                <p class="aff-profile-role">IT</p>
            </div>
        </div>
        <LogoutButton />
    </aside>

    @* ══════ OVERLAY MENU MOBILE ══════ *@
    @if (_menuOpen)
    {
        <div class="aff-menu-overlay" @onclick="() => _menuOpen = false">
            <div class="aff-menu-drawer" @onclick:stopPropagation="true">
                <div class="aff-menu-drawer-logo">
                    <img src="images/logo.png" alt="AssetFlow" class="aff-sidebar-logo" />
                </div>
                <nav class="aff-menu-drawer-nav">
                    <a href="/dashboard/it"      class="aff-nav-link"        @onclick="() => _menuOpen = false"><svg class="aff-nav-icon" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg><span class="aff-nav-text">Dashboard</span></a>
                    <a href="/it/equipements"    class="aff-nav-link active" @onclick="() => _menuOpen = false"><svg class="aff-nav-icon" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg><span class="aff-nav-text">Mes Équipements</span></a>
                    <a href="/it/employes"       class="aff-nav-link"        @onclick="() => _menuOpen = false"><svg class="aff-nav-icon" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg><span class="aff-nav-text">Gestion d'affectations</span></a>
                    <a href="/it/affectation"    class="aff-nav-link"        @onclick="() => _menuOpen = false"><svg class="aff-nav-icon" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg><span class="aff-nav-text">Affectations</span></a>
                    <a href="/it/incidents"      class="aff-nav-link"        @onclick="() => _menuOpen = false"><svg class="aff-nav-icon" viewBox="0 0 24 24"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3ZM12 9v4M12 17h.01"/></svg><span class="aff-nav-text">Incidents</span></a>
                    <a href="/it/inventaire"     class="aff-nav-link"        @onclick="() => _menuOpen = false"><svg class="aff-nav-icon" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg><span class="aff-nav-text">Inventaire</span></a>
                    <a href="/it/demandes-achat" class="aff-nav-link"        @onclick="() => _menuOpen = false"><svg class="aff-nav-icon" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/></svg><span class="aff-nav-text">Mes achats</span></a>
                    <a href="/it/messagerie"     class="aff-nav-link"        @onclick="() => _menuOpen = false"><svg class="aff-nav-icon" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg><span class="aff-nav-text">Messagerie</span></a>
                </nav>
                <div class="aff-sidebar-profile">
                    <div class="aff-profile-avatar">@GetInitials()</div>
                    <div class="aff-profile-info"><p class="aff-profile-name">@UserName</p><p class="aff-profile-role">IT</p></div>
                </div>
                <LogoutButton />
            </div>
        </div>
    }

    @* ══════ MAIN ══════ *@
    <main class="iteq-main">

        <header class="iteq-header">
            <button class="aff-hamburger" @onclick="() => _menuOpen = !_menuOpen" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
            <div class="iteq-header-left">
                <h1 class="iteq-page-title">Mes Équipements</h1>
                <span class="iteq-header-badge">@MaterielsGroupesFiltres.Count</span>
            </div>
            <div class="iteq-header-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text"
                       placeholder="Rechercher un équipement..."
                       value="@SearchQuery"
                       @oninput="OnSearchInput" />
            </div>
        </header>

        <div class="iteq-content">
            @if (IsLoading)
            {
                <div class="iteq-loading">
                    <div class="iteq-spinner"></div>
                    <p>Chargement de vos équipements...</p>
                </div>
            }
            else if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="iteq-empty">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
                    <p>@ErrorMessage</p>
                </div>
            }
            else if (MaterielsGroupesFiltres.Count == 0 && !string.IsNullOrEmpty(SearchQuery))
            {
                <div class="iteq-empty">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <p>Aucun équipement trouvé pour "@SearchQuery"</p>
                </div>
            }
            else if (MaterielsGroupesFiltres.Count == 0)
            {
                <div class="iteq-empty">
                    <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                    <p>Aucun équipement affecté pour le moment.</p>
                </div>
            }
            else
            {
                <div class="iteq-grid">
                    @foreach (var materiel in MaterielsGroupesFiltres.Where(m => m.NombreArticles > 0))
                    {
                        <div class="iteq-card @(materiel.StatutDominant == "Endommage" ? "card-damaged" : "")">

                            <div class="iteq-card-image">
                                @if (!string.IsNullOrEmpty(materiel.ImageUrl))
                                {
                                    <img src="@materiel.ImageUrl" alt="@materiel.Designation" />
                                }
                                else
                                {
                                    <div class="iteq-img-placeholder">
                                        <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                                    </div>
                                }
                                <div class="iteq-articles-badge">
                                    <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM16 3H8"/></svg>
                                    @materiel.NombreArticles article@(materiel.NombreArticles > 1 ? "s" : "")
                                </div>
                            </div>

                            <div class="iteq-card-content">
                                <h3 class="iteq-card-title">@materiel.Designation</h3>
                                <p class="iteq-card-ref">@materiel.Reference</p>
                                <p class="iteq-card-cat">@materiel.Categorie</p>
                                <div class="iteq-card-date">
                                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                                    Assigné le @materiel.DerniereAffectation.ToString("dd/MM/yyyy")
                                </div>
                                <button class="iteq-btn-articles" @onclick="() => OuvrirModal(materiel)">
                                    <svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                                    Voir les @materiel.NombreArticles article@(materiel.NombreArticles > 1 ? "s" : "")
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

    </main>
</div>

@* ══════ MODAL ARTICLES ══════ *@
@if (ModalOuvert && MaterielSelectionne != null)
{
    <div class="modal-backdrop" @onclick="FermerModal">
        <div class="modal-container" @onclick:stopPropagation="true">

            <div class="modal-header">
                <div class="modal-header-left">
                    <div class="modal-icon">
                        <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 3H8"/></svg>
                    </div>
                    <div>
                        <h2 class="modal-title">@MaterielSelectionne.Designation</h2>
                        <p class="modal-subtitle">
                            @MaterielSelectionne.NombreArticles article@(MaterielSelectionne.NombreArticles > 1 ? "s" : "") affecté@(MaterielSelectionne.NombreArticles > 1 ? "s" : "") · @MaterielSelectionne.Categorie
                        </p>
                    </div>
                </div>
                <button class="modal-close" @onclick="FermerModal">
                    <svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
                </button>
            </div>

            <div class="modal-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text"
                       placeholder="Rechercher par numéro de série..."
                       value="@ModalSearchQuery"
                       @oninput="OnModalSearchInput" />
            </div>

            <div class="modal-body">
                @{
                    var articlesFiltres = string.IsNullOrWhiteSpace(ModalSearchQuery)
                        ? MaterielSelectionne.Articles
                        : MaterielSelectionne.Articles
                            .Where(a => a.NumeroSerie.Contains(ModalSearchQuery, StringComparison.OrdinalIgnoreCase)
                                    || (a.Observations ?? "").Contains(ModalSearchQuery, StringComparison.OrdinalIgnoreCase))
                            .ToList();
                }

                @if (!articlesFiltres.Any())
                {
                    <div class="modal-empty">
                        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        <p>Aucun article trouvé.</p>
                    </div>
                }
                else
                {
                    <div class="articles-table-header">
                        <span>N° Série / Identifiant</span>
                        <span>Statut</span>
                        <span>Date affectation</span>
                        <span></span>
                    </div>
                    <div class="articles-list">
                        @foreach (var article in articlesFiltres)
                        {
                            <div class="article-row" @onclick="() => NaviguerVersDetail(article.AffectationId, article.ArticleId)">
                                <div class="article-serie">
                                    <div class="article-icon">
                                        <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                                    </div>
                                    <div>
                                        <p class="serie-number">@article.NumeroSerie</p>
                                        @if (!string.IsNullOrEmpty(article.Observations))
                                        { <p class="serie-obs">@article.Observations</p> }
                                    </div>
                                </div>
                                <div class="article-statut">
                                    <span class="statut-pill-sm" style="--pill-color: @article.StatutBadgeColor;">
                                        <span class="pill-dot"></span>
                                        @article.EtatArticle
                                    </span>
                                </div>
                                <div class="article-date">@article.DateAffectation.ToString("dd MMM yyyy")</div>
                                <div class="article-action">
                                    <button class="btn-voir-detail" @onclick:stopPropagation="true"
                                            @onclick="() => NaviguerVersDetail(article.AffectationId, article.ArticleId)">
                                        Voir détail
                                        <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="modal-footer">
                <span class="modal-footer-info">
                    @articlesFiltres.Count() article@(articlesFiltres.Count() > 1 ? "s" : "") affiché@(articlesFiltres.Count() > 1 ? "s" : "")
                </span>
                <button class="modal-btn-fermer" @onclick="FermerModal">Fermer</button>
            </div>

        </div>
    </div>
}
</RoleAuthGuard>
