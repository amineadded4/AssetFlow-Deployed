@page "/it/equipements"
@using AssetFlow.BlazorUI.Services
@using AssetFlow.BlazorUI.Components

<RoleAuthGuard AllowedRoles="@(new[]{"IT","Admin"})">
<div class="aff-layout">

    @* ══════ SIDEBAR ══════ *@
    
        @if (_estAdmin)
        {
            <AdminSidebar ForceOpen="_menuOpen" />
        }
        else
        {
            <ITSidebar ActivePage="equipements" ForceOpen="_menuOpen" />
        }
    
     

    @* ══════ OVERLAY MENU MOBILE ══════ *@
     @if (_menuOpen)
    { <div  @onclick="() => _menuOpen = !_menuOpen"></div> } 

    @* ══════ MAIN ══════ *@
    <main class="iteq-main">

        <header class="iteq-header">
            <button class="aff-hamburger" @onclick="() => _menuOpen = !_menuOpen" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
            <div class="iteq-header-left">
                <div class="header-brand-icon">
                        <svg viewBox="0 0 24 24">
                            <rect x="2" y="7" width="20" height="14" rx="2"/>
                            <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                            <line x1="12" y1="12" x2="12" y2="16"/>
                            <line x1="10" y1="14" x2="14" y2="14"/>
                        </svg>
                </div>
                <h1 class="iteq-page-title">Mes Équipements</h1>
                <span class="iteq-header-badge">@MaterielsGroupesFiltres.Count</span>
            </div>

            <div class="iteq-header-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text"
                       placeholder="Rechercher un équipement..."
                       value="@SearchQuery"
                       @oninput="OnSearchInput" />
            </div>
        </header>

        <div class="iteq-content">
            @if (IsLoading)
            {
                <div class="iteq-loading">
                    <div class="iteq-spinner"></div>
                    <p>Chargement de vos équipements...</p>
                </div>
            }
            else if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="iteq-empty">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
                    <p>@ErrorMessage</p>
                </div>
            }
            else if (MaterielsGroupesFiltres.Count == 0 && !string.IsNullOrEmpty(SearchQuery))
            {
                <div class="iteq-empty">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <p>Aucun équipement trouvé pour "@SearchQuery"</p>
                </div>
            }
            else if (MaterielsGroupesFiltres.Count == 0)
            {
                <div class="iteq-empty">
                    <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                    <p>Aucun équipement affecté pour le moment.</p>
                </div>
            }
            else
            {
                <div class="iteq-grid">
                    @foreach (var materiel in MaterielsGroupesFiltres.Where(m => m.NombreArticles > 0))
                    {
                        <div class="iteq-card @(materiel.StatutDominant == "Endommage" ? "card-damaged" : "")">

                            <div class="iteq-card-image">
                                @if (!string.IsNullOrEmpty(materiel.ImageUrl))
                                {
                                    <img src="@materiel.ImageUrl" alt="@materiel.Designation" />
                                }
                                else
                                {
                                    <div class="iteq-img-placeholder">
                                        <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                                    </div>
                                }
                                <div class="iteq-articles-badge">
                                    <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM16 3H8"/></svg>
                                    @materiel.NombreArticles article@(materiel.NombreArticles > 1 ? "s" : "")
                                </div>
                            </div>

                            <div class="iteq-card-content">
                                <h3 class="iteq-card-title">@materiel.Designation</h3>
                                <p class="iteq-card-ref">@materiel.Reference</p>
                                <p class="iteq-card-cat">@materiel.Categorie</p>
                                <div class="iteq-card-date">
                                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                                    Assigné le @materiel.DerniereAffectation.ToString("dd/MM/yyyy")
                                </div>

                                @* ── Bouton Voir les articles ── *@
                                <button class="iteq-btn-articles" @onclick="() => OuvrirModal(materiel)">
                                    <svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                                    Voir les @materiel.NombreArticles article@(materiel.NombreArticles > 1 ? "s" : "") / Déclaer un incident
                                </button>

                                @* ── Bouton Commenter (sur le matériel entier) ── *@
                                <button class="iteq-btn-commenter" @onclick="() => OuvrirModalCommentaire(materiel)">
                                    <svg viewBox="0 0 24 24">
                                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                                    </svg>
                                    Commenter
                                    @if (materiel.NombreCommentaires > 0)
                                    {
                                        <span class="iteq-comment-pill">@materiel.NombreCommentaires</span>
                                    }
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

    </main>
</div>

@* ══════ MODAL ARTICLES (inchangé) ══════ *@
@if (ModalOuvert && MaterielSelectionne != null)
{
    <div class="modal-backdrop" @onclick="FermerModal">
        <div class="modal-container" @onclick:stopPropagation="true">

            <div class="modal-header">
                <div class="modal-header-left">
                    <div class="modal-icon">
                        <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 3H8"/></svg>
                    </div>
                    <div>
                        <h2 class="modal-title">@MaterielSelectionne.Designation</h2>
                        <p class="modal-subtitle">
                            @MaterielSelectionne.NombreArticles article@(MaterielSelectionne.NombreArticles > 1 ? "s" : "") affecté@(MaterielSelectionne.NombreArticles > 1 ? "s" : "") · @MaterielSelectionne.Categorie
                        </p>
                    </div>
                </div>
                <button class="modal-close" @onclick="FermerModal">
                    <svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
                </button>
            </div>

            <div class="modal-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text"
                       placeholder="Rechercher par numéro de série..."
                       value="@ModalSearchQuery"
                       @oninput="OnModalSearchInput" />
            </div>

            <div class="modal-body">
                @{
                    var articlesFiltres = string.IsNullOrWhiteSpace(ModalSearchQuery)
                        ? MaterielSelectionne.Articles
                        : MaterielSelectionne.Articles
                            .Where(a => a.NumeroSerie.Contains(ModalSearchQuery, StringComparison.OrdinalIgnoreCase)
                                    || (a.Observations ?? "").Contains(ModalSearchQuery, StringComparison.OrdinalIgnoreCase))
                            .ToList();
                }

                @if (!articlesFiltres.Any())
                {
                    <div class="modal-empty">
                        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        <p>Aucun article trouvé.</p>
                    </div>
                }
                else
                {
                    <div class="articles-table-header">
                        <span>N° Série / Identifiant</span>
                        <span>Statut</span>
                        <span>Date affectation</span>
                        <span></span>
                    </div>
                    <div class="articles-list">
                        @foreach (var article in articlesFiltres)
                        {
                            <div class="article-row" @onclick="() => NaviguerVersDetail(article.AffectationId, article.ArticleId)">
                                <div class="article-serie">
                                    <div class="article-icon">
                                        <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                                    </div>
                                    <div>
                                        <p class="serie-number">@article.NumeroSerie</p>
                                        @if (!string.IsNullOrEmpty(article.Observations))
                                        { <p class="serie-obs">@article.Observations</p> }
                                    </div>
                                </div>
                                <div class="article-statut">
                                    <span class="statut-pill-sm" style="--pill-color: @article.StatutBadgeColor;">
                                        <span class="pill-dot"></span>
                                        @article.EtatArticle
                                    </span>
                                </div>
                                <div class="article-date">@article.DateAffectation.ToString("dd MMM yyyy")</div>
                                <div class="article-action">
                                    <button class="btn-voir-detail" @onclick:stopPropagation="true"
                                            @onclick="() => NaviguerVersDetail(article.AffectationId, article.ArticleId)">
                                        Voir détail
                                        <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="modal-footer">
                <span class="modal-footer-info">
                    @articlesFiltres.Count() article@(articlesFiltres.Count() > 1 ? "s" : "") affiché@(articlesFiltres.Count() > 1 ? "s" : "")
                </span>
                <button class="modal-btn-fermer" @onclick="FermerModal">Fermer</button>
            </div>

        </div>
    </div>
}

@* ══════ MODAL COMMENTAIRE (NOUVEAU) ══════ *@
@if (ModalCommentaireOuvert && MaterielCommentaire != null)
{
    <div class="modal-backdrop" @onclick="FermerModalCommentaire">
        <div class="modal-container modal-commentaire" @onclick:stopPropagation="true">

            @* ── Header ── *@
            <div class="modal-header">
                <div class="modal-header-left">
                    <div class="modal-icon modal-icon-comment">
                        <svg viewBox="0 0 24 24">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                        </svg>
                    </div>
                    <div>
                        <h2 class="modal-title">Commenter un équipement</h2>
                        <p class="modal-subtitle">
                            <strong>@MaterielCommentaire.Designation</strong>
                            &nbsp;·&nbsp;
                            <span class="modal-ref">@MaterielCommentaire.Reference</span>
                        </p>
                    </div>
                </div>
                <button class="modal-close" @onclick="FermerModalCommentaire">
                    <svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
                </button>
            </div>

            @* ── Corps ── *@
            <div class="modal-body commentaire-body">

                @* Zone de saisie *@
                <div class="commentaire-input-group">
                    <label class="commentaire-label">Votre avis sur cet équipement</label>
                    <textarea class="commentaire-textarea"
                              placeholder="Décrivez votre expérience, signalez un problème ou donnez votre avis sur @MaterielCommentaire.Designation..."
                              maxlength="1000"
                              @bind="CommentaireContenu"
                              @bind:event="oninput"
                              rows="5">
                    </textarea>
                    <div class="commentaire-counter @(CommentaireContenu.Length > 900 ? "counter-warn" : "")">
                        @CommentaireContenu.Length / 1000
                    </div>
                </div>

                @* Feedback succès / erreur *@
                @if (!string.IsNullOrEmpty(CommentaireFeedback))
                {
                    <div class="commentaire-feedback @(CommentaireSucces ? "feedback-success" : "feedback-error")">
                        <svg viewBox="0 0 24 24">
                            @if (CommentaireSucces)
                            {
                                <path d="M20 6L9 17l-5-5"/>
                            }
                            else
                            {
                                <circle cx="12" cy="12" r="10"/>
                                <path d="M12 8v4M12 16h.01"/>
                            }
                        </svg>
                        @CommentaireFeedback
                    </div>
                }

                
            @* ── Commentaires existants (AVEC bouton supprimer) ── *@
            @if (CommentaireChargement)
            {
                <div class="loading-state" style="min-height:80px;">
                    <div class="spinner"></div>
                </div>
            }
            else if (CommentairesExistants.Any())
            {
                <div class="commentaires-existants">
                    <h4 class="existants-titre">
                        <svg viewBox="0 0 24 24">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                        </svg>
                        Mes commentaires (@CommentairesExistants.Count)
                    </h4>
                    <div class="existants-list">
                        @foreach (var c in CommentairesExistants)
                        {
                            <div class="existant-item">
                                <div class="existant-avatar">@c.AuteurInitiales</div>
                                <div class="existant-content">
                                    <div class="existant-meta">
                                        <span class="existant-auteur">@c.AuteurNom</span>
                                        <span class="existant-date">@c.DateCreation.ToLocalTime().ToString("dd MMM yyyy · HH:mm")</span>

                                        @* ── Bouton Supprimer ── *@
                                        <button class="btn-supprimer-commentaire"
                                                disabled="@(CommentaireSupprimerId == c.Id)"
                                                @onclick="() => SupprimerCommentaire(c.Id)"
                                                title="Supprimer ce commentaire">
                                            @if (CommentaireSupprimerId == c.Id)
                                            {
                                                <span class="spinner-xs"></span>
                                            }
                                            else
                                            {
                                                <svg viewBox="0 0 24 24">
                                                    <polyline points="3 6 5 6 21 6"/>
                                                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                                                    <path d="M10 11v6M14 11v6"/>
                                                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                                                </svg>
                                            }
                                        </button>
                                    </div>
                                    <p class="existant-texte">@c.Contenu</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="no-comments">
                    <svg viewBox="0 0 24 24">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    </svg>
                    <p>Aucun commentaire pour le moment. Soyez le premier à donner votre avis !</p>
                </div>
            }


            </div>

            @* ── Footer ── *@
            <div class="modal-footer">
                <button class="modal-btn-fermer" @onclick="FermerModalCommentaire">Annuler</button>
                <button class="btn-envoyer-commentaire"
                        disabled="@(CommentaireEnvoi || string.IsNullOrWhiteSpace(CommentaireContenu))"
                        @onclick="EnvoyerCommentaire">
                    @if (CommentaireEnvoi)
                    {
                        <span class="spinner-sm"></span>
                        <span>Envoi...</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24">
                            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
                        </svg>
                        <span>Envoyer</span>
                    }
                </button>
            </div>

        </div>
    </div>
}
</RoleAuthGuard>
