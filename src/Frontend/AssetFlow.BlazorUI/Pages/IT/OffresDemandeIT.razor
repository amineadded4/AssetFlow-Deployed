@page "/it/offres/{DemandeId:int}"
@using AssetFlow.Application.DTOs
@using AssetFlow.BlazorUI.Components

<RoleAuthGuard AllowedRoles="@(new[]{"IT","Admin"})" Context="userRole">
    @{ _roleUtilisateur = userRole; }  @* ← assigné avant le premier rendu du contenu *@
    <div class="oda-layout">
        @if (_estAdmin)
        {
            <AdminSidebar ForceOpen="_menuOpen" />
        }
        else
        {
            <ITSidebar ActivePage="achats" ForceOpen="_menuOpen" />
        }

    @if (_menuOpen)
    { <div  @onclick="() => _menuOpen = !_menuOpen"></div> } 

    @* ══ MODALE PDF ══ *@
    @if (_pdfModalUrl != null)
    {
        <div class="oda-pdf-modal-overlay" @onclick="ClosePdfModal">
            <div class="oda-pdf-modal" @onclick:stopPropagation="true">
                <div class="oda-pdf-modal-header">
                    <div class="oda-pdf-modal-title-wrap">
                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        <span>@_pdfModalName</span>
                    </div>
                    <button class="oda-pdf-modal-close" @onclick="ClosePdfModal">
                        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <iframe src="@_pdfModalUrl" class="oda-pdf-modal-frame" title="PDF"></iframe>
            </div>
        </div>
    }

    @* ══ MODALE DE CONFIRMATION ══ *@
    @if (_confirmModalOffre != null)
    {
        <div class="oda-confirm-modal-overlay" @onclick="CloseConfirmModal">
            <div class="oda-confirm-modal" @onclick:stopPropagation="true">
                <div class="oda-confirm-modal-icon">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                </div>
                <h3 class="oda-confirm-modal-title">Confirmer la sélection</h3>
                <p class="oda-confirm-modal-sub">Vous êtes sur le point de sélectionner l'offre :</p>
                <div class="oda-confirm-modal-file">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    @_confirmModalOffre.NomFichier
                </div>

                @* ── Bannière irréversible ── *@
                <div class="oda-confirm-irreversible-banner">
                    <svg class="oda-irrev-icon" viewBox="0 0 24 24" fill="none">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <div class="oda-irrev-text">
                        <span class="oda-irrev-title">Action irréversible</span>
                        <span class="oda-irrev-desc">Une fois confirmée, cette sélection ne peut plus être modifiée ou annulée.</span>
                    </div>
                </div>

                <div class="oda-confirm-modal-actions">
                    <button class="oda-btn-ghost" @onclick="CloseConfirmModal" disabled="@_isSaving">Annuler</button>
                    <button class="oda-btn-confirm-modal @(_isSaving ? "saving" : "")"
                            @onclick="DoConfirm" disabled="@_isSaving">
                        @if (_isSaving)
                        {
                            <span class="oda-ocr-spin"></span>
                            <span>Enregistrement...</span>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                            <span>Oui, confirmer définitivement</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="oda-body-wrap">
        <main class="oda-main">
            <header class="oda-header">
                <button class="oda-hamburger" @onclick="() => _menuOpen = !_menuOpen" aria-label="Menu">
                    <span></span><span></span><span></span>
                </button>
                <div class="oda-header-left">
                    <div class="oda-breadcrumb">
                        <a href="/it/demandes-achat" class="oda-bc-link">Mes achats</a>
                        <svg class="oda-bc-sep" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
                        <span class="oda-bc-current">Sélection des offres</span>
                    </div>
                    <h1 class="oda-page-title">Sélection des offres</h1>
                    <p class="oda-page-sub">Demande&nbsp;#@DemandeId · Consultez et sélectionnez la meilleure offre</p>
                </div>
                @if (_offres.Count > 0)
                {
                    <span class="oda-pill">@_offres.Count offre(s)</span>
                }
            </header>

            <div class="oda-content">
                @if (_isLoading)
                {
                    <div class="oda-state">
                        <div class="oda-spinner"></div>
                        <p>Chargement des offres...</p>
                    </div>
                }
                else if (!_offres.Any())
                {
                    <div class="oda-state">
                        <p class="oda-empty-title">Aucune offre disponible</p>
                        <p class="oda-empty-sub">Aucune offre fournisseur n'a été soumise pour cette demande.</p>
                    </div>
                }
                else
                {
                    <div class="oda-selection-cards @(_confirmModalOffre != null ? "oda-cards-locked" : "")">
                        @foreach (var (offre, idx) in _offres.Select((o, i) => (o, i)))
                        {
                            var fs          = GetOrCreate(offre.IdOffre);
                            var ocrSt       = GetOcrStatus(offre.IdOffre);
                            var ocrErr      = GetOcrError(offre.IdOffre);
                            bool selected   = _selectedId == offre.IdOffre;
                            bool confirmed  = _confirmedId == offre.IdOffre;
                            bool isExpanded = _expandedId == offre.IdOffre;
                            bool modalOpen  = _confirmModalOffre != null;
                            // locked = modal ouvert OU une offre déjà confirmée
                            bool locked     = modalOpen || _confirmedId.HasValue;

                            <div class="oda-sel-card @(selected ? "is-selected" : "") @(confirmed ? "is-confirmed" : "") @(locked && !confirmed ? "is-locked" : "")">

                                <div class="oda-sel-card-header"
                                     @onclick="() => { if (!locked) SelectOffre(offre.IdOffre); }">
                                    <div class="oda-sel-header-top">
                                        <div class="oda-sel-title-row">
                                            <div class="oda-sel-radio @(selected ? "checked" : "") @(locked ? "radio-locked" : "")">
                                                @if (selected)
                                                {
                                                    <svg viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                                                }
                                            </div>
                                            <div>
                                                <p class="oda-sel-filename">@offre.NomFichier</p>
                                                <p class="oda-sel-filesize">@FormatBytes(offre.Taille)</p>
                                            </div>
                                        </div>
                                        <div class="oda-sel-badges">
                                            @if (confirmed)
                                            {
                                                <span class="oda-badge-selected">✓ SÉLECTIONNÉ</span>
                                            }
                                            @if (_recommendedOffre == offre.NomFichier)
                                            {
                                                <span class="oda-badge-recommended-ai">🤖 RECOMMANDÉ</span>
                                            }
                                            @if (ocrSt == OcrStatus.Done)
                                            {
                                                <span class="oda-ocr-badge oda-ocr-done">
                                                    <svg viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                                                    OCR extrait
                                                </span>
                                            }
                                            else if (ocrSt == OcrStatus.Running)
                                            {
                                                <span class="oda-ocr-badge oda-ocr-running">
                                                    <span class="oda-ocr-spin"></span>
                                                    Analyse...
                                                </span>
                                            }
                                        </div>
                                    </div>

                       @* Métriques depuis OCR (en cours) OU depuis SQL (après confirmation) *@
                        @if (confirmed && !string.IsNullOrEmpty(offre.PrixTotal))
                        {
                            <div class="oda-sel-metrics">
                                <div class="oda-metric">
                                    <span class="oda-metric-label">PRIX TOTAL</span>
                                    <span class="oda-metric-val primary">@offre.PrixTotal</span>
                                </div>
                                @if (!string.IsNullOrEmpty(offre.DelaiLivraison))
                                {
                                    <div class="oda-metric">
                                        <span class="oda-metric-label">DÉLAI</span>
                                        <span class="oda-metric-val @(IsDelaiRapide(offre.DelaiLivraison) ? "green" : "orange")">@offre.DelaiLivraison jours</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="oda-metric">
                                        <span class="oda-metric-label">DÉLAI</span>
                                        <span class="oda-metric-val oda-metric-na">Non renseigné</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(offre.Garantie))
                                {
                                    <div class="oda-metric">
                                        <span class="oda-metric-label">GARANTIE</span>
                                        <span class="oda-metric-val">@offre.Garantie</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="oda-metric">
                                        <span class="oda-metric-label">GARANTIE</span>
                                        <span class="oda-metric-val oda-metric-na">Non renseigné</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(offre.FraisLivraison))
                                {
                                    <div class="oda-metric">
                                        <span class="oda-metric-label">FRAIS LIVRAISON</span>
                                        <span class="oda-metric-val">@offre.FraisLivraison</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="oda-metric">
                                        <span class="oda-metric-label">FRAIS LIVRAISON</span>
                                        <span class="oda-metric-val oda-metric-na">Non renseigné</span>
                                    </div>
                                }
                            </div>
                        }
                        else if (confirmed)
                        {
                            @* Confirmé mais aucune info OCR n'avait été extraite *@
                            <div class="oda-metric-empty">
                                <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                Aucune information OCR disponible pour cette offre
                            </div>
                        }
                        else if (ocrSt == OcrStatus.Done && !string.IsNullOrEmpty(fs.TotalTtc))
                        {
                            <div class="oda-sel-metrics">
                                <div class="oda-metric">
                                    <span class="oda-metric-label">PRIX TOTAL</span>
                                    <span class="oda-metric-val primary">@fs.TotalTtc</span>
                                </div>
                                <div class="oda-metric">
                                    <span class="oda-metric-label">DÉLAI</span>
                                    @if (!string.IsNullOrEmpty(fs.DelaiLivraison))
                                    {
                                        <span class="oda-metric-val @(IsDelaiRapide(fs.DelaiLivraison) ? "green" : "orange")">@fs.DelaiLivraison jours</span>
                                    }
                                    else
                                    {
                                        <span class="oda-metric-val oda-metric-na">Non renseigné</span>
                                    }
                                </div>
                                <div class="oda-metric">
                                    <span class="oda-metric-label">GARANTIE</span>
                                    @if (!string.IsNullOrEmpty(fs.Garantie))
                                    {
                                        <span class="oda-metric-val">@fs.Garantie</span>
                                    }
                                    else
                                    {
                                        <span class="oda-metric-val oda-metric-na">Non renseigné</span>
                                    }
                                </div>
                                <div class="oda-metric">
                                    <span class="oda-metric-label">FRAIS LIVRAISON</span>
                                    @if (!string.IsNullOrEmpty(fs.FraisLivraison))
                                    {
                                        <span class="oda-metric-val">@fs.FraisLivraison</span>
                                    }
                                    else
                                    {
                                        <span class="oda-metric-val oda-metric-na">Non renseigné</span>
                                    }
                                </div>
                            </div>
                        }
                        else if (!confirmed && !string.IsNullOrEmpty(offre.PrixTotal))
                        {
                            @* Données SQL persistées (après navigation) *@
                            <div class="oda-sel-metrics">
                                <div class="oda-metric">
                                    <span class="oda-metric-label">PRIX TOTAL</span>
                                    <span class="oda-metric-val primary">@offre.PrixTotal</span>
                                </div>
                                <div class="oda-metric">
                                    <span class="oda-metric-label">DÉLAI</span>
                                    @if (!string.IsNullOrEmpty(offre.DelaiLivraison))
                                    {
                                        <span class="oda-metric-val @(IsDelaiRapide(offre.DelaiLivraison) ? "green" : "orange")">@offre.DelaiLivraison jours</span>
                                    }
                                    else { <span class="oda-metric-val oda-metric-na">Non renseigné</span> }
                                </div>
                                <div class="oda-metric">
                                    <span class="oda-metric-label">GARANTIE</span>
                                    @if (!string.IsNullOrEmpty(offre.Garantie))
                                    { <span class="oda-metric-val">@offre.Garantie</span> }
                                    else { <span class="oda-metric-val oda-metric-na">Non renseigné</span> }
                                </div>
                                <div class="oda-metric">
                                    <span class="oda-metric-label">FRAIS LIVRAISON</span>
                                    @if (!string.IsNullOrEmpty(offre.FraisLivraison))
                                    { <span class="oda-metric-val">@offre.FraisLivraison</span> }
                                    else { <span class="oda-metric-val oda-metric-na">Non renseigné</span> }
                                </div>
                            </div>
                        }
                        else if (ocrSt != OcrStatus.Done)
                        {
                            <p class="oda-sel-hint">Cliquez sur "Analyser" pour voir les détails</p>
                        }
                                </div>

                                <div class="oda-sel-expand-toggle"
                                     @onclick="() => { if (!modalOpen) Toggle(offre.IdOffre); }"
                                     @onclick:stopPropagation="true">
                                    <span>@(isExpanded ? "Masquer les détails" : "Voir / Analyser les détails")</span>
                                    <svg class="oda-chevron @(isExpanded ? "open" : "")" viewBox="0 0 24 24" fill="none">
                                        <polyline points="6 9 12 15 18 9"/>
                                    </svg>
                                </div>

                                @if (isExpanded)
                                {
                                    <div class="oda-sel-details">
                                        <div class="oda-two-col">

                                            <div class="oda-col-pdf">
                                                <p class="oda-col-label">
                                                    <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                                    Aperçu PDF
                                                </p>
                                                <div class="oda-pdf-thumb" @onclick="() => OpenPdfModal(offre)" @onclick:stopPropagation="true">
                                                    @if (_pdfUrls.ContainsKey(offre.IdOffre))
                                                    {
                                                        <iframe src="@_pdfUrls[offre.IdOffre]#toolbar=0&scrollbar=0" class="oda-pdf-thumb-frame" tabindex="-1" title="miniature"></iframe>
                                                        <div class="oda-pdf-thumb-overlay">
                                                            <svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
                                                            Agrandir
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="oda-pdf-placeholder">
                                                            <div class="oda-pdf-icon">
                                                                <svg viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                                                    <polyline points="14 2 14 8 20 8"/>
                                                                </svg>
                                                            </div>
                                                            <p class="oda-pdf-name">@offre.NomFichier</p>
                                                            <span class="oda-pdf-hint">Cliquer pour charger</span>
                                                        </div>
                                                    }
                                                </div>
                                                <div class="oda-pdf-btns">
                                                    <button class="oda-btn-view" @onclick="() => OpenPdfModal(offre)" @onclick:stopPropagation="true">
                                                        <svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
                                                        Visualiser
                                                    </button>
                                                    @if (ocrSt == OcrStatus.Running)
                                                    {
                                                        <button class="oda-btn-ocr oda-btn-ocr-running" disabled @onclick:stopPropagation="true">
                                                            <span class="oda-ocr-spin"></span>En cours…
                                                        </button>
                                                    }
                                                    else if (ocrSt == OcrStatus.Done)
                                                    {
                                                        <button class="oda-btn-ocr oda-btn-ocr-success"
                                                                @onclick="() => RunOcr(offre)"
                                                                @onclick:stopPropagation="true"
                                                                disabled="@locked">
                                                            <svg viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                                                            Ré-analyser
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="oda-btn-ocr"
                                                                @onclick="() => RunOcr(offre)"
                                                                @onclick:stopPropagation="true"
                                                                disabled="@locked">
                                                            <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                                            Analyser (OCR)
                                                        </button>
                                                    }
                                                </div>
                                                @if (ocrSt == OcrStatus.Error && ocrErr != null)
                                                {
                                                    <div class="oda-ocr-err-msg">
                                                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                                        @ocrErr
                                                    </div>
                                                }
                                            </div>

                                            <div class="oda-col-form">
                                                <p class="oda-col-label">
                                                    <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                    Données de l'offre
                                                    @if (ocrSt == OcrStatus.Done)
                                                    {
                                                        <span class="oda-label-badge">
                                                            <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                                            Pré-rempli par l'IA
                                                        </span>
                                                    }
                                                </p>

                                                <div class="oda-lignes-section">
                                                    <p class="oda-lignes-title">
                                                        <svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                                                        Conditions de l'offre
                                                    </p>
                                                    <div class="oda-lignes-table-wrap">
                                                        <table class="oda-lignes-table oda-cond-table">
                                                            <thead>
                                                                <tr>
                                                                    <th>Frais de livraison</th>
                                                                    <th>Délai de livraison</th>
                                                                    <th>Garantie</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <tr>
                                                                    <td><input class="oda-tbl-input" type="text" placeholder="0.00" @bind="fs.FraisLivraison" @bind:event="oninput" disabled="@locked" /></td>
                                                                    <td><input class="oda-tbl-input" type="text" placeholder="5" @bind="fs.DelaiLivraison" @bind:event="oninput" disabled="@locked" /></td>
                                                                    <td><input class="oda-tbl-input" type="text" placeholder="12 mois" @bind="fs.Garantie" @bind:event="oninput" disabled="@locked" /></td>
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </div>

                                                    @if (fs.Lignes.Any())
                                                    {
                                                        <p class="oda-lignes-title oda-lignes-title-border">
                                                            <svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                                                            Lignes de commande (@fs.Lignes.Count)
                                                        </p>
                                                        <div class="oda-lignes-table-wrap">
                                                            <table class="oda-lignes-table">
                                                                <thead>
                                                                    <tr>
                                                                        <th>Description</th><th>Qté</th><th>Unité</th>
                                                                        <th>P.U. HT</th><th>TVA %</th><th>Total TVA</th><th>Total TTC</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    @foreach (var ligne in fs.Lignes)
                                                                    {
                                                                        <tr>
                                                                            <td><input class="oda-tbl-input" type="text" @bind="ligne.Description" @bind:event="oninput" disabled="@locked" /></td>
                                                                            <td><input class="oda-tbl-input oda-tbl-sm" type="text" @bind="ligne.Quantite" @bind:event="oninput" disabled="@locked" /></td>
                                                                            <td><input class="oda-tbl-input oda-tbl-sm" type="text" @bind="ligne.Unite" @bind:event="oninput" disabled="@locked" /></td>
                                                                            <td><input class="oda-tbl-input oda-tbl-sm" type="text" @bind="ligne.PrixUnitaireHt" @bind:event="oninput" disabled="@locked" /></td>
                                                                            <td><input class="oda-tbl-input oda-tbl-sm" type="text" @bind="ligne.TvaPct" @bind:event="oninput" disabled="@locked" /></td>
                                                                            <td><input class="oda-tbl-input oda-tbl-sm" type="text" @bind="ligne.TotalTva" @bind:event="oninput" disabled="@locked" /></td>
                                                                            <td><input class="oda-tbl-input oda-tbl-sm oda-tbl-ttc" type="text" @bind="ligne.TotalTtc" @bind:event="oninput" disabled="@locked" /></td>
                                                                        </tr>
                                                                    }
                                                                </tbody>
                                                            </table>
                                                        </div>

                                                        <div class="oda-totaux">
                                                            <div class="oda-totaux-row">
                                                                <span class="oda-totaux-lbl">Total HT</span>
                                                                <input class="oda-totaux-input" type="text" @bind="fs.TotalHt" @bind:event="oninput" placeholder="0,00" disabled="@locked" />
                                                            </div>
                                                            <div class="oda-totaux-row">
                                                                <span class="oda-totaux-lbl">Total TVA</span>
                                                                <input class="oda-totaux-input" type="text" @bind="fs.TotalTva" @bind:event="oninput" placeholder="0,00" disabled="@locked" />
                                                            </div>
                                                            <div class="oda-totaux-row oda-totaux-ttc">
                                                                <span class="oda-totaux-lbl">Total TTC</span>
                                                                <input class="oda-totaux-input ttc" type="text" @bind="fs.TotalTtc" @bind:event="oninput" placeholder="0,00" disabled="@locked" />
                                                            </div>
                                                        </div>
                                                    }
                                                </div>

                                                <div class="oda-form-actions">
                                                    <button class="oda-btn-ghost"
                                                            @onclick="() => ResetForm(offre.IdOffre)"
                                                            @onclick:stopPropagation="true"
                                                            disabled="@locked">
                                                        Réinitialiser
                                                    </button>
                                                    @if (confirmed)
                                                    {
                                                        <button class="oda-btn-confirmed" disabled @onclick:stopPropagation="true">
                                                            <svg viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                                                            Confirmé
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="oda-btn-confirm"
                                                                @onclick="() => OpenConfirmModal(offre)"
                                                                @onclick:stopPropagation="true"
                                                                disabled="@locked">
                                                            <svg viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                                                            Confirmer la sélection
                                                        </button>
                                                    }
                                                </div>

                                                @if (_saveError != null && selected)
                                                {
                                                    <div class="oda-ocr-err-msg" style="margin-top:0.5rem">
                                                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>
                                                        @_saveError
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </main>
    </div>

</div>
@* ══ BOUTON CHATBOT FLOTTANT ══ *@
<button class="oda-chat-fab @(_chatOpen ? "is-open" : "")"
        @onclick="ToggleChat">
    @if (_chatOpen)
    {
        <svg viewBox="0 0 24 24" fill="none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    }
    else
    {
        <svg viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    }
    @if (!_chatOpen && _unreadCount > 0)
    {
        <span class="oda-chat-badge">@_unreadCount</span>
    }
</button>

@* ══ PANNEAU CHATBOT ══ *@
@if (_chatOpen)
{
    <div class="oda-chat-panel">
        <div class="oda-chat-panel-header">
            <div class="oda-chat-panel-avatar">
                <svg viewBox="0 0 24 24" fill="none"><path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/></svg>
            </div>
            <div>
                <p class="oda-chat-panel-name">Assistant IA — Groq</p>
                <div class="oda-chat-panel-status">
                    <span class="oda-status-dot"></span> EN LIGNE
                </div>
            </div>
            <button class="oda-chat-panel-close" @onclick="ToggleChat">
                <svg viewBox="0 0 24 24" fill="none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>

        <div class="oda-chat-messages" id="chatMessages">
            @if (!_chatMessages.Any())
            {
                <div class="oda-chat-welcome">
                    <p>Bonjour ! Je suis votre assistant pour la demande <strong>#@DemandeId</strong>.</p>
                    <p>Analysez les offres avec l'OCR puis posez-moi vos questions pour m'aider à choisir la meilleure.</p>
                </div>
            }
            @foreach (var msg in _chatMessages)
            {
                <div class="oda-chat-msg @(msg.Role == "user" ? "oda-chat-msg-user" : "oda-chat-msg-bot")">
                    @if (msg.Role == "assistant")
                    {
                        <div class="oda-chat-msg-avatar">
                            <svg viewBox="0 0 24 24" fill="none"><path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/></svg>
                        </div>
                    }
                    <div class="oda-chat-msg-bubble">@((MarkupString)FormatChatMessage(msg.Content))</div>
                </div>
            }
            @if (_chatLoading)
            {
                <div class="oda-chat-msg oda-chat-msg-bot">
                    <div class="oda-chat-msg-avatar">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/></svg>
                    </div>
                    <div class="oda-chat-msg-bubble oda-chat-typing">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            }
        </div>

        <div class="oda-chat-panel-footer">
            <div class="oda-chat-input-wrap">
                <input class="oda-chat-input"
                       type="text"
                       placeholder="Posez votre question..."
                       @bind="_chatInput"
                       @bind:event="oninput"
                       @onkeydown="OnChatKeyDown"
                       disabled="@(_chatLoading || _confirmedId.HasValue)" />
                <button class="oda-chat-send"
                        @onclick="SendChatMessage"
                        disabled="@(_chatLoading || string.IsNullOrWhiteSpace(_chatInput) || _confirmedId.HasValue)">
                    <svg viewBox="0 0 24 24" fill="none"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
            </div>
            @if (_confirmedId.HasValue)
            {
                <p class="oda-chat-disabled-hint">Chat désactivé après confirmation de l'offre.</p>
            }
        </div>
    </div>
}
</RoleAuthGuard>
