@* ============================================================
   AssetFlow.BlazorUI / Pages / IT / OffresDemandeIT.razor
   ============================================================ *@

@page "/it/offres/{DemandeId:int}"
@using AssetFlow.Application.DTOs
@using AssetFlow.BlazorUI.Components

<RoleAuthGuard AllowedRoles="@(new[]{"IT","Admin"})">
<div class="oda-layout">

    @* ══════════════════════════════════════════
       SIDEBAR — copie exacte de MesDemandesAchat
    ══════════════════════════════════════════ *@
