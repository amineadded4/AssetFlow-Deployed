@page "/"
@namespace AssetFlow.BlazorUI.Pages.RoleSelection
@using AssetFlow.BlazorUI.Components

<div class="role-select-page" @onkeydown="HandleKeyDown" tabindex="0" autofocus>

    <div class="role-select-header">
        <img src="images/logo.png" alt="AssetFlow" class="role-select-logo" />
        <p class="role-select-subtitle">Sélectionnez votre rôle pour continuer</p>
    </div>

    <div class="roles-container">

        <div class="role-card" @onclick='() => SelectRole("IT")'>
            <div class="role-icon-container" style="background:rgba(124,58,237,0.1);">
                <svg viewBox="0 0 24 24" style="stroke:#7C3AED;fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <path d="M8 21h8M12 17v4"/>
                </svg>
            </div>
            <div class="role-title">IT</div>
            <p class="role-description-text">Gestion du matériel, affectations, demandes d'achat, prédictions IA</p>
            <button class="btn-role" style="background:#7C3AED;">Continuer →</button>
        </div>

        <div class="role-card" @onclick='() => SelectRole("EquipeAchat")'>
            <div class="role-icon-container" style="background:rgba(16,185,129,0.1);">
                <svg viewBox="0 0 24 24" style="stroke:#10B981;fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
                    <path d="M3 6h18"/>
                    <path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
            </div>
            <div class="role-title">Équipe Achat</div>
            <p class="role-description-text">Réception demandes, gestion offres, OCR automatique, scoring IA</p>
            <button class="btn-role" style="background:#10B981;">Continuer →</button>
        </div>

        <div class="role-card" @onclick='() => SelectRole("Employe")'>
            <div class="role-icon-container" style="background:rgba(245,158,11,0.1);">
                <svg viewBox="0 0 24 24" style="stroke:#F59E0B;fill:none;stroke-width:1.75;stroke-linecap:round;stroke-linejoin:round;">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
            </div>
            <div class="role-title">Employé</div>
            <p class="role-description-text">Consultation équipements affectés, signalement incidents, QR codes</p>
            <button class="btn-role" style="background:#F59E0B;">Continuer →</button>
        </div>

    </div>

    <div class="admin-hint">
        <p>Mode avancé : tapez 'admin' pour accéder</p>
    </div>

</div>

@* ============================================================
   MODAL ADMIN — 2 onglets : Classique / Reconnaissance faciale
   ============================================================ *@
@if (ShowAdminModal)
{
    <div class="admin-modal-overlay" @onclick="CloseModal">
        <div class="admin-modal" @onclick:stopPropagation="true">

            @* En-tête *@
            <div class="admin-modal-header">
                <div class="admin-modal-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                </div>
                <div>
                    <h2 class="admin-modal-title">Accès Administrateur</h2>
                    <p class="admin-modal-subtitle">Mode avancé — authentification requise</p>
                </div>
                <button class="admin-modal-close" @onclick="CloseModal">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 6 6 18M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            @* Onglets *@
            <div class="admin-tabs">
                <button class="admin-tab @(ActiveTab == "classic" ? "active" : "")"
                        @onclick='() => SwitchTab("classic")'>
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="11" x="3" y="11" rx="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    Mot de passe
                </button>
                <button class="admin-tab @(ActiveTab == "face" ? "active" : "")"
                        @onclick='() => SwitchTab("face")'>
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 10h.01M15 10h.01"/>
                        <path d="M12 2a8 8 0 0 0-8 8v1a8 8 0 0 0 16 0v-1a8 8 0 0 0-8-8z"/>
                        <path d="M9 14s.5 1 3 1 3-1 3-1"/>
                    </svg>
                    Reconnaissance faciale
                </button>
            </div>

            @* ── ONGLET CLASSIC ── *@
            @if (ActiveTab == "classic")
            {
                @if (!string.IsNullOrEmpty(AdminErrorMessage))
                {
                    <div class="admin-alert-error">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
                        </svg>
                        @AdminErrorMessage
                    </div>
                }

                <div class="admin-form">
                    <div class="admin-input-group">
                        <label class="admin-field-label">E-mail</label>
                        <div class="admin-input-wrapper">
                            <svg class="admin-input-icon" viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="20" height="16" x="2" y="4" rx="2"/>
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                            </svg>
                            <input class="admin-form-input @(AdminEmailError ? "has-error" : "")"
                                   type="email" placeholder="admin@assetflow.com"
                                   @bind="AdminEmail" @bind:event="oninput"
                                   @onkeydown="HandleModalKeyDown" />
                        </div>
                        @if (AdminEmailError) { <span class="admin-error-text">Adresse email invalide</span> }
                    </div>

                    <div class="admin-input-group">
                        <label class="admin-field-label">Mot de passe</label>
                        <div class="admin-input-wrapper">
                            <svg class="admin-input-icon" viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="18" height="11" x="3" y="11" rx="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                            <input class="admin-form-input"
                                   type="@(ShowAdminPassword ? "text" : "password")"
                                   placeholder="••••••••"
                                   @bind="AdminPassword" @bind:event="oninput"
                                   @onkeydown="HandleModalKeyDown" />
                            <button class="admin-toggle-password" type="button" @onclick="ToggleAdminPassword" tabindex="-1">
                                @if (ShowAdminPassword)
                                {
                                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                                        <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><path d="m2 2 20 20"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>
                                    </svg>
                                }
                            </button>
                        </div>
                    </div>
                </div>

                <button class="admin-btn-login" @onclick="HandleAdminLogin" disabled="@AdminIsLoading">
                    @if (AdminIsLoading) { <span class="admin-spinner"></span> <span>Connexion...</span> }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                            <polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/>
                        </svg>
                        <span>Accéder au panneau admin</span>
                    }
                </button>
            }

            @* ── ONGLET FACE ── *@
            @if (ActiveTab == "face")
            {
                @if (!string.IsNullOrEmpty(FaceErrorMessage))
                {
                    <div class="admin-alert-error">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
                        </svg>
                        @FaceErrorMessage
                    </div>
                }

                @* Email *@
                <div class="admin-input-group" style="margin-bottom:0.85rem;">
                    <label class="admin-field-label">E-mail administrateur</label>
                    <div class="admin-input-wrapper">
                        <svg class="admin-input-icon" viewBox="0 0 24 24" fill="none" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="20" height="16" x="2" y="4" rx="2"/>
                            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                        </svg>
                        <input class="admin-form-input" type="email" placeholder="admin@assetflow.com"
                               @bind="FaceEmail" @bind:event="oninput" />
                    </div>
                </div>

                @* Caméra *@
                <div class="face-camera-container">
                    <video id="face-video" autoplay muted playsinline style="display:none;"></video>
                    <canvas id="face-canvas" class="face-canvas"></canvas>

                    @if (!CameraStarted)
                    {
                        <div class="face-camera-placeholder">
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M23 7l-7 5 7 5V7z"/>
                                <rect x="1" y="5" width="15" height="14" rx="2"/>
                            </svg>
                            <p>Caméra non démarrée</p>
                        </div>
                    }

                    @* Indicateur visage *@
                    <div class="face-status @(FaceDetected ? "detected" : "waiting")">
                        @if (FaceDetected)
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 10h.01M15 10h.01"/>
                                <path d="M12 2a8 8 0 0 0-8 8v1a8 8 0 0 0 16 0v-1a8 8 0 0 0-8-8z"/>
                                <path d="M9 14s.5 1 3 1 3-1 3-1"/>
                            </svg>
                            <span>Visage détecté</span>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/><path d="M8 15h8M9 9h.01M15 9h.01"/>
                            </svg>
                            <span>Regardez la caméra...</span>
                        }
                    </div>
                </div>

                <button class="admin-btn-login admin-btn-face" @onclick="HandleFaceLogin"
                        disabled="@(FaceIsLoading || !FaceDetected)">
                    @if (FaceIsLoading) { <span class="admin-spinner"></span> <span>Analyse en cours...</span> }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 10h.01M15 10h.01"/>
                            <path d="M12 2a8 8 0 0 0-8 8v1a8 8 0 0 0 16 0v-1a8 8 0 0 0-8-8z"/>
                        </svg>
                        <span>Se connecter avec mon visage</span>
                    }
                </button>
            }

            <p class="admin-modal-footer">Accès restreint — Administrateurs uniquement</p>
        </div>
    </div>
}
